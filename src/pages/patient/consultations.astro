  // Función simplificada para generar PDF desde vista de paciente
  async function generateSimplePDF(history: any, patient: any) {
    try {
      // Cargar jsPDF dinámicamente si no está cargado
      if (!(window as any).jspdf) {
        const script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
        document.head.appendChild(script);
        
        await new Promise((resolve, reject) => {
          script.onload = resolve;
          script.onerror = () => reject(new Error('No se pudo cargar jsPDF'));
          setTimeout(() => reject(new Error('Timeout cargando jsPDF')), 10000);
        });
      }
      
      const { jsPDF } = (window as any).jspdf;
      const doc = new jsPDF();
      
      // Configuración básica
      const pageWidth = doc.internal.pageSize.getWidth();
      const pageHeight = doc.internal.pageSize.getHeight();
      const margin = 20;
      let yPosition = margin;
      
      // Función para verificar espacio y añadir página si es necesario
      function checkPage(neededSpace = 20) {
        if (yPosition + neededSpace > pageHeight - margin) {
          doc.addPage();
          yPosition = margin;
        }
      }
      
      // Función para agregar texto con salto de línea
      function addText(text: string, fontSize = 10, style = 'normal', color = [0, 0, 0], maxWidth = pageWidth - 2 * margin) {
        checkPage(fontSize + 5);
        
        doc.setFontSize(fontSize);
        doc.setFont('helvetica', style);
        doc.setTextColor(color[0], color[1], color[2]);
        
        const lines = doc.splitTextToSize(text, maxWidth);
        lines.forEach((line: string, index: number) => {
          if (index > 0) checkPage(fontSize);
          doc.text(line, margin, yPosition);
          yPosition += fontSize * 0.6;
        });
        yPosition += 5;
      }
      
      // Función para agregar foto del paciente
      async function addPatientPhoto() {
        if (patient.photo_path) {
          try {
            // Crear imagen para obtener dimensiones
            const img = new Image();
            img.crossOrigin = 'anonymous';
            
            return new Promise((resolve) => {
              img.onload = function() {
                try {
                  const canvas = document.createElement('canvas');
                  const ctx = canvas.getContext('2d');
                  
                  if (!ctx) {
                    // Silently fail
                    resolve(null);
                    return;
                  }
                  
                  // Configurar canvas con tamaño fijo para el PDF
                  const photoWidth = 40;
                  const photoHeight = 50;
                  canvas.width = photoWidth * 3; // Alta resolución
                  canvas.height = photoHeight * 3;
                  
                  // Dibujar imagen escalada
                  ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                  
                  // Convertir a base64
                  const imageData = canvas.toDataURL('image/jpeg', 0.8);
                  
                  // Agregar al PDF
                  doc.addImage(imageData, 'JPEG', pageWidth - margin - photoWidth, yPosition, photoWidth, photoHeight);
                  
                  resolve(null);
                } catch (error) {
                  console.log('Error procesando la imagen:', error);
                  resolve(null);
                }
              };
              
              img.onerror = function() {
                console.log('No se pudo cargar la foto del paciente');
                resolve(null);
              };
              
              // Construir la URL completa de la foto
              const photoUrl = patient.photo_path.startsWith('http') 
                ? patient.photo_path 
                : `${window.location.origin}${patient.photo_path}`;
              
              console.log('Intentando cargar foto desde:', photoUrl);
              img.src = photoUrl;
            });
          } catch (error) {
            console.log('Error procesando foto del paciente:', error);
          }
        }
      }
      
      // Header del documento
      doc.setFillColor(240, 248, 255);
      doc.rect(0, 0, pageWidth, 35, 'F');
      
      doc.setFontSize(16);
      doc.setFont('helvetica', 'bold');
      doc.setTextColor(0, 100, 200);
      doc.text('HISTORIA MÉDICA OCUPACIONAL', margin, 20);
      
      doc.setFontSize(10);
      doc.setFont('helvetica', 'normal');
      doc.setTextColor(100, 100, 100);
      doc.text('Sistema de Salud Ocupacional', margin, 30);
      
      yPosition = 45;
      
      // Agregar foto del paciente
      const photoYPosition = yPosition;
      await addPatientPhoto();
      
      // Información del paciente (al lado de la foto)
      addText('INFORMACIÓN DEL PACIENTE', 12, 'bold', [0, 100, 200]);
      addText(`Nombre: ${patient.name || 'N/A'}`);
      
      if (patient.document_type && patient.document_number) {
        addText(`Documento: ${patient.document_type}: ${patient.document_number}`);
      }
      
      if (patient.date_of_birth) {
        const age = new Date().getFullYear() - new Date(patient.date_of_birth).getFullYear();
        addText(`Fecha de nacimiento: ${new Date(patient.date_of_birth).toLocaleDateString('es-ES')} (${age} años)`);
      }
      
      addText(`Género: ${patient.gender || 'No especificado'}`);
      addText(`Empresa: ${patient.company || 'No especificada'}`);
      addText(`Ocupación: ${patient.occupation || 'No especificada'}`);
      addText(`Tipo de sangre: ${patient.blood_type || 'No especificado'}`);
      addText(`Alergias: ${patient.allergies || 'Ninguna registrada'}`);
      
      // Asegurar que estemos debajo de la foto
      yPosition = Math.max(yPosition, photoYPosition + 60);
      
      // Información de la consulta
      yPosition += 10;
      addText('INFORMACIÓN DE LA CONSULTA', 12, 'bold', [0, 100, 200]);
      addText(`Fecha: ${new Date(history.created_at).toLocaleDateString('es-ES', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      })}`);
      addText(`Doctor: Dr. ${history.doctor_name || 'N/A'}`);
      if (history.cie10_code) {
        addText(`Código CIE-10: ${history.cie10_code}`);
      }
      
      // Motivo de consulta
      yPosition += 5;
      addText('MOTIVO DE CONSULTA', 12, 'bold', [0, 100, 200]);
      addText(history.symptoms || 'No especificado');
      
      // Enfermedad actual
      if (history.current_illness) {
        yPosition += 5;
        addText('ENFERMEDAD ACTUAL', 12, 'bold', [0, 100, 200]);
        addText(history.current_illness);
      }
      
      // Signos vitales
      if (history.vital_signs) {
        try {
          const vitalSigns = typeof history.vital_signs === 'string' 
            ? JSON.parse(history.vital_signs) 
            : history.vital_signs;
            
          yPosition += 5;
          addText('SIGNOS VITALES', 12, 'bold', [0, 100, 200]);
          
          if (vitalSigns.systolic_pressure && vitalSigns.diastolic_pressure) {
            addText(`Presión arterial: ${vitalSigns.systolic_pressure}/${vitalSigns.diastolic_pressure} mmHg`);
          }
          if (vitalSigns.heart_rate) {
            addText(`Frecuencia cardíaca: ${vitalSigns.heart_rate} lpm`);
          }
          if (vitalSigns.weight && vitalSigns.height) {
            const bmi = (vitalSigns.weight / Math.pow(vitalSigns.height/100, 2)).toFixed(1);
            addText(`Peso: ${vitalSigns.weight} kg`);
            addText(`Estatura: ${vitalSigns.height} cm`);
            addText(`IMC: ${bmi}`);
          }
          if (vitalSigns.temperature) {
            addText(`Temperatura: ${vitalSigns.temperature}°C`);
          }
          if (vitalSigns.oxygen_saturation) {
            addText(`Saturación de oxígeno: ${vitalSigns.oxygen_saturation}%`);
          }
        } catch (error) {
          console.error('Error procesando signos vitales:', error);
        }
      }
      
      // Antecedentes
      if (history.personal_history || history.family_history || history.surgical_history) {
        yPosition += 5;
        addText('ANTECEDENTES', 12, 'bold', [0, 100, 200]);
        
        if (history.personal_history) {
          addText('Personales:', 10, 'bold');
          addText(history.personal_history);
        }
        if (history.family_history) {
          addText('Familiares:', 10, 'bold');
          addText(history.family_history);
        }
        if (history.surgical_history) {
          addText('Quirúrgicos:', 10, 'bold');
          addText(history.surgical_history);
        }
      }
      
      // Examen físico
      if (history.physical_exam) {
        yPosition += 5;
        addText('EXAMEN FÍSICO', 12, 'bold', [0, 100, 200]);
        addText(history.physical_exam);
      }
      
      // Diagnóstico
      yPosition += 5;
      addText('DIAGNÓSTICO', 12, 'bold', [0, 150, 0]);
      addText(history.diagnosis || 'No especificado');
      
      // Tratamiento
      yPosition += 5;
      addText('PLAN DE TRATAMIENTO', 12, 'bold', [200, 100, 0]);
      addText(history.treatment || 'No especificado');
      
      // Medicamentos
      if (history.medications) {
        yPosition += 5;
        addText('MEDICAMENTOS PRESCRITOS', 12, 'bold', [150, 0, 150]);
        addText(history.medications);
      }
      
      // Recomendaciones
      if (history.recommendations) {
        yPosition += 5;
        addText('RECOMENDACIONES', 12, 'bold', [0, 100, 200]);
        addText(history.recommendations);
      }
      
      // Próxima cita
      if (history.next_appointment_date) {
        yPosition += 5;
        addText('PRÓXIMA CITA', 12, 'bold', [0, 100, 200]);
        addText(new Date(history.next_appointment_date).toLocaleDateString('es-ES'));
      }
      
      // Notas adicionales
      if (history.notes) {
        yPosition += 5;
        addText('NOTAS ADICIONALES', 12, 'bold', [0, 100, 200]);
        addText(history.notes);
      }
      
      // Footer
      doc.setFontSize(8);
      doc.setTextColor(100, 100, 100);
      doc.text(`Generado el ${new Date().toLocaleDateString('es-ES')} - Sistema de Salud Ocupacional`, 
               margin, pageHeight - 15);
      
      // Guardar
      const fileName = `Historia_Medica_${(patient.name || 'Paciente').replace(/\s+/g, '_')}_${new Date(history.created_at).toISOString().split('T')[0]}.pdf`;
      doc.save(fileName);
      
      showSweetAlert('success', '¡PDF Generado!', 'Historia médica descargada exitosamente', 2000);
      
    } catch (error) {
      // Silently fail
      showSweetAlert('error', 'Error al Generar PDF', (error instanceof Error ? error.message : 'Error desconocido'));
    }
  }

