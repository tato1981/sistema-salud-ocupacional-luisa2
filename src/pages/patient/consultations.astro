    (window as any).downloadSinglePDF = (historyId: number) => {
      (window as any).downloadMedicalHistoryPDF(historyId);
    };
    
    (window as any).downloadAllHistoriesPDF = async () => {
      try {
        // Obtener todas las historias desde el endpoint existente
        const response = await fetch('/api/patient/medical-history/complete');
        const result = await response.json();
        
        if (!result.success || !Array.isArray(result.data)) {
          throw new Error(result.message || 'No se pudo obtener el historial completo');
        }
        
        const histories = result.data;
        if (histories.length === 0) {
          (window as any).showSweetAlert?.('info', 'Sin registros', 'No hay historias para descargar');
          return;
        }
        
        // Cargar jsPDF si no está cargado
        if (!(window as any).jspdf) {
          const script = document.createElement('script');
          script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
          document.head.appendChild(script);
          await new Promise((resolve, reject) => {
            script.onload = resolve;
            script.onerror = () => reject(new Error('No se pudo cargar jsPDF'));
            setTimeout(() => reject(new Error('Timeout cargando jsPDF')), 10000);
          });
        }
        
        const { jsPDF } = (window as any).jspdf;
        const doc = new jsPDF();
        
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        const margin = 15;
        let y = margin;
        
        // Portada
        doc.setFontSize(16);
        doc.text('Historial Médico Completo', margin, y);
        y += 10;
        doc.setFontSize(11);
        const patientName = (typeof currentPatient !== 'undefined' && currentPatient?.name) ? currentPatient.name : 'Paciente';
        doc.text(`Paciente: ${patientName}`, margin, y);
        y += 8;
        doc.text(`Total de consultas: ${histories.length}`, margin, y);
        
        // Iterar historias
        histories.forEach((history: any, index: number) => {
          if (index > 0) {
            doc.addPage();
            y = margin;
          }
          
          doc.setFontSize(14);
          doc.text(`Consulta #${histories.length - index}`, margin, y);
          y += 8;
          doc.setFontSize(10);
          const dateStr = new Date(history.created_at).toLocaleString('es-ES');
          doc.text(`Fecha: ${dateStr}`, margin, y);
          y += 6;
          doc.text(`Doctor: ${history.doctor_name || 'N/A'}`, margin, y);
          y += 10;
          
          // Secciones
          function addSection(title: string, value?: string) {
            if (!value) return;
            doc.setFontSize(11);
            doc.text(title, margin, y);
            y += 6;
            doc.setFontSize(10);
            const lines = doc.splitTextToSize(value, pageWidth - margin * 2);
            doc.text(lines, margin, y);
            y += Math.min(60, lines.length * 5 + 4); // limitar crecimiento
          }
          
          addSection('Motivo de consulta', history.symptoms);
          addSection('Diagnóstico', history.diagnosis);
          addSection('Plan de tratamiento', history.treatment);
          addSection('Observaciones', history.notes);
          
          // Footer de página
          doc.setFontSize(8);
          const footerY = pageHeight - 10;
          doc.text(`Generado por Sistema de Salud Ocupacional - ${new Date().toLocaleDateString('es-ES')}`,
                   margin, footerY);
        });
        
        const fileSafeName = patientName.replace(/[^a-zA-Z0-9\s]/g, '').replace(/\s+/g, '_');
        doc.save(`Historial_Completo_${fileSafeName}.pdf`);
        (window as any).showSweetAlert?.('success', 'PDF generado', 'Descarga completada', 2000);
      } catch (error) {
        console.error('Error generando PDF completo:', error);
        (window as any).showSweetAlert?.('error', 'Error al generar PDF', (error as any)?.message || 'Error desconocido');
      }
    };
    
    // Cerrar con ESC
    const handleEsc = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        (window as any).closeCompleteHistoryModal();
        document.removeEventListener('keydown', handleEsc);
      }
    };
    document.addEventListener('keydown', handleEsc);
  }

  // Cargar datos iniciales
  document.addEventListener('DOMContentLoaded', () => {
    initializeEventListeners();
    loadPatientInfo().then(() => {
      loadUpcomingAppointments();
      loadAppointmentsHistory();
    });
  });
</script>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  // Verificar que SweetAlert2 se cargó correctamente
  window.addEventListener('load', function() {
    // Silently fail
  });

  // Función helper para mostrar alertas con SweetAlert2
  function showSweetAlert(type: string, title: string, message: string, timer?: number) {
    if (typeof (window as any).Swal === 'undefined') {
      alert(`${title}: ${message}`);
      return;
    }
    
    const config: any = {
      icon: type,
      title: title,
      text: message,
      confirmButtonColor: '#3B82F6'
    };
    
    if (timer) {
      config.timer = timer;
      config.showConfirmButton = false;
    }
    
    return (window as any).Swal.fire(config);
  }

  // Función para confirmaciones con SweetAlert2
  function showSweetConfirm(title: string, message: string, confirmText: string = 'Sí, continuar') {
    if (typeof (window as any).Swal === 'undefined') {
      return Promise.resolve(confirm(`${title}: ${message}`));
    }
    
    return (window as any).Swal.fire({
      title: title,
      text: message,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#3B82F6',
      cancelButtonColor: '#d33',
      confirmButtonText: confirmText,
      cancelButtonText: 'Cancelar'
    }).then((result: any) => result.isConfirmed);
  }

  // Hacer las funciones disponibles globalmente
  (window as any).showSweetAlert = showSweetAlert;
  (window as any).showSweetConfirm = showSweetConfirm;
</script>
