---
import Layout from '../../../../layouts/Layout.astro';
import MedicalHistoryForm from '../../../../components/ui/MedicalHistoryForm.astro';
import { requireAuth, hasRole } from '../../../../lib/auth.js';
import { db } from '../../../../lib/database.js';

// Verificar autenticación y rol de doctor
const user = requireAuth(Astro.cookies);
if (!hasRole(user, 'doctor')) {
  return Astro.redirect('/auth/login');
}

// Obtener ID del paciente desde los parámetros
const patientId = Astro.params.id;

// Verificar si estamos editando una historia existente
const editHistoryId = Astro.url.searchParams.get('edit');
let editingHistory = null;

if (!patientId) {
  return Astro.redirect('/doctor/patients');
}

// Obtener información del paciente
let patient = null;
let medicalHistories = [];

try {
  // Obtener datos del paciente
  const [patientRows] = await db.execute(`
    SELECT p.*, 
           u.name as doctor_name,
           u.specialization as doctor_specialization,
           c.name as company_name
    FROM patients p
    LEFT JOIN users u ON p.assigned_doctor_id = u.id
    LEFT JOIN companies c ON p.company_id = c.id
    WHERE p.id = ?
  `, [patientId]);

  if ((patientRows as any[]).length === 0) {
    return Astro.redirect('/doctor/patients');
  }

  patient = (patientRows as any[])[0];

  // Verificar que el doctor tenga acceso a este paciente
  // Los doctores pueden acceder a todos los pacientes en el sistema para evaluaciones ocupacionales
  // Solo se restringe si hay un doctor asignado específico y no es el actual
  // El admin tiene acceso total
  if (user.role !== 'admin' && patient.assigned_doctor_id && patient.assigned_doctor_id !== user.id) {
      // Verificar si el doctor actual puede ver otros pacientes (para consultas ocupacionales)
      // Silently fail or redirect
      // Por ahora permitimos el acceso para evaluaciones ocupacionales
      // return Astro.redirect('/doctor/patients');
    }

  // Obtener historias médicas del paciente
  const [historyRows] = await db.execute(`
    SELECT 
      mh.*,
      u.name as doctor_name,
      a.appointment_date,
      a.appointment_type
    FROM medical_histories mh
    LEFT JOIN users u ON mh.doctor_id = u.id
    LEFT JOIN appointments a ON mh.appointment_id = a.id
    WHERE mh.patient_id = ?
    ORDER BY mh.created_at DESC
  `, [patientId]);

  medicalHistories = historyRows as any[];

  // Si estamos editando, cargar los datos de la historia específica
  if (editHistoryId) {
    const [editRows] = await db.execute(`
      SELECT 
        mh.*,
        u.name as doctor_name
      FROM medical_histories mh
      LEFT JOIN users u ON mh.doctor_id = u.id
      WHERE mh.id = ? AND mh.patient_id = ?
    `, [editHistoryId, patientId]);

    if ((editRows as any[]).length > 0) {
      editingHistory = (editRows as any[])[0];
    }
  }

} catch (error) {
  // Silently fail
  return Astro.redirect('/doctor/patients');
}

// Calcular edad del paciente
function calculateAge(birthDate: string): number {
  if (!birthDate) return 0;
  const today = new Date();
  const birth = new Date(birthDate);
  let age = today.getFullYear() - birth.getFullYear();
  const monthDiff = today.getMonth() - birth.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {
    age--;
  }
  return age;
}

// Función para obtener formato ISO local (YYYY-MM-DDTHH:mm)
function toLocalISOString(date: Date): string {
  const tzOffset = date.getTimezoneOffset() * 60000;
  return new Date(date.getTime() - tzOffset).toISOString().slice(0, 16);
}

// Lógica para precargar datos (edición o copia de última consulta)
let prefillData: any = {};

if (editingHistory) {
  prefillData = editingHistory;
} else if (medicalHistories.length > 0) {
  // Si es nueva consulta pero tiene historial, precargamos datos de la última vez
  const lastHistory = medicalHistories[0];
  prefillData = {
    ...lastHistory,
    // Limpiamos campos que SIEMPRE deben ser nuevos
    id: undefined,
    created_at: new Date(), // Fecha actual para la nueva historia
    updated_at: undefined,
    appointment_id: undefined,
    // Limpiar JSON de signos vitales
    vital_signs: null,
    // Signos vitales deben medirse en cada consulta
    vital_signs_height: null,
    vital_signs_weight: null,
    vital_signs_bmi: null,
    vital_signs_temperature: null,
    vital_signs_heart_rate: null,
    vital_signs_respiratory_rate: null,
    vital_signs_blood_pressure: null,
    vital_signs_oxygen_saturation: null,
    // Próxima cita se define de nuevo
    next_appointment_date: null
  };
}
---

<Layout title={`Historia Médica - ${patient.name}${editingHistory ? ' (Editando)' : ''}`}>
  <!-- SweetAlert2 CDN - Cargar antes que otros scripts -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" is:inline></script>
  
  <!-- Definir función global para mostrar alertas -->
  <script is:inline>
    // Función global para mostrar alertas con SweetAlert2
    window.showSweetAlert = function(type, title, message, timer = null) {
      if (typeof Swal !== 'undefined') {
        const config = {
          icon: type,
          title: title,
          text: message,
          confirmButtonColor: '#3B82F6',
          allowOutsideClick: false
        };
        
        if (timer) {
          config.timer = timer;
          config.showConfirmButton = false;
        }
        
        Swal.fire(config);
      } else {
        // console.log('SweetAlert2 no disponible, usando alert nativo');
        alert(`${title}: ${message}`);
      }
    };
  </script>
  
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <div class="flex items-center space-x-4">
            <a href={`/doctor/patients/${patient.id}`} class="text-gray-500 hover:text-gray-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
            </a>
            <div>
              <h1 class="text-2xl font-bold text-gray-900">
                {editingHistory ? 'Editar Historia Médica Ocupacional' : 'Historia Médica Ocupacional'}
              </h1>
              <p class="text-sm text-gray-600">
                Paciente: {patient.name}
                {editingHistory && ` - Editando consulta del ${new Date(editingHistory.created_at).toLocaleDateString('es-ES')}`}
              </p>
            </div>
          </div>
          
          <div class="flex items-center space-x-4">
            <button 
              id="newHistoryBtn"
              class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium flex items-center space-x-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              <span>Nueva Historia Médica</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Información del paciente -->
      <div class="bg-white shadow rounded-lg p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Información del Paciente</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-500">Nombre completo</label>
            <p class="mt-1 text-sm text-gray-900">{patient.name}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500">Documento</label>
            <p class="mt-1 text-sm text-gray-900">{patient.document_type}: {patient.document_number}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500">Edad</label>
            <p class="mt-1 text-sm text-gray-900">{calculateAge(patient.date_of_birth)} años</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500">Empresa</label>
            <p class="mt-1 text-sm text-gray-900">{patient.company_name || patient.company || 'No especificada'}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500">Ocupación</label>
            <p class="mt-1 text-sm text-gray-900">{patient.occupation || 'No especificada'}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500">Tipo de sangre</label>
            <p class="mt-1 text-sm text-gray-900">{patient.blood_type || 'No especificado'}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500">Alergias</label>
            <p class="mt-1 text-sm text-gray-900">{patient.allergies || 'Ninguna registrada'}</p>
          </div>
        </div>
      </div>

      <!-- Modal para nueva historia médica (simplificado - el completo está abajo) -->

      <!-- Lista de historias médicas -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">Historial de Consultas Médicas</h2>
        </div>
        
        <div class="p-6">
          {medicalHistories.length === 0 ? (
            <div class="text-center py-12">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No hay historias médicas</h3>
              <p class="mt-1 text-sm text-gray-500">Comience creando la primera historia médica ocupacional para este paciente.</p>
              <div class="mt-6">
                <button 
                  id="firstHistoryBtn"
                  class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                  </svg>
                  Primera Historia Médica
                </button>
              </div>
            </div>
          ) : (
            <div class="space-y-6">
              {medicalHistories.map((history) => (
                <div class="border border-gray-200 rounded-lg p-6 hover:bg-gray-50 transition-colors">
                  <div class="flex justify-between items-start mb-4">
                    <div>
                      <h3 class="text-lg font-semibold text-gray-900">
                        Consulta del {new Date(history.created_at).toLocaleDateString('es-ES', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric'
                        })}
                      </h3>
                      <p class="text-sm text-gray-600">
                        Dr. {history.doctor_name} • 
                        {history.appointment_type ? history.appointment_type.replace('_', ' ').toUpperCase() : 'CONSULTA GENERAL'}
                      </p>
                    </div>
                    <div class="flex space-x-2">
                      <button 
                        onclick={`viewHistory(${history.id})`}
                        class="text-blue-600 hover:text-blue-800 text-sm font-medium">
                        Ver detalles
                      </button>
                      <button 
                        onclick={`editHistory(${history.id})`}
                        class="text-green-600 hover:text-green-800 text-sm font-medium">
                        Editar
                      </button>
                      <button 
                        onclick={`downloadPDF(${history.id})`}
                        class="text-purple-600 hover:text-purple-800 text-sm font-medium">
                        PDF
                      </button>
                    </div>
                  </div>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-500 mb-1">Motivo de consulta</label>
                      <p class="text-sm text-gray-900">{history.symptoms.substring(0, 100)}{history.symptoms.length > 100 ? '...' : ''}</p>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-500 mb-1">Diagnóstico</label>
                      <p class="text-sm text-gray-900">{history.diagnosis.substring(0, 100)}{history.diagnosis.length > 100 ? '...' : ''}</p>
                    </div>
                  </div>
                  
                  <div id={`vital-signs-${history.id}`} class="bg-blue-50 rounded-md p-4" style="display: none;">
                    <h4 class="text-sm font-medium text-blue-900 mb-2">Signos Vitales</h4>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs">
                      <!-- Contenido cargado dinámicamente -->
                    </div>
                  </div>
                  
                  {history.cie10_code && (
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        CIE-10: {history.cie10_code}
                      </span>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Modal para ver detalles de historia médica -->
    <div id="viewHistoryModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-11/12 max-w-4xl shadow-lg rounded-md bg-white">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Detalles de la Historia Médica</h3>
          <div class="flex space-x-2">
            <button 
              id="downloadPDFFromModal"
              class="bg-purple-600 hover:bg-purple-700 text-white px-3 py-1 rounded text-sm">
              Descargar PDF
            </button>
            <button id="closeViewModalBtn" class="text-gray-400 hover:text-gray-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
        
        <div id="historyDetailsContent" class="space-y-6">
          <!-- Contenido cargado dinámicamente -->
        </div>
      </div>
    </div>
  </div>

  <!-- Modal para crear/editar historia médica -->
  <div id="newHistoryModal" class="fixed inset-0 z-50 overflow-y-auto bg-black bg-opacity-50 hidden">
    <div class="flex min-h-screen items-center justify-center p-4">
      <div class="bg-white rounded-lg shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex justify-between items-center">
          <h2 class="text-xl font-bold text-gray-900">
            {editingHistory ? 'Editar Historia Médica' : 'Nueva Historia Médica Ocupacional'}
          </h2>
          <button id="closeModalBtn" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <div class="p-6">
          <form id="medicalHistoryForm" class="space-y-6">
            <!-- Información básica -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Fecha de la consulta</label>
                <input 
                  type="datetime-local" 
                  name="consultation_date" 
                  id="consultation_date"
                  value={editingHistory ? toLocalISOString(new Date(editingHistory.created_at)) : (prefillData.created_at ? toLocalISOString(new Date(prefillData.created_at)) : toLocalISOString(new Date()))}
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                  required
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Código CIE-10 (opcional)</label>
                <input 
                  type="text" 
                  name="cie10_code" 
                  id="cie10_code"
                  value={editingHistory?.cie10_code || ''}
                  placeholder="Ej: Z00.0 (máx. 20 caracteres)"
                  maxlength="20"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>
            </div>

            <!-- Motivo de consulta -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Motivo de consulta *</label>
              <textarea 
                name="symptoms" 
                id="symptoms"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                required
                placeholder="Describa el motivo de la consulta médica ocupacional..."
              >{editingHistory?.symptoms || ''}</textarea>
            </div>

            <!-- Enfermedad actual -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Enfermedad actual</label>
              <textarea 
                name="current_illness" 
                id="current_illness"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Describa la enfermedad o condición actual..."
              >{editingHistory?.current_illness || ''}</textarea>
            </div>

            <!-- Signos vitales -->
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
              <h3 class="text-lg font-semibold text-blue-900 mb-4">Signos Vitales</h3>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Peso (kg)</label>
                  <input 
                    type="number" 
                    name="weight" 
                    id="weight"
                    step="0.1" 
                    min="0"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="70.5"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Altura (cm)</label>
                  <input 
                    type="number" 
                    name="height" 
                    id="height"
                    min="0" 
                    max="250"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="170"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Presión sistólica</label>
                  <input 
                    type="number" 
                    name="systolic_pressure" 
                    id="systolic_pressure"
                    min="0" 
                    max="300"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="120"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Presión diastólica</label>
                  <input 
                    type="number" 
                    name="diastolic_pressure" 
                    id="diastolic_pressure"
                    min="0" 
                    max="200"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="80"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Frecuencia cardíaca</label>
                  <input 
                    type="number" 
                    name="heart_rate" 
                    id="heart_rate"
                    min="0" 
                    max="300"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="72"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Temperatura (°C)</label>
                  <input 
                    type="number" 
                    name="temperature" 
                    id="temperature"
                    step="0.1" 
                    min="30" 
                    max="45"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="36.5"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Saturación O2 (%)</label>
                  <input 
                    type="number" 
                    name="oxygen_saturation" 
                    id="oxygen_saturation"
                    min="0" 
                    max="100"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="98"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">IMC</label>
                  <input 
                    type="text" 
                    id="bmi_display"
                    class="w-full px-3 py-2 bg-gray-100 border border-gray-300 rounded-md"
                    readonly
                    placeholder="Calculado automáticamente"
                  />
                </div>
              </div>
              
              <!-- Alertas de signos vitales -->
              <div id="vitalSignsAlerts" class="mt-4 space-y-2"></div>
            </div>

            <!-- Antecedentes -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Antecedentes personales</label>
                <textarea 
                  name="personal_history" 
                  id="personal_history"
                  rows="4" 
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="Enfermedades previas, cirugías, alergias..."
                >{prefillData.personal_history || ''}</textarea>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Antecedentes familiares</label>
                <textarea 
                  name="family_history" 
                  id="family_history"
                  rows="4" 
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="Enfermedades familiares relevantes..."
                >{prefillData.family_history || ''}</textarea>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Antecedentes quirúrgicos</label>
                <textarea 
                  name="surgical_history" 
                  id="surgical_history"
                  rows="4" 
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="Cirugías previas..."
                >{prefillData.surgical_history || ''}</textarea>
              </div>
            </div>

            <!-- Examen físico -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Examen físico</label>
              <textarea 
                name="physical_exam" 
                id="physical_exam"
                rows="4" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Hallazgos del examen físico..."
              >{prefillData.physical_exam || ''}</textarea>
            </div>

            <!-- Diagnóstico -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Diagnóstico *</label>
              <textarea 
                name="diagnosis" 
                id="diagnosis"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                required
                placeholder="Diagnóstico médico ocupacional..."
              >{prefillData.diagnosis || ''}</textarea>
            </div>

            <!-- Tratamiento -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Plan de tratamiento *</label>
              <textarea 
                name="treatment" 
                id="treatment"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                required
                placeholder="Plan de tratamiento y seguimiento..."
              >{prefillData.treatment || ''}</textarea>
            </div>

            <!-- Medicamentos -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Medicamentos prescritos</label>
              <textarea 
                name="medications" 
                id="medications"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Medicamentos, dosis, frecuencia..."
              >{prefillData.medications || ''}</textarea>
            </div>

            <!-- Recomendaciones -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Recomendaciones</label>
              <textarea 
                name="recommendations" 
                id="recommendations"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Recomendaciones médicas, restricciones laborales..."
              >{prefillData.recommendations || ''}</textarea>
            </div>

            <!-- Próxima cita -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Próxima cita</label>
              <input 
                type="date" 
                name="next_appointment_date" 
                id="next_appointment_date"
                value={prefillData.next_appointment_date ? new Date(prefillData.next_appointment_date).toISOString().split('T')[0] : ''}
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>

            <!-- Notas adicionales -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Notas adicionales</label>
              <textarea 
                name="notes" 
                id="notes"
                rows="3" 
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Observaciones adicionales..."
              >{prefillData.notes || ''}</textarea>
            </div>

            <!-- Botones -->
            <div class="flex justify-end space-x-4 pt-4 border-t border-gray-200">
              <button 
                type="button" 
                id="cancelBtn"
                class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50"
              >
                Cancelar
              </button>
              <button 
                type="submit" 
                id="submitBtn"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700"
              >
                {editingHistory ? 'Actualizar Historia' : 'Guardar Historia'}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ 
    patientId: parseInt(patientId), 
    userId: user.id, 
    patientData: patient,
    editingHistory: editingHistory,
    isEditing: !!editingHistory
  }}>
    // Variables globales
    let currentHistoryForPDF = null;
    
    // Funciones para manejar modales
    function openNewHistoryModal() {
      document.getElementById('newHistoryModal').classList.remove('hidden');
      
      // Si estamos editando, cargar los datos
      if (isEditing && editingHistory) {
        loadEditingData();
      }
    }
    
    function closeNewHistoryModal() {
      document.getElementById('newHistoryModal').classList.add('hidden');
    }
    
    function openViewHistoryModal() {
      document.getElementById('viewHistoryModal').classList.remove('hidden');
    }
    
    function closeViewHistoryModal() {
      document.getElementById('viewHistoryModal').classList.add('hidden');
    }

    // Cargar datos para edición
    function loadEditingData() {
      if (!editingHistory || !editingHistory.vital_signs) return;
      
      try {
        const vitalSigns = typeof editingHistory.vital_signs === 'string' 
          ? JSON.parse(editingHistory.vital_signs) 
          : editingHistory.vital_signs;
        
        // Cargar signos vitales
        if (vitalSigns.weight) document.getElementById('weight').value = vitalSigns.weight;
        if (vitalSigns.height) document.getElementById('height').value = vitalSigns.height;
        if (vitalSigns.systolic_pressure) document.getElementById('systolic_pressure').value = vitalSigns.systolic_pressure;
        if (vitalSigns.diastolic_pressure) document.getElementById('diastolic_pressure').value = vitalSigns.diastolic_pressure;
        if (vitalSigns.heart_rate) document.getElementById('heart_rate').value = vitalSigns.heart_rate;
        if (vitalSigns.temperature) document.getElementById('temperature').value = vitalSigns.temperature;
        if (vitalSigns.oxygen_saturation) document.getElementById('oxygen_saturation').value = vitalSigns.oxygen_saturation;
        
        // Calcular IMC si hay peso y altura
        calculateBMI();
        evaluateVitalSigns();
        
      } catch (error) {
        console.error('Error cargando datos de edición:', error);
      }
    }

    // Calcular IMC automáticamente
    function calculateBMI() {
      const weight = parseFloat(document.getElementById('weight').value);
      const height = parseFloat(document.getElementById('height').value);
      
      if (weight && height && height > 0) {
        const heightInMeters = height / 100;
        const bmi = weight / (heightInMeters * heightInMeters);
        document.getElementById('bmi_display').value = bmi.toFixed(1);
        
        // Clasificación WHO del IMC
        let classification = '';
        if (bmi < 18.5) classification = '(Bajo peso)';
        else if (bmi < 25) classification = '(Normal)';
        else if (bmi < 30) classification = '(Sobrepeso)';
        else classification = '(Obesidad)';
        
        document.getElementById('bmi_display').value = `${bmi.toFixed(1)} ${classification}`;
      } else {
        document.getElementById('bmi_display').value = '';
      }
    }

    // Evaluar signos vitales
    function evaluateVitalSigns() {
      const alertsContainer = document.getElementById('vitalSignsAlerts');
      const alerts = [];
      
      // Evaluar presión arterial
      const systolic = parseFloat(document.getElementById('systolic_pressure').value);
      const diastolic = parseFloat(document.getElementById('diastolic_pressure').value);
      
      if (systolic && diastolic) {
        if (systolic >= 180 || diastolic >= 120) {
          alerts.push({ type: 'error', message: '⚠️ Crisis hipertensiva - Requiere atención inmediata' });
        } else if (systolic >= 140 || diastolic >= 90) {
          alerts.push({ type: 'warning', message: '⚠️ Hipertensión arterial detectada' });
        } else if (systolic < 90 || diastolic < 60) {
          alerts.push({ type: 'warning', message: '⚠️ Presión arterial baja detectada' });
        }
      }
      
      // Evaluar frecuencia cardíaca
      const heartRate = parseFloat(document.getElementById('heart_rate').value);
      if (heartRate) {
        if (heartRate > 100) {
          alerts.push({ type: 'warning', message: '⚠️ Taquicardia detectada (FC > 100 lpm)' });
        } else if (heartRate < 60) {
          alerts.push({ type: 'info', message: 'ℹ️ Bradicardia detectada (FC < 60 lpm)' });
        }
      }
      
      // Mostrar alertas
      alertsContainer.innerHTML = alerts.map(alert => `
        <div class="p-3 rounded-md ${alert.type === 'error' ? 'bg-red-50 border border-red-200 text-red-800' : 
                                     alert.type === 'warning' ? 'bg-yellow-50 border border-yellow-200 text-yellow-800' : 
                                     'bg-blue-50 border border-blue-200 text-blue-800'}">
          ${alert.message}
        </div>
      `).join('');
    }

    // Manejar envío del formulario
    async function handleFormSubmit(event) {
      event.preventDefault();
      
      const formData = new FormData(event.target);
      const submitBtn = document.getElementById('submitBtn');
      
      // Preparar signos vitales
      const vitalSigns = {
        weight: formData.get('weight') ? parseFloat(formData.get('weight')) : null,
        height: formData.get('height') ? parseFloat(formData.get('height')) : null,
        systolic_pressure: formData.get('systolic_pressure') ? parseInt(formData.get('systolic_pressure')) : null,
        diastolic_pressure: formData.get('diastolic_pressure') ? parseInt(formData.get('diastolic_pressure')) : null,
        heart_rate: formData.get('heart_rate') ? parseInt(formData.get('heart_rate')) : null,
        temperature: formData.get('temperature') ? parseFloat(formData.get('temperature')) : null,
        oxygen_saturation: formData.get('oxygen_saturation') ? parseInt(formData.get('oxygen_saturation')) : null
      };
      
      // Validación de longitud CIE-10
      const cie10Val = formData.get('cie10_code');
      if (cie10Val && String(cie10Val).length > 20) {
        if (typeof showSweetAlert === 'function') {
          showSweetAlert('warning', 'Código CIE-10 demasiado largo', 'Máx. 20 caracteres. Ajusta el valor.');
        } else {
          alert('Código CIE-10 demasiado largo. Máx. 20 caracteres.');
        }
        return;
      }

      // Preparar datos
      const data = {
        patient_id: patientId,
        doctor_id: userId,
        consultation_date: formData.get('consultation_date'),
        cie10_code: formData.get('cie10_code') || null,
        symptoms: formData.get('symptoms'),
        current_illness: formData.get('current_illness') || null,
        vital_signs: JSON.stringify(vitalSigns),
        personal_history: formData.get('personal_history') || null,
        family_history: formData.get('family_history') || null,
        surgical_history: formData.get('surgical_history') || null,
        physical_exam: formData.get('physical_exam') || null,
        diagnosis: formData.get('diagnosis'),
        treatment: formData.get('treatment'),
        medications: formData.get('medications') || null,
        recommendations: formData.get('recommendations') || null,
        next_appointment_date: formData.get('next_appointment_date') || null,
        notes: formData.get('notes') || null
      };
      
      try {
        submitBtn.disabled = true;
        submitBtn.textContent = isEditing ? 'Actualizando...' : 'Guardando...';
        
        const url = isEditing 
          ? `/api/doctor/medical-history/${editingHistory.id}` 
          : '/api/doctor/medical-history/create';
        
        const method = isEditing ? 'PUT' : 'POST';
        
        const response = await fetch(url, {
          method: method,
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
          // Usar SweetAlert para éxito
          showSweetAlert(
            'success', 
            isEditing ? 'Historia Actualizada' : 'Historia Creada',
            isEditing ? 'Historia médica actualizada exitosamente' : 'Historia médica creada exitosamente',
            2000
          );
          
          setTimeout(() => {
            if (isEditing) {
              // Recargar la página para mostrar los cambios
              window.location.href = `/doctor/patients/${patientId}/medical-history`;
            } else {
              closeNewHistoryModal();
              location.reload();
            }
          }, 2000);
        } else {
          // Usar SweetAlert para error
          showSweetAlert(
            'error',
            'Error al Guardar',
            result.message || 'No se pudo guardar la historia médica'
          );
        }
      } catch (error) {
        console.error('Error guardando historia médica:', error);
        showSweetAlert(
          'error',
          'Error de Conexión',
          'Error al guardar la historia médica'
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = isEditing ? 'Actualizar Historia' : 'Guardar Historia';
      }
    }
    
    // Event listeners
    document.getElementById('newHistoryBtn')?.addEventListener('click', openNewHistoryModal);
    document.getElementById('firstHistoryBtn')?.addEventListener('click', openNewHistoryModal);
    document.getElementById('closeModalBtn').addEventListener('click', closeNewHistoryModal);
    document.getElementById('closeViewModalBtn')?.addEventListener('click', closeViewHistoryModal);
    document.getElementById('cancelBtn').addEventListener('click', closeNewHistoryModal);
    
    // Event listeners para cálculos automáticos
    document.getElementById('weight').addEventListener('input', calculateBMI);
    document.getElementById('height').addEventListener('input', calculateBMI);
    document.getElementById('systolic_pressure').addEventListener('input', evaluateVitalSigns);
    document.getElementById('diastolic_pressure').addEventListener('input', evaluateVitalSigns);
    document.getElementById('heart_rate').addEventListener('input', evaluateVitalSigns);
    
    // Event listener para el formulario
    document.getElementById('medicalHistoryForm').addEventListener('submit', handleFormSubmit);

    // Validación de entrada CIE-10 en tiempo real
    const cie10Input = document.getElementById('cie10_code');
    if (cie10Input) {
      cie10Input.addEventListener('input', function() {
        if (this.value.length > 20) {
          if (typeof showSweetAlert === 'function') {
            showSweetAlert('warning', 'Código CIE-10 demasiado largo', 'Máx. 20 caracteres. Se recortó automáticamente.');
          }
          this.value = this.value.slice(0, 20);
        }
      });
    }
    
    // Si estamos editando, abrir el modal automáticamente
    if (isEditing) {
      openNewHistoryModal();
    }
    
    // Cerrar modal al hacer clic fuera
    document.getElementById('newHistoryModal').addEventListener('click', function(e) {
      if (e.target === this) closeNewHistoryModal();
    });
    
    document.getElementById('viewHistoryModal').addEventListener('click', function(e) {
      if (e.target === this) closeViewHistoryModal();
    });
    
    // Configurar carga de signos vitales al iniciar
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[id^="vital-signs-"]').forEach(function(element) {
        const historyId = element.id.split('-')[2];
        loadVitalSigns(historyId);
      });
    });
    
    // Cargar signos vitales dinámicamente
    function loadVitalSigns(historyId) {
      // Esta función será llamada para cada historia médica para mostrar los signos vitales
      // Por ahora la dejamos vacía, se puede implementar más tarde si es necesario
    }
    
    // Función para ver detalles de historia médica
    window.viewHistory = async function(historyId) {
      try {
        const response = await fetch(`/api/doctor/medical-history/${historyId}`);
        const result = await response.json();
        
        if (result.success) {
          const history = result.data;
          currentHistoryForPDF = history; // Guardar para PDF
          const content = document.getElementById('historyDetailsContent');
          
          // Parsear signos vitales si existen
          let vitalSigns = null;
          if (history.vital_signs) {
            try {
              vitalSigns = JSON.parse(history.vital_signs);
            } catch (e) {
              console.error('Error parseando signos vitales:', e);
            }
          }
          
          content.innerHTML = `
            <div class="space-y-6">
              <!-- Información básica -->
              <div class="bg-gray-50 rounded-lg p-4">
                <h4 class="font-semibold text-gray-900 mb-2">Información de la Consulta</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                  <div>
                    <span class="font-medium text-gray-700">Fecha:</span>
                    ${new Date(history.created_at).toLocaleDateString('es-ES', {
                      year: 'numeric',
                      month: 'long', 
                      day: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit'
                    })}
                  </div>
                  <div>
                    <span class="font-medium text-gray-700">Doctor:</span>
                    Dr. ${history.doctor_name}
                  </div>
                  ${history.cie10_code ? `
                    <div>
                      <span class="font-medium text-gray-700">Código CIE-10:</span>
                      ${history.cie10_code}
                    </div>
                  ` : ''}
                </div>
              </div>
              
              <!-- Motivo de consulta -->
              <div>
                <h4 class="font-semibold text-gray-900 mb-2">Motivo de Consulta</h4>
                <p class="text-gray-700 bg-gray-50 p-3 rounded">${history.symptoms}</p>
              </div>
              
              ${history.current_illness ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Enfermedad Actual</h4>
                  <p class="text-gray-700 bg-gray-50 p-3 rounded">${history.current_illness}</p>
                </div>
              ` : ''}
              
              <!-- Signos vitales -->
              ${vitalSigns ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Signos Vitales</h4>
                  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                      ${vitalSigns.systolic_pressure ? `
                        <div>
                          <span class="font-medium text-blue-700">Presión arterial:</span>
                          <p class="text-blue-900">${vitalSigns.systolic_pressure}/${vitalSigns.diastolic_pressure} mmHg</p>
                        </div>
                      ` : ''}
                      ${vitalSigns.heart_rate ? `
                        <div>
                          <span class="font-medium text-blue-700">Frecuencia cardíaca:</span>
                          <p class="text-blue-900">${vitalSigns.heart_rate} lpm</p>
                        </div>
                      ` : ''}
                      ${vitalSigns.weight && vitalSigns.height ? `
                        <div>
                          <span class="font-medium text-blue-700">Peso/Estatura:</span>
                          <p class="text-blue-900">${vitalSigns.weight} kg / ${vitalSigns.height} cm</p>
                        </div>
                        <div>
                          <span class="font-medium text-blue-700">IMC:</span>
                          <p class="text-blue-900">${(vitalSigns.weight / Math.pow(vitalSigns.height/100, 2)).toFixed(1)}</p>
                        </div>
                      ` : ''}
                      ${vitalSigns.temperature ? `
                        <div>
                          <span class="font-medium text-blue-700">Temperatura:</span>
                          <p class="text-blue-900">${vitalSigns.temperature}°C</p>
                        </div>
                      ` : ''}
                      ${vitalSigns.oxygen_saturation ? `
                        <div>
                          <span class="font-medium text-blue-700">Saturación O₂:</span>
                          <p class="text-blue-900">${vitalSigns.oxygen_saturation}%</p>
                        </div>
                      ` : ''}
                    </div>
                  </div>
                </div>
              ` : ''}
              
              <!-- Antecedentes -->
              ${(history.personal_history || history.family_history || history.surgical_history) ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Antecedentes</h4>
                  <div class="space-y-3">
                    ${history.personal_history ? `
                      <div>
                        <span class="font-medium text-gray-700">Personales:</span>
                        <p class="text-gray-600 mt-1">${history.personal_history}</p>
                      </div>
                    ` : ''}
                    ${history.family_history ? `
                      <div>
                        <span class="font-medium text-gray-700">Familiares:</span>
                        <p class="text-gray-600 mt-1">${history.family_history}</p>
                      </div>
                    ` : ''}
                    ${history.surgical_history ? `
                      <div>
                        <span class="font-medium text-gray-700">Quirúrgicos:</span>
                        <p class="text-gray-600 mt-1">${history.surgical_history}</p>
                      </div>
                    ` : ''}
                  </div>
                </div>
              ` : ''}
              
              <!-- Examen físico -->
              ${history.physical_exam ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Examen Físico</h4>
                  <p class="text-gray-700 bg-gray-50 p-3 rounded">${history.physical_exam}</p>
                </div>
              ` : ''}
              
              <!-- Diagnóstico -->
              <div>
                <h4 class="font-semibold text-gray-900 mb-2">Diagnóstico</h4>
                <p class="text-gray-700 bg-green-50 border border-green-200 p-3 rounded">${history.diagnosis}</p>
              </div>
              
              <!-- Tratamiento -->
              <div>
                <h4 class="font-semibold text-gray-900 mb-2">Plan de Tratamiento</h4>
                <p class="text-gray-700 bg-yellow-50 border border-yellow-200 p-3 rounded">${history.treatment}</p>
              </div>
              
              <!-- Medicamentos -->
              ${history.medications ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Medicamentos Prescritos</h4>
                  <p class="text-gray-700 bg-purple-50 border border-purple-200 p-3 rounded">${history.medications}</p>
                </div>
              ` : ''}
              
              <!-- Recomendaciones -->
              ${history.recommendations ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Recomendaciones</h4>
                  <div class="bg-blue-50 border border-blue-200 p-3 rounded">
                    <pre class="text-gray-700 whitespace-pre-wrap text-sm">${history.recommendations}</pre>
                  </div>
                </div>
              ` : ''}
              
              <!-- Próxima cita -->
              ${history.next_appointment_date ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Próxima Cita</h4>
                  <p class="text-gray-700">${new Date(history.next_appointment_date).toLocaleDateString('es-ES')}</p>
                </div>
              ` : ''}
              
              <!-- Notas -->
              ${history.notes ? `
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Notas Adicionales</h4>
                  <p class="text-gray-700 bg-gray-50 p-3 rounded">${history.notes}</p>
                </div>
              ` : ''}
            </div>
          `;
          
          openViewHistoryModal();
        } else {
          showSweetAlert(
            'error',
            'Error al Cargar',
            'Error al cargar los detalles de la historia médica'
          );
        }
      } catch (error) {
        console.error('Error cargando historia médica:', error);
        showSweetAlert(
          'error',
          'Error de Conexión',
          'Error de conexión al cargar los detalles'
        );
      }
    };
    
    // Función para editar historia médica
    window.editHistory = function(historyId) {
      // Redirigir a la misma página con parámetro de edición
      const currentUrl = window.location.pathname;
      window.location.href = `${currentUrl}?edit=${historyId}`;
    };
    
    // Función para descargar PDF
    window.downloadPDF = function(historyId) {
      window.open(`/api/doctor/medical-history/pdf/${historyId}`, '_blank');
    };
    
    // Event listener para el botón de PDF en el modal
    document.getElementById('downloadPDFFromModal')?.addEventListener('click', function() {
      if (currentHistoryForPDF) {
        window.downloadPDF(currentHistoryForPDF.id);
      }
    });
    

</script>
</Layout>
