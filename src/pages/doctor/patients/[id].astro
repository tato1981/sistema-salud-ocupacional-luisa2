---
import Layout from '../../../layouts/Layout.astro';
import { requireAuth } from '../../../lib/auth';

// Verificar autenticación y rol de doctor
const user = requireAuth(Astro.cookies);
if (!user || (user.role !== 'doctor' && user.role !== 'admin')) {
  return Astro.redirect('/auth/login');
}

const patientId = Astro.params.id;
if (!patientId) {
  return Astro.redirect('/doctor/appointments');
}
---

<Layout title="Información del Paciente - Panel Doctor">
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-4">
          <div class="flex items-center space-x-4">
            <a href="/doctor/appointments" class="text-gray-500 hover:text-gray-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </a>
            <h1 class="text-2xl font-bold text-gray-900">Información del Paciente</h1>
          </div>
          <div class="flex items-center space-x-4">
            <button 
              id="medicalHistoryBtn"
              class="hidden bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-md text-sm font-medium flex items-center space-x-2 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <span>Historia Médica</span>
            </button>


            <div class="text-sm text-gray-600">
              Dr. <span class="font-medium">{user.name}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      
      <!-- Loading State -->
      <div id="loadingState" class="text-center py-8">
        <div class="inline-flex items-center">
          <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Cargando información del paciente...
        </div>
      </div>

      <!-- Error State -->
      <div id="errorState" class="hidden text-center py-8">
        <div class="text-red-600">
          <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <h3 class="text-lg font-medium mb-2">Error al cargar paciente</h3>
          <p id="errorMessage" class="text-gray-600"></p>
          <button onclick="window.location.href='/doctor/appointments'" class="mt-4 bg-blue-600 text-white px-4 py-2 rounded-lg">
            Volver a mis citas
          </button>
        </div>
      </div>

      <!-- Patient Information -->
      <div id="patientContent" class="hidden">
        
        <!-- Basic Information Card -->
        <div class="bg-white rounded-lg shadow mb-6">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-gray-900">Información Personal</h2>
          </div>
          <div class="p-6">
            <div class="flex flex-col lg:flex-row gap-6">
              
              <!-- Foto del Paciente -->
              <div class="flex-shrink-0 text-center lg:text-left">
                <div class="w-32 h-32 mx-auto lg:mx-0 mb-4">
                  <div id="patientPhotoContainer" class="w-32 h-32 rounded-lg border-2 border-gray-200 overflow-hidden bg-gray-100 flex items-center justify-center">
                    <img 
                      id="patientPhoto" 
                      src="" 
                      alt="Foto del paciente"
                      class="w-full h-full object-cover hidden"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                    />
                    <div id="patientPhotoPlaceholder" class="flex flex-col items-center justify-center text-gray-400">
                      <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                      </svg>
                      <span class="text-xs">Sin foto</span>
                    </div>
                  </div>
                </div>
                <p class="text-sm text-gray-600 text-center lg:text-left">Foto del paciente</p>
              </div>

              <!-- Información Personal -->
              <div class="flex-1">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo</label>
                    <p id="patientName" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <p id="patientEmail" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border break-all">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                    <p id="patientPhone" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Documento</label>
                    <p id="patientDocument" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de Nacimiento</label>
                    <p id="patientBirthDate" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Género</label>
                    <p id="patientGender" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border capitalize">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Sangre</label>
                    <p id="patientBloodType" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Edad</label>
                    <p id="patientAge" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
                    <p id="patientAddress" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Work Information Card -->
        <div class="bg-white rounded-lg shadow mb-6">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-gray-900">Información Laboral</h2>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Empresa</label>
                <p id="patientCompany" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Ocupación</label>
                <p id="patientOccupation" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Emergency Contact Card -->
        <div class="bg-white rounded-lg shadow mb-6">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-gray-900">Contacto de Emergencia</h2>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                <p id="emergencyContactName" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                <p id="emergencyContactPhone" class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md border">-</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Medical Information Card -->
        <div class="bg-white rounded-lg shadow mb-6">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-gray-900">Información Médica</h2>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Alergias</label>
                <div id="patientAllergies" class="text-sm text-gray-900 bg-gray-50 p-2 rounded min-h-[60px]">-</div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Medicamentos Actuales</label>
                <div id="patientMedications" class="text-sm text-gray-900 bg-gray-50 p-2 rounded min-h-[60px]">-</div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Condiciones Médicas</label>
                <div id="patientMedicalConditions" class="text-sm text-gray-900 bg-gray-50 p-2 rounded min-h-[60px]">-</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Última Historia Médica Ocupacional -->
        <div id="recentMedicalHistory" class="bg-white rounded-lg shadow mb-6 hidden">
          <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h2 class="text-lg font-medium text-gray-900">Última Evaluación Médica Ocupacional</h2>
            <button 
              onclick="window.location.href = '/doctor/patients/' + (window.location.pathname.split('/').pop()) + '/medical-history'"
              class="text-sm text-blue-600 hover:text-blue-800 font-medium">
              Ver historial completo →
            </button>
          </div>
          <div id="recentMedicalHistoryContent" class="p-6">
            <!-- Contenido cargado dinámicamente -->
          </div>
        </div>

        <!-- Patient's Appointments with this Doctor -->
        <div class="bg-white rounded-lg shadow">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-gray-900">Citas con este Paciente</h2>
          </div>
          <div class="p-6">
            <div id="patientAppointmentsContainer">
              <div class="text-center py-4 text-gray-500">
                Cargando historial de citas...
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const patientId = window.location.pathname.split('/').pop();
  let currentPatient: any = null;

  // Elementos del DOM
  const loadingState = document.getElementById('loadingState')!;
  const errorState = document.getElementById('errorState')!;
  const patientContent = document.getElementById('patientContent')!;
  const errorMessage = document.getElementById('errorMessage')!;

  // Cargar información del paciente
  async function loadPatientData() {
    try {
      const response = await fetch(`/api/doctor/patients/${patientId}`);
      const result = await response.json();

      if (result.success && result.data) {
        currentPatient = result.data;
        populatePatientData(currentPatient);
        loadPatientAppointments();
        loadRecentMedicalHistory();
        
        // Mostrar contenido
        loadingState.classList.add('hidden');
        patientContent.classList.remove('hidden');
      } else {
        showError(result.message || 'No se pudo cargar la información del paciente');
      }
    } catch (error) {
      // Silently fail
      showError('Error de conexión al cargar el paciente');
    }
  }

  // Mostrar error
  function showError(message: string) {
    loadingState.classList.add('hidden');
    errorMessage.textContent = message;
    errorState.classList.remove('hidden');
  }

  // Poblar datos del paciente
  function populatePatientData(patient: any) {
    document.getElementById('patientName')!.textContent = patient.name || '-';
    document.getElementById('patientEmail')!.textContent = patient.email || '-';
    document.getElementById('patientPhone')!.textContent = patient.phone || '-';
    document.getElementById('patientDocument')!.textContent = 
      `${patient.document_type || ''} ${patient.document_number || ''}`.trim() || '-';
    document.getElementById('patientBirthDate')!.textContent = 
      patient.date_of_birth ? new Date(patient.date_of_birth).toLocaleDateString() : '-';
    document.getElementById('patientGender')!.textContent = patient.gender || '-';
    document.getElementById('patientBloodType')!.textContent = patient.blood_type || '-';
    document.getElementById('patientAge')!.textContent = calculateAge(patient.date_of_birth) + ' años';
    document.getElementById('patientAddress')!.textContent = patient.address || '-';
    document.getElementById('patientCompany')!.textContent = patient.company || '-';
    document.getElementById('patientOccupation')!.textContent = patient.occupation || '-';
    document.getElementById('emergencyContactName')!.textContent = patient.emergency_contact_name || '-';
    document.getElementById('emergencyContactPhone')!.textContent = patient.emergency_contact_phone || '-';
    document.getElementById('patientAllergies')!.textContent = patient.allergies || 'Ninguna registrada';
    document.getElementById('patientMedications')!.textContent = patient.medications || 'Ningún medicamento registrado';
    document.getElementById('patientMedicalConditions')!.textContent = patient.medical_conditions || 'Ninguna condición registrada';
    
    // Mostrar foto del paciente
    const patientPhoto = document.getElementById('patientPhoto') as HTMLImageElement;
    const patientPhotoPlaceholder = document.getElementById('patientPhotoPlaceholder')!;
    
    if (patient.photo_path) {
      patientPhoto.src = patient.photo_path;
      patientPhoto.style.display = 'block';
      patientPhotoPlaceholder.style.display = 'none';
    } else {
      patientPhoto.style.display = 'none';
      patientPhotoPlaceholder.style.display = 'flex';
    }
    
    // Mostrar botón de Historia Médica una vez cargado el paciente
    showMedicalHistoryButton();
  }

  // Calcular edad
  function calculateAge(birthDate: string): number {
    if (!birthDate) return 0;
    const today = new Date();
    const birth = new Date(birthDate);
    let age = today.getFullYear() - birth.getFullYear();
    const monthDiff = today.getMonth() - birth.getMonth();
    
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {
      age--;
    }
    
    return age;
  }

  // Cargar última historia médica
  async function loadRecentMedicalHistory() {
    try {
      const response = await fetch(`/api/doctor/medical-history/list?patient_id=${patientId}`);
      const result = await response.json();
      
      if (result.success && result.data && result.data.length > 0) {
        const recentHistory = result.data[0]; // La más reciente
        displayRecentMedicalHistory(recentHistory);
      }
    } catch (error) {
      // Silently fail
    }
  }

  // Mostrar resumen de la última historia médica
  function displayRecentMedicalHistory(history: any) {
    const container = document.getElementById('recentMedicalHistory');
    const content = document.getElementById('recentMedicalHistoryContent');
    
    if (!container || !content) return;

    // Parsear signos vitales si existen
    let vitalSigns = null;
    if (history.vital_signs) {
      try {
        // Si ya es un objeto, usarlo directamente, sino parsearlo
        vitalSigns = typeof history.vital_signs === 'string' 
          ? JSON.parse(history.vital_signs) 
          : history.vital_signs;
      } catch (e) {
        // Silently fail
        vitalSigns = null;
      }
    }

    content.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Información básica -->
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de consulta</label>
            <p class="text-sm text-gray-900 bg-gray-50 p-2 rounded">
              ${new Date(history.created_at).toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Motivo de consulta</label>
            <p class="text-sm text-gray-900 bg-gray-50 p-2 rounded max-h-20 overflow-y-auto">
              ${history.symptoms.substring(0, 100)}${history.symptoms.length > 100 ? '...' : ''}
            </p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Diagnóstico</label>
            <p class="text-sm text-gray-900 bg-green-50 border border-green-200 p-2 rounded max-h-20 overflow-y-auto">
              ${history.diagnosis.substring(0, 100)}${history.diagnosis.length > 100 ? '...' : ''}
            </p>
          </div>
        </div>

        <!-- Signos vitales -->
        ${vitalSigns ? `
          <div class="space-y-3">
            <h4 class="font-medium text-gray-900">Signos Vitales</h4>
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
              <div class="grid grid-cols-2 gap-2 text-xs">
                ${vitalSigns.systolic_pressure && vitalSigns.diastolic_pressure ? `
                  <div>
                    <span class="text-blue-700 font-medium">PA:</span>
                    <span class="text-blue-900">${vitalSigns.systolic_pressure}/${vitalSigns.diastolic_pressure} mmHg</span>
                  </div>
                ` : ''}
                ${vitalSigns.heart_rate ? `
                  <div>
                    <span class="text-blue-700 font-medium">FC:</span>
                    <span class="text-blue-900">${vitalSigns.heart_rate} lpm</span>
                  </div>
                ` : ''}
                ${vitalSigns.weight && vitalSigns.height ? `
                  <div>
                    <span class="text-blue-700 font-medium">Peso:</span>
                    <span class="text-blue-900">${vitalSigns.weight} kg</span>
                  </div>
                  <div>
                    <span class="text-blue-700 font-medium">Estatura:</span>
                    <span class="text-blue-900">${vitalSigns.height} cm</span>
                  </div>
                  <div class="col-span-2">
                    <span class="text-blue-700 font-medium">IMC:</span>
                    <span class="text-blue-900 font-bold">
                      ${(vitalSigns.weight / Math.pow(vitalSigns.height/100, 2)).toFixed(1)}
                    </span>
                  </div>
                ` : ''}
                ${vitalSigns.temperature ? `
                  <div>
                    <span class="text-blue-700 font-medium">T°:</span>
                    <span class="text-blue-900">${vitalSigns.temperature}°C</span>
                  </div>
                ` : ''}
                ${vitalSigns.oxygen_saturation ? `
                  <div>
                    <span class="text-blue-700 font-medium">SpO₂:</span>
                    <span class="text-blue-900">${vitalSigns.oxygen_saturation}%</span>
                  </div>
                ` : ''}
              </div>
            </div>
          </div>
        ` : ''}

        <!-- Tratamiento y seguimiento -->
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tratamiento</label>
            <p class="text-sm text-gray-900 bg-yellow-50 border border-yellow-200 p-2 rounded max-h-20 overflow-y-auto">
              ${history.treatment.substring(0, 100)}${history.treatment.length > 100 ? '...' : ''}
            </p>
          </div>
          ${history.medications ? `
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Medicamentos</label>
              <p class="text-sm text-gray-900 bg-purple-50 border border-purple-200 p-2 rounded max-h-20 overflow-y-auto">
                ${history.medications.substring(0, 100)}${history.medications.length > 100 ? '...' : ''}
              </p>
            </div>
          ` : ''}
          ${history.next_appointment_date ? `
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Próxima cita</label>
              <p class="text-sm text-gray-900 bg-gray-50 p-2 rounded">
                ${new Date(history.next_appointment_date).toLocaleDateString('es-ES')}
              </p>
            </div>
          ` : ''}
          ${history.cie10_code ? `
            <div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                CIE-10: ${history.cie10_code}
              </span>
            </div>
          ` : ''}
        </div>
      </div>
    `;

    container.classList.remove('hidden');
  }

  // Cargar citas del paciente con este doctor
  async function loadPatientAppointments() {
    const container = document.getElementById('patientAppointmentsContainer')!;
    
    try {
      const response = await fetch(`/api/doctor/patients/${patientId}/appointments`);
      const result = await response.json();
      
      if (result.success && result.data && result.data.length > 0) {
        const appointments = result.data;
        container.innerHTML = appointments.map((apt: any) => `
          <div class="border border-gray-200 rounded-lg p-4 mb-4">
            <div class="flex justify-between items-start">
              <div>
                <h4 class="font-medium text-gray-900">
                  ${new Date(apt.appointment_date).toLocaleDateString('es-ES', {
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })} - ${new Date(apt.appointment_date).toLocaleTimeString('es-ES', {
                    hour: '2-digit',
                    minute: '2-digit'
                  })}
                </h4>
                <p class="text-sm text-gray-600 mt-1">
                  ${apt.appointment_type || 'Consulta general'}
                </p>
                <p class="text-sm text-gray-500 mt-1">
                  ${apt.reason || 'Sin motivo específico'}
                </p>
              </div>
              <div class="flex flex-col items-end space-y-2">
                <span class="px-2 py-1 text-xs font-medium rounded-full ${getStatusBadgeClass(apt.status)}">
                  ${getStatusText(apt.status)}
                </span>
                ${apt.status === 'programada' ? 
                  `<button onclick="changeAppointmentStatus(${apt.id}, 'en_progreso')" class="text-green-600 hover:text-green-800 text-sm font-medium">Iniciar</button>` :
                  apt.status === 'en_progreso' ? 
                  `<button onclick="changeAppointmentStatus(${apt.id}, 'completada')" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    Completar
                  </button>` :
                  ''
                }
              </div>
            </div>
          </div>
        `).join('');
      } else {
        container.innerHTML = `
          <div class="text-center py-4 text-gray-500">
            <p>No hay citas registradas con este paciente</p>
          </div>
        `;
      }
    } catch (error) {
      container.innerHTML = `
        <div class="text-center py-4 text-red-500">
          Error al cargar el historial de citas
        </div>
      `;
    }
  }

  // Obtener clase CSS para el estado
  function getStatusBadgeClass(status: string): string {
    switch (status) {
      case 'programada': return 'bg-blue-100 text-blue-800';
      case 'en_progreso': return 'bg-yellow-100 text-yellow-800';
      case 'completada': return 'bg-green-100 text-green-800';
      case 'cancelada': return 'bg-red-100 text-red-800';
      case 'no_asistio': return 'bg-gray-100 text-gray-800';
      default: return 'bg-gray-100 text-gray-800';
    }
  }

  // Obtener texto del estado
  function getStatusText(status: string): string {
    switch (status) {
      case 'programada': return 'Programada';
      case 'en_progreso': return 'En progreso';
      case 'completada': return 'Completada';
      case 'cancelada': return 'Cancelada';
      case 'no_asistio': return 'No asistió';
      default: return status;
    }
  }

  // Cambiar estado de cita
  (window as any).changeAppointmentStatus = async (appointmentId: number, newStatus: string) => {
    await ensureSweetAlert();
    
    const statusTexts: {[key: string]: string} = {
      'en_progreso': 'En progreso',
      'completada': 'Completada',
      'cancelada': 'Cancelada',
      'no_asistio': 'No asistió'
    };

    const confirmTitle = newStatus === 'completada' ? '¿Completar Cita?' : '¿Cambiar estado?';
    const confirmText = newStatus === 'completada' 
      ? 'Esto marcará la cita como completada. Asegúrese de haber registrado toda la información médica necesaria.'
      : `Esto marcará la cita como "${statusTexts[newStatus]}"`;
    
    const confirmButtonText = newStatus === 'completada' ? 'Sí, completar' : 'Sí, cambiar';
    const confirmButtonColor = newStatus === 'completada' ? '#10b981' : '#3b82f6';

    const result = await (window as any).Swal.fire({
      title: confirmTitle,
      text: confirmText,
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: confirmButtonColor,
      cancelButtonColor: '#d33',
      confirmButtonText: confirmButtonText,
      cancelButtonText: 'Cancelar'
    });

    if (result.isConfirmed) {
      try {
        const response = await fetch(`/api/doctor/appointments/${appointmentId}/status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus })
        });

        const updateResult = await response.json();

        if (updateResult.success) {
          await (window as any).Swal.fire({
            title: '¡Actualizado!',
            text: `La cita ha sido marcada como "${statusTexts[newStatus]}".`,
            icon: 'success',
            timer: 2000,
            showConfirmButton: false
          });
          
          // Recargar las citas
          loadPatientAppointments();
        } else {
          (window as any).Swal.fire('Error', updateResult.message || 'No se pudo actualizar el estado', 'error');
        }
      } catch (error) {
        (window as any).Swal.fire('Error', 'Error de conexión al actualizar el estado', 'error');
      }
    }
  };

  // Manejar botón de Historia Médica
  document.getElementById('medicalHistoryBtn')?.addEventListener('click', function() {
    const patientId = getCurrentPatientId();
    if (patientId) {
      window.location.href = `/doctor/patients/${patientId}/medical-history`;
    }
  });

  // Función para obtener el ID del paciente actual
  function getCurrentPatientId() {
    return window.location.pathname.split('/').pop();
  }

  // Mostrar botón de Historia Médica una vez cargado el paciente
  function showMedicalHistoryButton() {
    const btn = document.getElementById('medicalHistoryBtn');
    if (btn) {
      btn.classList.remove('hidden');
      btn.classList.add('inline-flex');
    }

  }

  // Cargar datos al inicializar la página
  loadPatientData();



  // Carga dinámica de SweetAlert2 si no está presente
  async function ensureSweetAlert() {
    if (typeof (window as any).Swal === 'undefined') {
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/sweetalert2@11';
      document.head.appendChild(s);
      await new Promise((res, rej) => { s.onload = res; s.onerror = () => rej(new Error('SweetAlert2 no cargó')); });
    }
  }

  function deriveMedicalConcept(h) {
    const t = (s) => (s || '').toLowerCase();
    const diag = t(h.diagnosis);
    const rec = t(h.recommendations);
    if (diag.includes('restric') || rec.includes('restric') || rec.includes('reposo')) {
      return { status: 'APTO CON RESTRICCIONES', reasons: [] };
    }
    return { status: 'APTO', reasons: [] };
  }

  async function ensureJsPDF() {
    if (!(window).jspdf) {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
      document.head.appendChild(s);
      await new Promise((res, rej) => { s.onload = res; s.onerror = () => rej(new Error('jsPDF no cargó')); });
    }
  }

  async function addPatientPhotoToPDF(doc, patient, x, y, w, h) {
    if (!patient.photo_path) return;
    try {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      let url = patient.photo_path;
      if (!url.startsWith('http')) url = `/uploads/patients/${url}`;
      img.src = url;
      await new Promise((res, rej) => { img.onload = res; img.onerror = rej; });
      const canvas = document.createElement('canvas');
      canvas.width = w*3; canvas.height = h*3;
      const ctx = canvas.getContext('2d');
      const arImg = img.width / img.height; const arCan = canvas.width / canvas.height;
      let dw, dh, ox, oy;
      if (arImg > arCan) { dw = canvas.width; dh = canvas.width / arImg; ox = 0; oy = (canvas.height - dh)/2; }
      else { dh = canvas.height; dw = canvas.height * arImg; ox = (canvas.width - dw)/2; oy = 0; }
      ctx!.imageSmoothingEnabled = true; ctx!.imageSmoothingQuality = 'high';
      ctx!.drawImage(img, ox, oy, dw, dh);
      const data = canvas.toDataURL('image/jpeg', 0.95);
      doc.addImage(data, 'JPEG', x, y, w, h);
    } catch (e) { }
  }

  async function generateConceptPDF(patient, history, concept) {
    const { jsPDF } = (window).jspdf;
    const doc = new jsPDF();
    const m = 14; let y = m;

    doc.setFont('helvetica','bold'); doc.setFontSize(14);
    doc.text('CONCEPTO MÉDICO OCUPACIONAL', 105, y, { align: 'center' });
    y += 10;

    doc.setFontSize(10); doc.setFont('helvetica','normal');
    doc.text(`Nombre: ${patient.name || '-'}`, m, y); y += 6;
    doc.text(`Documento: ${(patient.document_type || '')} ${(patient.document_number || '')}`.trim(), m, y); y += 6;
    doc.text(`Empresa: ${patient.company || '-'}`, m, y); y += 6;
    doc.text(`Ocupación: ${patient.occupation || '-'}`, m, y); y += 8;

    try { await addPatientPhotoToPDF(doc, patient, 160, m-2, 35, 35); } catch {}

    doc.setFont('helvetica','bold');
    const color = concept.status === 'APTO CON RESTRICCIONES' ? [234,179,8] : [34,197,94];
    doc.setTextColor(...color);
    doc.text(`Concepto: ${concept.status}`, m, y); y += 8;
    doc.setTextColor(0,0,0);

    doc.setFont('helvetica','normal');
    const lines = [`Fecha historia: ${new Date(history.created_at).toLocaleDateString('es-ES')}`];
    if (history.diagnosis) lines.push(`Diagnóstico: ${history.diagnosis}`);
    if (history.recommendations) lines.push(`Recomendaciones: ${history.recommendations}`);
    lines.forEach(line => { doc.text(doc.splitTextToSize(line, 210 - 2*m), m, y); y += 6; });

    const fileName = `Concepto_${(patient.name || 'Paciente').replace(/\s+/g,'_')}.pdf`;
    doc.save(fileName);
  }
</script>