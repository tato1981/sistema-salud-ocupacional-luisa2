---
import DashboardLayout from '@/components/layout/DashboardLayout.astro';
import SignaturePad from '@/components/ui/SignaturePad.astro';
import { requireAuth } from '@/lib/auth';

// Verificar autenticación y rol de admin o staff
const user = requireAuth(Astro.cookies);
if (!user || (user.role !== 'admin' && user.role !== 'staff')) {
  return Astro.redirect('/auth/login');
}
---

<DashboardLayout title="Gestión de Pacientes - Panel Admin" user={user}>
  <div class="space-y-6">
    <!-- Encabezado de página -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
        <span class="hidden sm:inline">👥 Gestión de Pacientes</span>
        <span class="sm:hidden">👥 Pacientes</span>
      </h1>
      <button
        id="newPatientBtn"
        class="mt-4 sm:mt-0 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium flex items-center justify-center text-sm sm:text-base">
        <span class="hidden sm:inline">+ Nuevo Paciente</span>
        <span class="sm:hidden">+ Nuevo</span>
      </button>
    </div>
      
      <!-- Estadísticas rápidas responsive -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6">
        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-blue-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Total Pacientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="totalPatients">-</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-3 sm:p-6 rounded-lg shadow">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-green-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Citas Hoy</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="todayAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-yellow-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Pendientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="pendingAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-purple-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Nuevos Este Mes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="newThisMonth">-</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Filtros y búsqueda responsive -->
      <div class="card p-4 sm:p-6 mb-6">
        <div class="flex flex-col space-y-4 lg:flex-row lg:items-center lg:justify-between lg:space-y-0">
          <div class="flex-1 max-w-lg">
            <div class="relative">
              <input 
                type="text" 
                id="searchInput"
                placeholder="Buscar por nombre, documento o email..."
                class="w-full pl-10 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              />
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3">
            <select id="genderFilter" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500">
              <option value="">Todos los géneros</option>
              <option value="masculino">Masculino</option>
              <option value="femenino">Femenino</option>
              <option value="otro">Otro</option>
            </select>
            <button 
              id="refreshBtn"
              class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg transition-colors text-sm"
            >
              <span class="hidden sm:inline">🔄 Actualizar</span>
              <span class="sm:hidden">🔄</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Lista de pacientes -->
      <div class="card overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Lista de Pacientes</h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paciente</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contacto</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Edad/Género</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Empresa</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Última Cita</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody id="patientsTableBody" class="bg-white divide-y divide-gray-200">
              <!-- Se carga dinámicamente -->
            </tbody>
          </table>
        </div>
        
        <!-- Loading state -->
        <div id="loadingState" class="text-center py-8">
          <div class="inline-flex items-center">
            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Cargando pacientes...
          </div>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
          <span class="text-sm text-gray-700" id="resultsCount">Mostrando 0 resultados</span>
          <div class="flex space-x-2">
            <button id="prevBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Anterior</button>
            <button id="nextBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Siguiente</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal para nuevo paciente responsive -->
  <div id="patientModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 modal-overlay">
    <div class="relative top-4 sm:top-20 mx-auto p-4 sm:p-5 border w-full max-w-5xl shadow-lg rounded-md bg-white my-4 sm:my-0">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base sm:text-lg font-medium text-gray-900" id="modalTitle">Nuevo Paciente</h3>
          <button id="closeModal" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <form id="patientForm" class="space-y-4">
          <!-- Foto de perfil -->
          <div class="flex flex-col items-center mb-6">
            <!-- Camera UI (Hidden by default) -->
            <div id="cameraContainer" class="hidden w-full max-w-xs mb-4 bg-gray-900 rounded-lg overflow-hidden relative shadow-xl">
                <video id="cameraFeed" autoplay playsinline class="w-full h-64 object-cover"></video>
                <div class="absolute bottom-4 left-0 right-0 flex justify-center space-x-4 z-10">
                    <button type="button" id="takePhotoBtn" class="bg-white text-gray-900 rounded-full p-3 shadow-lg hover:bg-gray-100 transition-colors transform hover:scale-110" title="Capturar">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                        </svg>
                    </button>
                    <button type="button" id="cancelCameraBtn" class="bg-red-500 text-white rounded-full p-3 shadow-lg hover:bg-red-600 transition-colors transform hover:scale-110" title="Cancelar">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>

            <div id="photoDisplayContainer" class="relative group">
              <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-gray-100 shadow-lg bg-gray-100 flex items-center justify-center">
                <img id="photoPreview" src="" alt="Foto de perfil" class="w-full h-full object-cover hidden" />
                <svg id="photoPlaceholder" class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              
              <!-- File Upload Label -->
              <label for="photoInput" class="absolute bottom-0 right-0 bg-blue-600 p-2 rounded-full text-white cursor-pointer hover:bg-blue-700 shadow-md transition-colors z-10" title="Subir foto">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                </svg>
              </label>

              <!-- Camera Button -->
              <button type="button" id="openCameraBtn" class="absolute bottom-0 left-0 bg-green-600 p-2 rounded-full text-white cursor-pointer hover:bg-green-700 shadow-md transition-colors z-10" title="Tomar foto con cámara">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </button>

              <input type="file" id="photoInput" name="photo" accept="image/*" class="hidden" />
              <button type="button" id="removePhotoBtn" class="absolute top-0 -right-2 bg-red-500 text-white p-1 rounded-full shadow-md hidden hover:bg-red-600 z-20" title="Eliminar foto">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <p class="text-sm text-gray-500 mt-2">Foto de perfil (opcional)</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo *</label>
              <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" name="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
              <input type="tel" name="phone" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Documento *</label>
              <select name="documentType" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="cedula">Cédula</option>
                <option value="pasaporte">Pasaporte</option>
                <option value="tarjeta_identidad">Tarjeta de Identidad</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Número de Documento *</label>
              <input type="text" name="documentNumber" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de Nacimiento *</label>
              <input type="date" id="dateOfBirth" name="dateOfBirth" required max="" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <p class="text-xs text-gray-500 mt-1">La fecha de nacimiento no puede ser mayor a la fecha actual</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Género *</label>
              <select name="gender" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="masculino">Masculino</option>
                <option value="femenino">Femenino</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Sangre</label>
              <select name="bloodType" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="">Seleccionar...</option>
                <option value="A+">A+</option>
                <option value="A-">A-</option>
                <option value="B+">B+</option>
                <option value="B-">B-</option>
                <option value="AB+">AB+</option>
                <option value="AB-">AB-</option>
                <option value="O+">O+</option>
                <option value="O-">O-</option>
              </select>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
            <textarea name="address" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Ocupación</label>
              <input type="text" name="occupation" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Empresa (opcional)</label>
              <select name="companyId" id="companySelect" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="">Particular / Sin empresa</option>
              </select>
              <small class="text-xs text-gray-500">Si no aparece en la lista, puede escribirla abajo.</small>
              <input type="text" name="company" placeholder="Nombre de empresa (opcional)" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contacto de Emergencia</label>
              <input type="text" name="emergencyContactName" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono de Emergencia</label>
              <input type="tel" name="emergencyContactPhone" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
          </div>

          <!-- Información Médica -->
          <div class="border-t pt-4 mt-4">
            <h4 class="text-sm font-medium text-gray-900 mb-3">Información Médica</h4>
            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Alergias</label>
                <textarea name="allergies" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Lista de alergias conocidas..."></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Medicamentos Actuales</label>
                <textarea name="medications" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Medicamentos que toma actualmente..."></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Condiciones Médicas</label>
                <textarea name="medicalConditions" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enfermedades crónicas o condiciones relevantes..."></textarea>
              </div>
            </div>
          </div>

          <!-- Firma del Paciente -->
          <div class="col-span-full mt-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Firma del Paciente</label>
            
            <!-- Tabs para elegir método de firma -->
            <div class="flex border-b border-gray-200 mb-4">
              <button type="button" id="tabDrawSignature" class="px-4 py-2 text-sm font-medium text-blue-600 border-b-2 border-blue-600 focus:outline-none">
                Dibujar Firma
              </button>
              <button type="button" id="tabUploadSignature" class="px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 focus:outline-none">
                Subir Imagen
              </button>
            </div>

            <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
              
              <!-- Firma existente -->
              <div id="existingSignatureContainer" class="hidden mb-4 text-center">
                <p class="text-sm text-gray-500 mb-2">Firma Actual</p>
                <img id="existingSignatureImage" src="" alt="Firma del paciente" class="mx-auto max-h-32 border border-gray-300 rounded bg-white mb-3" />
                <button type="button" id="changeSignatureBtn" class="text-sm text-blue-600 hover:text-blue-800 font-medium underline">
                  Cambiar Firma
                </button>
              </div>

              <!-- Contenedor para dibujar firma -->
              <div id="drawSignatureContainer">
                <div id="newSignatureContainer">
                  <SignaturePad />
                  <div id="signaturePreviewContainer" class="hidden mt-3 p-3 bg-green-50 border border-green-200 rounded-lg flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                      <div class="bg-green-100 p-2 rounded-full">
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </div>
                      <div>
                        <p class="text-sm font-medium text-green-800">Firma capturada correctamente</p>
                        <p class="text-xs text-green-600">Lista para guardar</p>
                      </div>
                    </div>
                    <button type="button" id="resetSignatureBtn" class="text-sm text-red-600 hover:text-red-800 font-medium">
                      Cambiar
                    </button>
                  </div>
                </div>
              </div>

              <!-- Contenedor para subir imagen -->
              <div id="uploadSignatureContainer" class="hidden">
                <div class="flex flex-col items-center justify-center w-full">
                  <label for="signatureFile" class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100">
                    <div class="flex flex-col items-center justify-center pt-5 pb-6">
                      <svg class="w-8 h-8 mb-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2"/>
                      </svg>
                      <p class="mb-2 text-sm text-gray-500"><span class="font-semibold">Click para subir</span> o arrastrar y soltar</p>
                      <p class="text-xs text-gray-500">PNG, JPG (MAX. 2MB)</p>
                    </div>
                    <input id="signatureFile" type="file" class="hidden" accept="image/png, image/jpeg, image/jpg" />
                  </label>
                </div>
                
                <div id="uploadPreviewContainer" class="hidden mt-4 text-center relative">
                  <p class="text-sm text-gray-500 mb-2">Vista previa</p>
                  <div class="relative inline-block">
                    <img id="uploadPreviewImage" src="" alt="Vista previa firma" class="max-h-32 border border-gray-300 rounded bg-white" />
                    <button type="button" id="removeUploadBtn" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1 hover:bg-red-600 shadow-md">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                      </svg>
                    </button>
                  </div>
                  <div class="mt-2 text-green-600 text-sm font-medium flex items-center justify-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Imagen seleccionada
                  </div>
                </div>
              </div>

            </div>
          </div>

          <div class="flex flex-col sm:flex-row justify-end space-y-3 sm:space-y-0 sm:space-x-3 pt-4">
            <button type="button" id="cancelBtn" class="w-full sm:w-auto px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 text-sm">
              Cancelar
            </button>
            <button type="submit" class="w-full sm:w-auto px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm">
              <span id="submitBtnText">Guardar Paciente</span>
              <svg id="submitBtnLoader" class="hidden animate-spin -mr-1 ml-3 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import Swal from 'sweetalert2';
  
  // Declaración de tipos
  interface Patient {
    id: number;
    name: string;
    email: string;
    documentType: string;
    documentNumber: string;
    dateOfBirth: string;
    gender: string;
    phone?: string;
    bloodType?: string;
    address?: string;
    occupation?: string;
    company?: string;
    companyId?: number;
    emergencyContactName?: string;
    emergencyContactPhone?: string;
    photoPath?: string;
    signaturePath?: string;
    allergies?: string;
    medications?: string;
    medicalConditions?: string;
  }

  let currentPatients: Patient[] = [];
  let currentSignatureBlob: Blob | null = null;
  let isEditMode = false;
  let currentPatientId: number | null = null;
  let currentPage = 1;
  const itemsPerPage = 10;

  // Variables adicionales para archivos y modo
  let currentSignatureMode: 'draw' | 'upload' = 'draw';
  let photoFile: File | null = null;
  let signatureFile: File | null = null;
  let deletePhoto = false;

  // Elementos de UI adicionales
  const tabDrawSignature = document.getElementById('tabDrawSignature');
  const tabUploadSignature = document.getElementById('tabUploadSignature');
  const drawSignatureContainer = document.getElementById('drawSignatureContainer');
  const uploadSignatureContainer = document.getElementById('uploadSignatureContainer');
  const signatureFileInput = document.getElementById('signatureFile') as HTMLInputElement;
  const uploadPreviewContainer = document.getElementById('uploadPreviewContainer');
  const uploadPreviewImage = document.getElementById('uploadPreviewImage') as HTMLImageElement;
  const removeUploadBtn = document.getElementById('removeUploadBtn');

  // Elementos de Foto
  const photoInput = document.getElementById('photoInput') as HTMLInputElement;
  const photoPreview = document.getElementById('photoPreview') as HTMLImageElement;
  const photoPlaceholder = document.getElementById('photoPlaceholder');
  const removePhotoBtn = document.getElementById('removePhotoBtn');

  // Elementos de firma (con comprobación de nulidad)
  const existingSignatureContainer = document.getElementById('existingSignatureContainer');
  const newSignatureContainer = document.getElementById('newSignatureContainer');
  const existingSignatureImage = document.getElementById('existingSignatureImage') as HTMLImageElement;
  const signaturePreviewContainer = document.getElementById('signaturePreviewContainer');
  const changeSignatureBtn = document.getElementById('changeSignatureBtn');
  const resetSignatureBtn = document.getElementById('resetSignatureBtn');

  // Funciones de firma
  function switchSignatureMode(mode: 'draw' | 'upload') {
    currentSignatureMode = mode;
    
    if (mode === 'draw') {
      tabDrawSignature?.classList.add('text-blue-600', 'border-b-2', 'border-blue-600');
      tabDrawSignature?.classList.remove('text-gray-500', 'hover:text-gray-700');
      tabUploadSignature?.classList.remove('text-blue-600', 'border-b-2', 'border-blue-600');
      tabUploadSignature?.classList.add('text-gray-500', 'hover:text-gray-700');
      
      drawSignatureContainer?.classList.remove('hidden');
      uploadSignatureContainer?.classList.add('hidden');
      
      // Resize signature pad
      setTimeout(() => {
        if ((window as any).signaturePad) {
          (window as any).signaturePad.resize();
        }
      }, 100);
    } else {
      tabUploadSignature?.classList.add('text-blue-600', 'border-b-2', 'border-blue-600');
      tabUploadSignature?.classList.remove('text-gray-500', 'hover:text-gray-700');
      tabDrawSignature?.classList.remove('text-blue-600', 'border-b-2', 'border-blue-600');
      tabDrawSignature?.classList.add('text-gray-500', 'hover:text-gray-700');
      
      uploadSignatureContainer?.classList.remove('hidden');
      drawSignatureContainer?.classList.add('hidden');
    }
  }

  // ... (rest of the file) ...

  function showExistingSignature(url: string) {
    if (existingSignatureImage) existingSignatureImage.src = url;
    if (existingSignatureContainer) existingSignatureContainer.classList.remove('hidden');
    if (newSignatureContainer) newSignatureContainer.classList.add('hidden');
    currentSignatureBlob = null;
  }

  function showNewSignaturePad() {
    if (existingSignatureContainer) existingSignatureContainer.classList.add('hidden');
    if (newSignatureContainer) newSignatureContainer.classList.remove('hidden');
    if (signaturePreviewContainer) signaturePreviewContainer.classList.add('hidden');
    
    // Resize signature pad when visible
    setTimeout(() => {
      if ((window as any).signaturePad) {
        (window as any).signaturePad.resize();
        (window as any).signaturePad.clearSignature();
      }
    }, 100);
  }

  // Event listeners para firma
  if (changeSignatureBtn) {
    changeSignatureBtn.addEventListener('click', showNewSignaturePad);
  }

  if (resetSignatureBtn) {
    resetSignatureBtn.addEventListener('click', () => {
      signaturePreviewContainer.classList.add('hidden');
      currentSignatureBlob = null;
      if ((window as any).signaturePad) {
        (window as any).signaturePad.clearSignature();
      }
    });
  }

  // Event Listeners for Tabs and Files
  tabDrawSignature?.addEventListener('click', () => switchSignatureMode('draw'));
  tabUploadSignature?.addEventListener('click', () => switchSignatureMode('upload'));
  
  photoInput?.addEventListener('change', handlePhotoSelect);
  removePhotoBtn?.addEventListener('click', removePhoto);
  
  signatureFileInput?.addEventListener('change', handleSignatureFileSelect);
  removeUploadBtn?.addEventListener('click', removeUploadSignature);

  // Callback global para captura de firma
  (window as any).onSignatureCapture = (blob: Blob, url: string) => {
    currentSignatureBlob = blob;
    signaturePreviewContainer.classList.remove('hidden');
  };

  // Manejo de Foto de Perfil
  function handlePhotoSelect(e: Event) {
    const input = e.target as HTMLInputElement;
    if (input.files && input.files[0]) {
      const file = input.files[0];
      
      // Validar tamaño (max 5MB)
      if (file.size > 5 * 1024 * 1024) {
        showAlert('error', 'Error', 'La imagen no puede superar los 5MB');
        input.value = '';
        return;
      }

      const reader = new FileReader();
      reader.onload = (e) => {
        if (photoPreview && e.target?.result) {
          photoPreview.src = e.target.result as string;
          photoPreview.classList.remove('hidden');
          photoPlaceholder?.classList.add('hidden');
          removePhotoBtn?.classList.remove('hidden');
        }
      };
      reader.readAsDataURL(file);
      photoFile = file;
      deletePhoto = false;
    }
  }

  // Exponer globalmente para evitar ReferenceError si se llama desde HTML
  (window as any).handlePhotoSelect = handlePhotoSelect;

  function removePhoto() {
    if (photoInput) photoInput.value = '';
    if (photoPreview) {
      photoPreview.src = '';
      photoPreview.classList.add('hidden');
    }
    photoPlaceholder?.classList.remove('hidden');
    removePhotoBtn?.classList.add('hidden');
    photoFile = null;
    deletePhoto = true;
  }

  // Manejo de Archivo de Firma
  function handleSignatureFileSelect(e: Event) {
    const input = e.target as HTMLInputElement;
    if (input.files && input.files[0]) {
      const file = input.files[0];
      
      // Validar tamaño (max 5MB)
      if (file.size > 5 * 1024 * 1024) {
        showAlert('error', 'Error', 'La imagen no puede superar los 5MB');
        input.value = '';
        return;
      }

      const reader = new FileReader();
      reader.onload = (e) => {
        if (uploadPreviewImage && e.target?.result) {
          uploadPreviewImage.src = e.target.result as string;
          uploadPreviewContainer?.classList.remove('hidden');
        }
      };
      reader.readAsDataURL(file);
      signatureFile = file;
    }
  }

  function removeUploadSignature() {
    if (signatureFileInput) signatureFileInput.value = '';
    if (uploadPreviewImage) uploadPreviewImage.src = '';
    uploadPreviewContainer?.classList.add('hidden');
    signatureFile = null;
  }

  // --- Lógica de Cámara ---
  const cameraContainer = document.getElementById('cameraContainer');
  const photoDisplayContainer = document.getElementById('photoDisplayContainer');
  const cameraFeed = document.getElementById('cameraFeed') as HTMLVideoElement;
  const takePhotoBtn = document.getElementById('takePhotoBtn');
  const cancelCameraBtn = document.getElementById('cancelCameraBtn');
  const openCameraBtn = document.getElementById('openCameraBtn');
  let mediaStream: MediaStream | null = null;

  async function openCamera() {
    try {
      mediaStream = await navigator.mediaDevices.getUserMedia({ 
        video: { 
            facingMode: 'user',
            width: { ideal: 640 },
            height: { ideal: 480 }
        } 
      });
      cameraFeed.srcObject = mediaStream;
      cameraContainer?.classList.remove('hidden');
      photoDisplayContainer?.classList.add('hidden');
    } catch (err) {
      console.error("Error accessing camera: ", err);
      showAlert('error', 'Error', 'No se pudo acceder a la cámara. Verifique los permisos.');
    }
  }

  function closeCamera() {
    if (mediaStream) {
      mediaStream.getTracks().forEach(track => track.stop());
      mediaStream = null;
    }
    cameraFeed.srcObject = null;
    cameraContainer?.classList.add('hidden');
    photoDisplayContainer?.classList.remove('hidden');
  }

  function takePhoto() {
    if (!mediaStream) return;
    
    const canvas = document.createElement('canvas');
    canvas.width = cameraFeed.videoWidth;
    canvas.height = cameraFeed.videoHeight;
    const ctx = canvas.getContext('2d');
    if (ctx) {
        ctx.drawImage(cameraFeed, 0, 0, canvas.width, canvas.height);
        
        canvas.toBlob((blob) => {
            if (blob) {
                // Create a File object from the Blob
                const file = new File([blob], "camera_capture.jpg", { type: "image/jpeg" });
                
                // Update photoFile variable (used in form submission)
                photoFile = file;
                deletePhoto = false;

                // Update preview
                if (photoPreview) {
                    const newUrl = URL.createObjectURL(blob);
                    
                    // Force refresh
                    photoPreview.src = '';
                    setTimeout(() => {
                        photoPreview.src = newUrl;
                        photoPreview.classList.remove('hidden');
                        photoPlaceholder?.classList.add('hidden');
                        removePhotoBtn?.classList.remove('hidden');
                    }, 50);
                }
                
                closeCamera();
            }
        }, 'image/jpeg', 0.8);
    }
  }

  // Event Listeners para Cámara
  openCameraBtn?.addEventListener('click', openCamera);
  cancelCameraBtn?.addEventListener('click', closeCamera);
  takePhotoBtn?.addEventListener('click', takePhoto);


  // Cargar estadísticas
  async function loadStatistics() {
    try {
      const [patientStats, appointmentStats] = await Promise.all([
        fetch('/api/admin/patients/stats').then(r => r.json()),
        fetch('/api/admin/appointments/stats').then(r => r.json())
      ]);

      if (patientStats.success) {
        document.getElementById('totalPatients')!.textContent = patientStats.data.totalPatients;
        document.getElementById('newThisMonth')!.textContent = patientStats.data.newThisMonth;
      }

      if (appointmentStats.success) {
        document.getElementById('todayAppointments')!.textContent = appointmentStats.data.todayTotal;
        document.getElementById('pendingAppointments')!.textContent = (appointmentStats.data.todayTotal - appointmentStats.data.todayCompleted).toString();
      }
    } catch (error) {
      // Silently fail
    }
  }

  // Cargar pacientes
  async function loadPatients(searchTerm = '') {
    const loadingState = document.getElementById('loadingState')!;
    const tableBody = document.getElementById('patientsTableBody')!;
    
    loadingState.classList.remove('hidden');
    
    try {
      const url = searchTerm 
        ? `/api/admin/patients/search?q=${encodeURIComponent(searchTerm)}`
        : '/api/admin/patients';
      
      const response = await fetch(url);
      const data = await response.json();
      
      if (data.success) {
        currentPatients = data.data;
        renderPatients(currentPatients);
      }
    } catch (error) {
      // Silently fail
    } finally {
      loadingState.classList.add('hidden');
    }
  }

  // Renderizar pacientes en la tabla
  function renderPatients(patients: any[]) {
    const tableBody = document.getElementById('patientsTableBody')!;
    const countSpan = document.getElementById('resultsCount')!;
    const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
    const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
    
    // Pagination Logic
    const totalPages = Math.ceil(patients.length / itemsPerPage);
    
    // Ensure currentPage is valid
    if (currentPage < 1) currentPage = 1;
    if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
    
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const paginatedItems = patients.slice(start, end);

    if (patients.length === 0) {
      countSpan.textContent = 'Mostrando 0 resultados';
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-gray-500">
            No se encontraron pacientes
          </td>
        </tr>
      `;
      prevBtn.disabled = true;
      nextBtn.disabled = true;
      return;
    }

    countSpan.textContent = `Mostrando ${start + 1}-${Math.min(end, patients.length)} de ${patients.length} resultados`;

    // Update buttons
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;

    // Remove existing event listeners (to avoid duplicates)
    const newPrevBtn = prevBtn.cloneNode(true);
    const newNextBtn = nextBtn.cloneNode(true);
    prevBtn.parentNode!.replaceChild(newPrevBtn, prevBtn);
    nextBtn.parentNode!.replaceChild(newNextBtn, nextBtn);
    
    // Add event listeners
    newPrevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
            currentPage--;
            renderPatients(patients);
        }
    });

    newNextBtn.addEventListener('click', () => {
        if (currentPage < totalPages) {
            currentPage++;
            renderPatients(patients);
        }
    });

    tableBody.innerHTML = paginatedItems.map(patient => `
      <tr class="hover:bg-gray-50">
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="flex items-center">
            <div class="flex-shrink-0 h-10 w-10">
              ${patient.photo_path ? `
                <img class="h-10 w-10 rounded-full object-cover border border-gray-200" src="${patient.photo_path}" alt="${patient.name}" onerror="this.onerror=null; this.src=''; this.parentElement.innerHTML='<div class=\'h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center border border-gray-200\'><span class=\'text-sm font-medium text-gray-700\'>${patient.name.charAt(0).toUpperCase()}</span></div>'"/>
              ` : `
                <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center border border-gray-200">
                  <span class="text-sm font-medium text-gray-700">${patient.name.charAt(0).toUpperCase()}</span>
                </div>
              `}
            </div>
            <div class="ml-4">
              <div class="text-sm font-medium text-gray-900">${patient.name}</div>
              <div class="text-sm text-gray-500">${new Date(patient.created_at).toLocaleDateString()}</div>
            </div>
          </div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm text-gray-900">${patient.document_number}</div>
          <div class="text-sm text-gray-500">${patient.document_type}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm text-gray-900">${patient.email || '-'}</div>
          <div class="text-sm text-gray-500">${patient.phone || '-'}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm text-gray-900">${calculateAge(patient.date_of_birth)} años</div>
          <div class="text-sm text-gray-500">${patient.gender}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm text-gray-900">${patient.company || '-'}</div>
          <div class="text-sm text-gray-500">${patient.occupation || '-'}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
          ${patient.last_appointment_date ? `
            <div class="text-sm text-gray-900">
              ${new Date(patient.last_appointment_date).toLocaleDateString('es-ES')}
            </div>
            <div class="text-xs text-gray-500">
              ${patient.last_appointment_time} - ${getAppointmentStatusDisplay(patient.last_appointment_status)}
            </div>
            ${patient.last_appointment_doctor ? `
              <div class="text-xs text-gray-600">Dr. ${patient.last_appointment_doctor}</div>
            ` : ''}
          ` : `
            <div class="text-gray-400">Sin citas</div>
          `}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
          <div class="flex space-x-2 justify-end">
            <button onclick="viewPatient(${patient.id})" class="text-blue-600 hover:text-blue-900 px-2 py-1 text-xs">
              👁️ Ver
            </button>
            <button onclick="viewAppointmentHistory(${patient.id})" class="text-purple-600 hover:text-purple-900 px-2 py-1 text-xs" title="Ver historial de citas">
              📋 Historial
            </button>
            <button onclick="editPatient(${patient.id})" class="text-indigo-600 hover:text-indigo-900 px-2 py-1 text-xs">
              ✏️ Editar
            </button>
            <button onclick="scheduleAppointment(${patient.id})" class="text-green-600 hover:text-green-900 px-2 py-1 text-xs">
              📅 Cita
            </button>
            <button onclick="deletePatient(${patient.id}, '${patient.name}')" class="text-red-600 hover:text-red-900 px-2 py-1 text-xs">
              🗑️ Eliminar
            </button>
            <button onclick="impersonateUser(${patient.id}, '${patient.name.replace(/'/g, "\\\'")}')" class="text-purple-600 hover:text-purple-900 px-2 py-1 text-xs" title="Iniciar sesión como este paciente">
              🕵️ Acceder
            </button>
          </div>
        </td>
      </tr>
    `).join('');
  }

  // Calcular edad
  function calculateAge(birthDate: string): number {
    const today = new Date();
    const birth = new Date(birthDate);
    let age = today.getFullYear() - birth.getFullYear();
    const monthDiff = today.getMonth() - birth.getMonth();
    
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {
      age--;
    }
    
    return age;
  }

  // Obtener texto de estado de cita
  function getAppointmentStatusDisplay(status: string): string {
    switch (status) {
      case 'completed':
        return 'Completada';
      case 'scheduled':
        return 'Programada';
      case 'cancelled':
        return 'Cancelada';
      default:
        return status || 'Sin estado';
    }
  }

  // Modal management
  const modal = document.getElementById('patientModal')!;
  const patientForm = document.getElementById('patientForm') as HTMLFormElement;

  function openModal() {
    modal.classList.remove('hidden');
    patientForm.reset();

    // Limpiar estado de edición
    delete patientForm.dataset.patientId;
    document.getElementById('modalTitle')!.textContent = 'Nuevo Paciente';
    document.getElementById('submitBtnText')!.textContent = 'Guardar Paciente';

    // Cargar empresas para el selector
    loadCompaniesIntoSelect('');
    syncCompanyInputState();
    
    // Resetear firma y foto
    currentSignatureBlob = null;
    photoFile = null;
    signatureFile = null;
    deletePhoto = false;
    
    // Reset UI
    switchSignatureMode('draw');
    if (photoInput) photoInput.value = '';
    if (photoPreview && photoPlaceholder && removePhotoBtn) {
      photoPreview.src = '';
      photoPreview.classList.add('hidden');
      photoPlaceholder.classList.remove('hidden');
      removePhotoBtn.classList.add('hidden');
    }
    
    if (signatureFileInput) signatureFileInput.value = '';
    if (uploadPreviewContainer) uploadPreviewContainer.classList.add('hidden');
    if (uploadPreviewImage) uploadPreviewImage.src = '';

    showNewSignaturePad();
  }

  function closeModal() {
    modal.classList.add('hidden');
  }

  // Cargar empresas en el selector de empresa
  async function loadCompaniesIntoSelect(selectedId = '') {
    const companySelect = document.getElementById('companySelect') as HTMLSelectElement | null;
    if (!companySelect) return;

    try {
      const resp = await fetch('/api/admin/companies');
      const data = await resp.json();
      if (data.success && Array.isArray(data.data)) {
        // Reiniciar opciones
        companySelect.innerHTML = '<option value="">Particular / Sin empresa</option>';
        data.data.forEach((c: any) => {
          const opt = document.createElement('option');
          opt.value = String(c.id);
          opt.textContent = c.name;
          companySelect.appendChild(opt);
        });
        companySelect.value = selectedId || '';
        syncCompanyInputState();
      }
    } catch (err) {
      // Silently fail
    }
  }

  // Sincronizar estado del input de empresa según el selector
  function syncCompanyInputState() {
    const companySelectEl = document.getElementById('companySelect') as HTMLSelectElement | null;
    const companyInputEl = document.querySelector('input[name="company"]') as HTMLInputElement | null;
    if (!companySelectEl || !companyInputEl) return;
    if (companySelectEl.value && companySelectEl.value !== '') {
      companyInputEl.disabled = true;
      companyInputEl.value = '';
      companyInputEl.placeholder = 'Empresa seleccionada en lista';
    } else {
      companyInputEl.disabled = false;
      companyInputEl.placeholder = 'Nombre de empresa (opcional)';
    }
  }

  // Listener de cambio en selector de empresa
  document.addEventListener('change', (e) => {
    const target = e.target as HTMLElement;
    if (target && (target as HTMLSelectElement).id === 'companySelect') {
      syncCompanyInputState();
    }
  });

  // Cerrar modal al hacer clic fuera
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Búsqueda
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  let searchTimeout: NodeJS.Timeout;

  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentPage = 1; // Reset to first page
      loadPatients(searchInput.value.trim());
    }, 300);
  });

  // Formulario de paciente
  patientForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    e.stopPropagation();

    const formData = new FormData(patientForm);
    
    // Agregar firma si existe
    if (currentSignatureMode === 'draw') {
      // Obtener el blob directamente del componente SignaturePad
      if ((window as any).signaturePad && typeof (window as any).signaturePad.getBlob === 'function') {
        const blob = await (window as any).signaturePad.getBlob();
        if (blob) {
          formData.append('signature', blob, 'signature.png');
        }
      } else if (currentSignatureBlob) {
        // Fallback por si getBlob no está disponible (versión anterior del componente)
        formData.append('signature', currentSignatureBlob, 'signature.png');
      }
    } else if (currentSignatureMode === 'upload' && signatureFile) {
      formData.append('signature', signatureFile);
    }

    // Agregar foto si existe (ya sea subida o de cámara)
    if (photoFile) {
      formData.delete('photo'); // Eliminar el campo del input file original
      formData.append('photo', photoFile);
    }

    if (deletePhoto) {
      formData.append('deletePhoto', 'true');
    }

    // Validación extra del documento
    const documentNumber = formData.get('documentNumber') as string;
    if (!documentNumber || documentNumber.trim() === '') {
      showAlert('error', 'Error', 'El número de documento es requerido');
      return;
    }
    
    const submitBtn = document.querySelector('#patientForm button[type="submit"]') as HTMLButtonElement;
    const submitBtnText = document.getElementById('submitBtnText')!;
    const submitBtnLoader = document.getElementById('submitBtnLoader')!;
    
    // Verificar si es edición o creación
    const patientId = patientForm.dataset.patientId;
    const isEditing = !!patientId;
    
    // Estado de carga
    submitBtn.disabled = true;
    submitBtnText.textContent = isEditing ? 'Actualizando...' : 'Guardando...';
    submitBtnLoader.classList.remove('hidden');

    try {
      const url = isEditing ? `/api/admin/patients/${patientId}` : '/api/admin/patients';
      const method = isEditing ? 'PUT' : 'POST';

      const response = await fetch(url, {
        method: method,
        body: formData // Enviar como FormData para soportar archivos
      });

      const result = await response.json();

      if (result.success) {
        showAlert('success', isEditing ? '¡Paciente actualizado!' : '¡Paciente registrado!',
                 isEditing ? 'El paciente ha sido actualizado exitosamente' : 'El paciente ha sido registrado exitosamente');
        
        closeModal();
        loadPatients();
        loadStatistics();
        
        // Verificar inmediatamente si se guardó correctamente
        if (!isEditing && result.data && result.data.id) {
          setTimeout(async () => {
            try {
              const verifyResponse = await fetch(`/api/admin/patients/${result.data.id}`);
              const verifyResult = await verifyResponse.json();
              if (verifyResult.success && verifyResult.data) {
              }
            } catch (verifyError) {
              // Silently fail
            }
          }, 1000);
        }
      } else {
        // Silently fail
        
        const alertResult = showAlert('error', 'Error', result.message);
        // Silently fail
      }
    } catch (error) {
      // Silently fail
      showAlert('error', 'Error', isEditing ? 'No se pudo actualizar el paciente' : 'No se pudo registrar el paciente');
    } finally {
      submitBtn.disabled = false;
      submitBtnText.textContent = isEditing ? 'Actualizar Paciente' : 'Guardar Paciente';
      submitBtnLoader.classList.add('hidden');
    }
  });

  // Función helper para mostrar alertas - usando SweetAlert2 global
  function showAlert(type: 'success' | 'error' | 'warning' | 'info', title: string, message?: string, timer?: number) {
    // Usar las funciones globales de SweetAlert2
    if (typeof (window as any).showSweetAlert === 'function') {
      return (window as any).showSweetAlert(type, title, message, timer);
    } else {
      // Fallback a alerta nativa
      const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : type === 'warning' ? '⚠️' : 'ℹ️';
      const fullMessage = message ? `${icon} ${title}: ${message}` : `${icon} ${title}`;
      alert(fullMessage);
      return Promise.resolve();
    }
  }

  // Event listeners
  document.getElementById('newPatientBtn')!.addEventListener('click', openModal);
  document.getElementById('closeModal')!.addEventListener('click', closeModal);
  document.getElementById('cancelBtn')!.addEventListener('click', closeModal);

  // Configurar validación de fecha de nacimiento
  const dateOfBirthInput = document.getElementById('dateOfBirth') as HTMLInputElement;
  const today = new Date().toISOString().split('T')[0]; // Formato YYYY-MM-DD
  dateOfBirthInput.max = today; // No permitir fechas futuras
  
  // Validación adicional al cambiar la fecha
  dateOfBirthInput.addEventListener('change', (e) => {
    const selectedDate = new Date((e.target as HTMLInputElement).value);
    const currentDate = new Date();
    
    if (selectedDate > currentDate) {
      showAlert('error', 'Fecha Inválida', 'La fecha de nacimiento no puede ser mayor a la fecha actual');
      (e.target as HTMLInputElement).value = '';
    }
  });

  // Refresh button
  document.getElementById('refreshBtn')!.addEventListener('click', () => {
    loadPatients();
    loadStatistics();
  });

  // Funciones para acciones de pacientes
  (window as any).viewPatient = (id: number) => {
    window.location.href = `/admin/patients/${id}`;
  };

  (window as any).viewAppointmentHistory = (id: number) => {
    window.location.href = `/admin/patients/${id}#appointments`;
  };

    (window as any).editPatient = async (id: number) => {
    try {
      console.log('Fetching patient data for ID:', id);
      // Obtener datos del paciente
      const response = await fetch(`/api/admin/patients/${id}`);
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const contentType = response.headers.get('content-type');
      if (!contentType || !contentType.includes('application/json')) {
        const text = await response.text();
        console.error('Non-JSON response:', text);
        throw new Error('La respuesta del servidor no es JSON válido');
      }

      const result = await response.json();
      console.log('Patient data received:', result);

      if (result.success && result.data) {
        const patient = result.data;

        // Poblar el formulario con los datos del paciente - usando helper para seguridad
        const setVal = (selector: string, value: string | null | undefined) => {
          try {
            const el = document.querySelector(selector) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
            if (el) {
              el.value = value || '';
            } else {
              console.warn(`Element not found: ${selector}`);
            }
          } catch (e) {
            console.error(`Error setting value for ${selector}:`, e);
          }
        };

        try {
          console.log('Populating basic fields...');
          setVal('input[name="name"]', patient.name);
          setVal('input[name="email"]', patient.email);
          setVal('input[name="phone"]', patient.phone);
          setVal('select[name="documentType"]', patient.document_type);
          setVal('input[name="documentNumber"]', patient.document_number);

          // Formatear fecha de nacimiento para el input date (YYYY-MM-DD)
          if (patient.date_of_birth) {
            const date = new Date(patient.date_of_birth);
            const formattedDate = !isNaN(date.getTime())
              ? date.toISOString().split('T')[0]
              : '';
            setVal('input[name="dateOfBirth"]', formattedDate);
          } else {
            setVal('input[name="dateOfBirth"]', '');
          }

          setVal('select[name="gender"]', patient.gender);
          setVal('select[name="bloodType"]', patient.blood_type);
          setVal('textarea[name="address"]', patient.address);
          setVal('input[name="occupation"]', patient.occupation);
          setVal('input[name="company"]', patient.company);
          setVal('input[name="emergencyContactName"]', patient.emergency_contact_name);
          setVal('input[name="emergencyContactPhone"]', patient.emergency_contact_phone);
          
          // Campos médicos
          setVal('textarea[name="allergies"]', patient.allergies);
          setVal('textarea[name="medications"]', patient.medications);
          setVal('textarea[name="medicalConditions"]', patient.medical_conditions);
        } catch (formError) {
          console.error('Error populating basic form fields:', formError);
        }

        try {
          console.log('Handling company selection...');
          // Cargar empresas y preseleccionar la del paciente si existe
          await loadCompaniesIntoSelect(patient.company_id ? String(patient.company_id) : '');
          const companySelectEl = document.querySelector('select[name="companyId"]') as HTMLSelectElement | null;
          if (companySelectEl) {
            companySelectEl.value = patient.company_id ? String(patient.company_id) : '';
          }
          syncCompanyInputState();
        } catch (companyError) {
          console.error('Error handling company selection:', companyError);
        }

        try {
          console.log('Handling media (photo/signature)...');
          // Gestionar Foto
          photoFile = null;
          deletePhoto = false;
          if (patient.photo_path) {
              if (photoPreview && photoPlaceholder && removePhotoBtn) {
                  photoPreview.src = patient.photo_path;
                  photoPreview.classList.remove('hidden');
                  photoPlaceholder.classList.add('hidden');
                  removePhotoBtn.classList.remove('hidden');
              }
          } else {
              if (photoPreview && photoPlaceholder && removePhotoBtn) {
                  photoPreview.src = '';
                  photoPreview.classList.add('hidden');
                  photoPlaceholder.classList.remove('hidden');
                  removePhotoBtn.classList.add('hidden');
              }
          }

          // Gestionar firma
          currentSignatureBlob = null;
          signatureFile = null;
          switchSignatureMode('draw');
          
          if (patient.signature_path) {
            // Si tiene firma, mostrarla
            showExistingSignature(patient.signature_path);
          } else {
            // Si no tiene firma, mostrar el pad
            showNewSignaturePad();
          }
        } catch (mediaError) {
          console.error('Error handling media (photo/signature):', mediaError);
        }

        console.log('Opening modal...');
        // Cambiar el título del modal y agregar el ID del paciente
        const modalTitle = document.getElementById('modalTitle');
        if (modalTitle) modalTitle.textContent = 'Editar Paciente';
        
        if (patientForm) patientForm.dataset.patientId = id.toString();

        // Abrir modal
        if (modal) {
          modal.classList.remove('hidden');
        } else {
          console.error('Modal element not found');
          showAlert('error', 'Error', 'Error interno: No se pudo abrir el modal');
        }
      } else {
        console.error('API returned success:false or no data', result);
        showAlert('error', 'Error', result.message || 'No se pudo cargar la información del paciente');
      }
    } catch (error) {
      console.error('Error loading patient data (full stack):', error);
      showAlert('error', 'Error', 'Error al cargar datos del paciente: ' + (error instanceof Error ? error.message : String(error)));
    }
  };

  (window as any).scheduleAppointment = (id: number) => {
    window.location.href = `/admin/appointments/new?patientId=${id}`;
  };

  (window as any).deletePatient = async (id: number, name: string) => {
    const result = await (window as any).showSweetConfirm(
      '🗑️ Eliminar Paciente',
      `¿Está seguro de que desea eliminar al paciente "${name}"?\n\nEsta acción no se puede deshacer y eliminará:\n• Todos los datos del paciente\n• Su historial médico\n• Citas asociadas\n\n¿Desea continuar?`,
      '🗑️ Sí, eliminar',
      '❌ Cancelar'
    );

    if (!result.isConfirmed) {
      return;
    }

    try {
      const response = await fetch(`/api/admin/patients/${id}`, {
        method: 'DELETE'
      });

      const deleteResult = await response.json();

      if (deleteResult.success) {
        showAlert('success', 'Eliminado', 'El paciente ha sido eliminado exitosamente');
        
        // Recargar la lista de pacientes
        loadPatients();
        loadStatistics();
      } else {
        showAlert('error', 'Error', deleteResult.message || 'No se pudo eliminar el paciente');
      }
    } catch (error) {
      showAlert('error', 'Error', 'Error al eliminar el paciente');
    }
  };

  // Impersonar usuario
  (window as any).impersonateUser = async (id: number, name: string) => {
    // Usar Swal directamente si está disponible, o confirm nativo
    if (typeof Swal !== 'undefined') {
      const result = await Swal.fire({
        title: '🕵️ Iniciar Sesión como Paciente',
        text: `¿Estás seguro de que deseas iniciar sesión como "${name}"? Esto te desconectará de tu sesión de administrador temporalmente.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#7c3aed', // Purple
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Sí, acceder',
        cancelButtonText: 'Cancelar'
      });

      if (!result.isConfirmed) return;
    } else {
      if (!confirm(`¿Estás seguro de que deseas iniciar sesión como "${name}"? Esto te desconectará de tu sesión de administrador temporalmente.`)) {
        return;
      }
    }

    try {
      const response = await fetch('/api/auth/impersonate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ userId: id })
      });
      
      const data = await response.json();
      
      if (data.success) {
        window.location.href = data.redirectUrl;
      } else {
        showAlert('error', 'Error', data.message);
      }
    } catch (error) {
      console.error('Error:', error);
      showAlert('error', 'Error', 'Ocurrió un error al intentar iniciar sesión');
    }
  };

  // Cargar datos iniciales
  loadStatistics();
  loadPatients();
</script>

  <script>
    // Inicialización de la página
    document.addEventListener('DOMContentLoaded', function() {
      // Verificar si hay un parámetro edit en la URL
      const urlParams = new URLSearchParams(window.location.search);
      const editPatientId = urlParams.get('edit');

      if (editPatientId) {
        // Esperar a que se carguen los pacientes y luego abrir el modal de edición
        setTimeout(() => {
          if ((window as any).editPatient) {
            (window as any).editPatient(parseInt(editPatientId));
          }
        }, 1000);
      }
    });
  </script>
  </div>
</DashboardLayout>