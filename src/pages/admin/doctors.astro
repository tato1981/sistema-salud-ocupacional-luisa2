---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { requireAuth } from '../../lib/auth';

// Verificar autenticación y rol de administrador
const user = requireAuth(Astro.cookies);
if (!user || user.role !== 'admin') {
  return Astro.redirect('/auth/login');
}
---

<DashboardLayout title="Gestión de Doctores - Admin" user={user}>
  <div class="space-y-6">
    <!-- Encabezado de página -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">👨‍⚕️ Gestión de Doctores</h1>
      <button
        onclick="openAddDoctorModal()"
        class="mt-4 sm:mt-0 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium flex items-center justify-center text-sm sm:text-base"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        <span class="hidden sm:inline">Agregar Doctor</span>
        <span class="sm:hidden">Nuevo</span>
      </button>
    </div>
      
      <!-- Stats Cards Responsive -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-8">
        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-blue-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Total Doctores</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="totalDoctors">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-green-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Activos</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="activeDoctors">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-yellow-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Especialidades</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="specializations">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-purple-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a1 1 0 011-1h6a1 1 0 011 1v4h3a2 2 0 012 2v1H2V9a2 2 0 012-2h3z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Con Pacientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="doctorsWithPatients">-</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters Responsive -->
      <div class="bg-white p-4 sm:p-6 rounded-lg shadow mb-4 sm:mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Buscar por nombre</label>
            <input 
              type="text" 
              id="searchName"
              placeholder="Buscar doctor..."
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            >
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Especialidad</label>
            <select id="filterSpecialization" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <option value="">Todas las especialidades</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
            <select id="filterStatus" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <option value="">Todos</option>
              <option value="active">Activos</option>
              <option value="inactive">Inactivos</option>
            </select>
          </div>
          <div class="flex items-end">
            <button 
              onclick="clearFilters()"
              class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium text-sm"
            >
              Limpiar Filtros
            </button>
          </div>
        </div>
      </div>

      <!-- Doctors Table/Cards Responsive -->
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-4 py-4 sm:px-6 border-b border-gray-200">
          <h3 class="text-base sm:text-lg font-medium text-gray-900">Lista de Doctores</h3>
        </div>
        
        <!-- Desktop Table View (hidden on mobile) -->
        <div class="hidden lg:block overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Doctor</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Especialidad</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Teléfono</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pacientes</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody id="doctorsTableBody" class="bg-white divide-y divide-gray-200">
              <!-- Los doctores se cargarán aquí dinámicamente para desktop -->
            </tbody>
          </table>
        </div>
        
        <!-- Mobile Cards View (visible only on mobile/tablet) -->
        <div class="lg:hidden" id="doctorsCardsContainer">
          <div id="doctorsCards" class="p-4 space-y-4">
            <!-- Los doctores se cargarán aquí dinámicamente como cards -->
          </div>
        </div>

        <!-- Pagination -->
        <div class="px-4 py-4 sm:px-6 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
          <span class="text-sm text-gray-700" id="resultsCount">Mostrando 0 resultados</span>
          <div class="flex space-x-2">
            <button id="prevBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Anterior</button>
            <button id="nextBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Siguiente</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal Agregar/Editar Doctor -->
    <div id="doctorModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-11/12 md:w-2/3 lg:w-1/2 shadow-lg rounded-md bg-white">
        <div class="mt-3">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-medium text-gray-900" id="modalTitle">Agregar Doctor</h3>
            <button onclick="closeDoctorModal()" class="text-gray-400 hover:text-gray-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          
          <form id="doctorForm">
            <input type="hidden" id="doctorId" name="id">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo *</label>
                <input 
                  type="text" 
                  id="doctorName" 
                  name="name" 
                  required 
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Dr. Juan Pérez"
                >
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input 
                  type="email" 
                  id="doctorEmail" 
                  name="email" 
                  required 
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="doctor@hospital.com"
                >
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Número de Documento *</label>
                <input 
                  type="text" 
                  id="doctorDocument" 
                  name="document_number" 
                  required 
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="12345678"
                >
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                <input 
                  type="tel" 
                  id="doctorPhone" 
                  name="phone" 
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="+57 300 123 4567"
                >
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Especialidad</label>
                <input 
                  type="text" 
                  id="doctorSpecialization" 
                  name="specialization" 
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Medicina General"
                >
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Registro Profesional *</label>
                <input 
                  type="text" 
                  id="doctorLicense" 
                  name="professional_license" 
                  required
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Ej: 12345-MD"
                >
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
                <select
                  id="doctorStatus"
                  name="is_active"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                >
                  <option value="1">Activo</option>
                  <option value="0">Inactivo</option>
                </select>
              </div>
            </div>

            <!-- Firma del Médico -->
            <div class="mb-4 border-t border-gray-200 pt-4">
              <label class="block text-sm font-medium text-gray-700 mb-2">
                ✍️ Firma Digital del Médico
              </label>
              <div class="flex flex-col md:flex-row gap-4">
                <!-- Preview de firma actual/nueva -->
                <div class="flex-1">
                  <div id="signaturePreview" class="border-2 border-dashed border-gray-300 rounded-lg p-4 bg-gray-50 h-32 flex items-center justify-center">
                    <div id="signaturePreviewContent" class="text-center text-gray-400">
                      <svg class="mx-auto h-12 w-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                      </svg>
                      <p class="text-sm">Sin firma</p>
                    </div>
                  </div>
                </div>

                <!-- Controles de upload -->
                <div class="flex-1 flex flex-col justify-center space-y-3">
                  <input
                    type="file"
                    id="signatureFile"
                    name="signature"
                    accept="image/png,image/jpeg,image/jpg,image/webp"
                    class="hidden"
                    onchange="previewSignature(event)"
                  >
                  <button
                    type="button"
                    onclick="document.getElementById('signatureFile').click()"
                    class="w-full bg-blue-100 hover:bg-blue-200 text-blue-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors"
                  >
                    📁 Seleccionar Imagen de Firma
                  </button>
                  <button
                    type="button"
                    id="removeSignatureBtn"
                    onclick="removeSignature()"
                    class="w-full bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors hidden"
                  >
                    🗑️ Eliminar Firma
                  </button>
                  <p class="text-xs text-gray-500">
                    Formatos: PNG, JPG, JPEG, WebP<br>
                    Tamaño máximo: 2 MB<br>
                    Recomendado: Fondo transparente
                  </p>
                </div>
              </div>
              <input type="hidden" id="existingSignaturePath" name="existing_signature_path" value="">
              <input type="hidden" id="removeSignatureFlag" name="remove_signature" value="0">
            </div>

            <div class="mb-4" id="passwordSection">
              <label class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
              <div class="relative">
                <input 
                  type="password" 
                  id="doctorPassword" 
                  name="password" 
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Dejar vacío para no cambiar (en edición)"
                >
                <button 
                  type="button" 
                  onclick="togglePasswordVisibility('doctorPassword')"
                  class="absolute inset-y-0 right-0 pr-3 flex items-center"
                >
                  <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
              <button 
                type="button" 
                onclick="closeDoctorModal()"
                class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg"
              >
                Cancelar
              </button>
              <button 
                type="submit"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg"
              >
                Guardar Doctor
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    interface Doctor {
      id: number;
      name: string;
      email: string;
      document_number?: string;
      phone?: string;
      specialization?: string;
      professional_license?: string;
      is_active: boolean;
      patient_count?: number;
    }

    let doctors: Doctor[] = [];
    let filteredDoctors: Doctor[] = [];
    let currentPage = 1;
    const itemsPerPage = 10;

    // Función helper para mostrar alertas - usando SweetAlert2 cuando esté disponible
    function showAlert(type: 'success' | 'error' | 'warning' | 'info', title: string, message?: string) {
      // Intentar usar SweetAlert2 primero
      if (typeof (window as any).Swal !== 'undefined') {
        const config = {
          icon: type,
          title: title,
          text: message || '',
          confirmButtonColor: '#3B82F6'
        };
        
        if (type === 'success') {
          (config as any).timer = 2000;
          (config as any).showConfirmButton = false;
        }
        
        return (window as any).Swal.fire(config);
      } else {
        // Fallback a alerta nativa
        const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : type === 'warning' ? '⚠️' : 'ℹ️';
        const fullMessage = message ? `${icon} ${title}: ${message}` : `${icon} ${title}`;
        alert(fullMessage);
      }
    }

    // Cargar doctores al cargar la página
    document.addEventListener('DOMContentLoaded', function() {
      // Evitar múltiples inicializaciones
      if (window.doctorsPageInitialized) {
        return;
      }
      window.doctorsPageInitialized = true;
      
      loadDoctors();
      setupEventListeners();
    });

    function setupEventListeners() {
      // Eventos de filtros
      document.getElementById('searchName')?.addEventListener('input', filterDoctors);
      document.getElementById('filterSpecialization')?.addEventListener('change', filterDoctors);
      document.getElementById('filterStatus')?.addEventListener('change', filterDoctors);

      // Evento del formulario
      document.getElementById('doctorForm')?.addEventListener('submit', handleDoctorSubmit);
    }

    // Cargar doctores
    async function loadDoctors() {
      try {
        const response = await fetch('/api/admin/doctors/list');
        const result = await response.json();
        
        if (result.success) {
          doctors = result.data;
          filteredDoctors = [...doctors];
          renderDoctors();
          updateStats();
          updateSpecializationFilter();
        }
      } catch (error) {
        alert('❌ Error: No se pudieron cargar los doctores');
      }
    }

    // Renderizar tabla de doctores
    function renderDoctors() {
      const tbody = document.getElementById('doctorsTableBody');
      const cardsContainer = document.getElementById('doctorsCards');
      const resultsCount = document.getElementById('resultsCount');
      const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
      const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
      
      if (!tbody || !cardsContainer) return;

      if (filteredDoctors.length === 0) {
        if (resultsCount) resultsCount.textContent = 'Mostrando 0 resultados';
        if (prevBtn) prevBtn.disabled = true;
        if (nextBtn) nextBtn.disabled = true;

        // Vista tabla - desktop
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="px-6 py-4 text-center text-gray-500">
              No se encontraron doctores
            </td>
          </tr>
        `;
        
        // Vista cards - móvil
        cardsContainer.innerHTML = `
          <div class="text-center py-8 text-gray-500">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <p>No se encontraron doctores</p>
          </div>
        `;
        return;
      }

      // Paginación
      const totalPages = Math.ceil(filteredDoctors.length / itemsPerPage);
      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const paginatedDoctors = filteredDoctors.slice(start, end);

      if (resultsCount) {
        resultsCount.textContent = `Mostrando ${start + 1} - ${Math.min(end, filteredDoctors.length)} de ${filteredDoctors.length} resultados`;
      }

      if (prevBtn) {
        prevBtn.disabled = currentPage === 1;
        // Clonar para limpiar event listeners anteriores
        const newPrevBtn = prevBtn.cloneNode(true) as HTMLButtonElement;
        prevBtn.parentNode?.replaceChild(newPrevBtn, prevBtn);
        newPrevBtn.addEventListener('click', () => {
          if (currentPage > 1) {
            currentPage--;
            renderDoctors();
          }
        });
      }

      if (nextBtn) {
        nextBtn.disabled = currentPage >= totalPages;
        // Clonar para limpiar event listeners anteriores
        const newNextBtn = nextBtn.cloneNode(true) as HTMLButtonElement;
        nextBtn.parentNode?.replaceChild(newNextBtn, nextBtn);
        newNextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) {
            currentPage++;
            renderDoctors();
          }
        });
      }

      // Renderizar tabla para desktop
      tbody.innerHTML = paginatedDoctors.map(doctor => `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-10 w-10">
                <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center">
                  <span class="text-sm font-medium text-blue-800">${doctor.name.split(' ').map(n => n[0]).join('')}</span>
                </div>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-900">${doctor.name}</div>
                <div class="text-sm text-gray-500">${doctor.email}</div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
            ${doctor.document_number || 'No registrado'}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
            <div>${doctor.specialization || 'Medicina General'}</div>
            <div class="text-xs text-gray-500">${doctor.professional_license || ''}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
            ${doctor.phone || 'No registrado'}
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${doctor.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
              ${doctor.is_active ? 'Activo' : 'Inactivo'}
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
            ${doctor.patient_count || 0} pacientes
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
            <div class="flex space-x-2">
              <button onclick="editDoctor(${doctor.id})" class="text-blue-600 hover:text-blue-900 text-sm">
                Editar
              </button>
              <button onclick="toggleDoctorStatus(${doctor.id})" class="text-yellow-600 hover:text-yellow-900 text-sm">
                ${doctor.is_active ? 'Desactivar' : 'Activar'}
              </button>
              <button onclick="resetDoctorPassword(${doctor.id})" class="text-green-600 hover:text-green-900 text-sm">
                Reset Password
              </button>
              <button onclick="deleteDoctor(${doctor.id}, '${doctor.name.replace(/'/g, "\\\'")}')" class="text-red-600 hover:text-red-900 text-sm">
                Eliminar
              </button>
              <button onclick="impersonateUser(${doctor.id}, '${doctor.name.replace(/'/g, "\\\'")}')" class="text-purple-600 hover:text-purple-900 text-sm" title="Iniciar sesión como este usuario">
                🕵️ Acceder
              </button>
            </div>
          </td>
        </tr>
      `).join('');

      // Renderizar cards para móvil
      cardsContainer.innerHTML = paginatedDoctors.map(doctor => `
        <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
          <div class="flex items-center mb-3">
            <div class="flex-shrink-0 h-12 w-12">
              <div class="h-12 w-12 rounded-full bg-blue-100 flex items-center justify-center">
                <span class="text-base font-medium text-blue-800">${doctor.name.split(' ').map(n => n[0]).join('')}</span>
              </div>
            </div>
            <div class="ml-3 flex-1 min-w-0">
              <h4 class="text-sm font-medium text-gray-900 truncate">${doctor.name}</h4>
              <p class="text-sm text-gray-500 truncate">${doctor.email}</p>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${doctor.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
                ${doctor.is_active ? 'Activo' : 'Inactivo'}
              </span>
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-3 text-sm mb-4">
            <div>
              <span class="font-medium text-gray-600">Documento:</span>
              <p class="text-gray-900">${doctor.document_number || 'No registrado'}</p>
            </div>
            <div>
              <span class="font-medium text-gray-600">Teléfono:</span>
              <p class="text-gray-900">${doctor.phone || 'No registrado'}</p>
            </div>
            <div>
              <span class="font-medium text-gray-600">Especialidad:</span>
              <p class="text-gray-900">${doctor.specialization || 'Medicina General'}</p>
              <p class="text-xs text-gray-500">${doctor.professional_license ? 'Reg: ' + doctor.professional_license : ''}</p>
            </div>
            <div>
              <span class="font-medium text-gray-600">Pacientes:</span>
              <p class="text-gray-900">${doctor.patient_count || 0} pacientes</p>
            </div>
          </div>
          
          <div class="flex flex-wrap gap-2">
            <button onclick="editDoctor(${doctor.id})" class="flex-1 bg-blue-50 text-blue-700 px-3 py-2 rounded text-xs font-medium hover:bg-blue-100">
              ✏️ Editar
            </button>
            <button onclick="toggleDoctorStatus(${doctor.id})" class="flex-1 bg-yellow-50 text-yellow-700 px-3 py-2 rounded text-xs font-medium hover:bg-yellow-100">
              ${doctor.is_active ? '⏸️ Desactivar' : '▶️ Activar'}
            </button>
            <button onclick="resetDoctorPassword(${doctor.id})" class="flex-1 bg-green-50 text-green-700 px-3 py-2 rounded text-xs font-medium hover:bg-green-100">
              🔐 Reset
            </button>
            <button onclick="deleteDoctor(${doctor.id}, '${doctor.name.replace(/'/g, "\\\'")}')" class="flex-1 bg-red-50 text-red-700 px-3 py-2 rounded text-xs font-medium hover:bg-red-100">
              🗑️ Eliminar
            </button>
            <button onclick="impersonateUser(${doctor.id}, '${doctor.name.replace(/'/g, "\\\'")}')" class="flex-1 bg-purple-50 text-purple-700 px-3 py-2 rounded text-xs font-medium hover:bg-purple-100">
              🕵️ Acceder
            </button>
          </div>
        </div>
      `).join('');
    }

    // Actualizar estadísticas
    function updateStats() {
      const totalDoctors = doctors.length;
      const activeDoctors = doctors.filter(d => d.is_active).length;
      const specializations = new Set(doctors.map(d => d.specialization || 'Medicina General')).size;
      const doctorsWithPatients = doctors.filter(d => (d.patient_count || 0) > 0).length;

      document.getElementById('totalDoctors')!.textContent = totalDoctors.toString();
      document.getElementById('activeDoctors')!.textContent = activeDoctors.toString();
      document.getElementById('specializations')!.textContent = specializations.toString();
      document.getElementById('doctorsWithPatients')!.textContent = doctorsWithPatients.toString();
    }

    // Actualizar filtro de especialidades
    function updateSpecializationFilter() {
      const select = document.getElementById('filterSpecialization') as HTMLSelectElement;
      if (!select) return;

      const specializations = new Set(doctors.map(d => d.specialization || 'Medicina General'));
      const currentValue = select.value;
      
      select.innerHTML = '<option value="">Todas las especialidades</option>';
      specializations.forEach(spec => {
        const option = document.createElement('option');
        option.value = spec;
        option.textContent = spec;
        select.appendChild(option);
      });
      
      select.value = currentValue;
    }

    // Filtrar doctores
    function filterDoctors() {
      const searchName = (document.getElementById('searchName') as HTMLInputElement)?.value.toLowerCase() || '';
      const filterSpec = (document.getElementById('filterSpecialization') as HTMLSelectElement)?.value || '';
      const filterStatus = (document.getElementById('filterStatus') as HTMLSelectElement)?.value || '';

      filteredDoctors = doctors.filter(doctor => {
        const matchesName = doctor.name.toLowerCase().includes(searchName) || 
                           doctor.email.toLowerCase().includes(searchName);
        const matchesSpec = !filterSpec || (doctor.specialization || 'Medicina General') === filterSpec;
        const matchesStatus = !filterStatus || 
                             (filterStatus === 'active' && doctor.is_active) ||
                             (filterStatus === 'inactive' && !doctor.is_active);

        return matchesName && matchesSpec && matchesStatus;
      });

      currentPage = 1;
      renderDoctors();
    }

    // Limpiar filtros
    function clearFilters() {
      (document.getElementById('searchName') as HTMLInputElement).value = '';
      (document.getElementById('filterSpecialization') as HTMLSelectElement).value = '';
      (document.getElementById('filterStatus') as HTMLSelectElement).value = '';
      filterDoctors();
    }

    // Abrir modal para agregar doctor
    (window as any).openAddDoctorModal = () => {
      document.getElementById('modalTitle')!.textContent = 'Agregar Doctor';
      (document.getElementById('doctorForm') as HTMLFormElement).reset();
      document.getElementById('doctorId')!.setAttribute('value', '');
      document.getElementById('passwordSection')!.style.display = 'block';
      document.getElementById('doctorPassword')!.setAttribute('required', 'true');
      document.getElementById('doctorModal')!.classList.remove('hidden');
    };

    // Preview de firma
    (window as any).previewSignature = (event: Event) => {
      const input = event.target as HTMLInputElement;
      const file = input.files?.[0];

      if (file) {
        // Validar tamaño (2 MB máximo)
        if (file.size > 2 * 1024 * 1024) {
          showAlert('error', 'Archivo muy grande', 'La imagen no debe superar 2 MB');
          input.value = '';
          return;
        }

        // Validar tipo
        const validTypes = ['image/png', 'image/jpeg', 'image/jpg', 'image/webp'];
        if (!validTypes.includes(file.type)) {
          showAlert('error', 'Formato no válido', 'Solo se permiten imágenes PNG, JPG, JPEG o WebP');
          input.value = '';
          return;
        }

        // Mostrar preview
        const reader = new FileReader();
        reader.onload = (e) => {
          const previewContent = document.getElementById('signaturePreviewContent')!;
          previewContent.innerHTML = `
            <img src="${e.target?.result}" alt="Firma" class="max-h-24 max-w-full object-contain">
          `;
          document.getElementById('removeSignatureBtn')!.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      }
    };

    // Eliminar firma
    (window as any).removeSignature = () => {
      const fileInput = document.getElementById('signatureFile') as HTMLInputElement;
      fileInput.value = '';

      const previewContent = document.getElementById('signaturePreviewContent')!;
      previewContent.innerHTML = `
        <svg class="mx-auto h-12 w-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
        </svg>
        <p class="text-sm text-gray-400">Sin firma</p>
      `;

      document.getElementById('removeSignatureBtn')!.classList.add('hidden');
      document.getElementById('removeSignatureFlag')!.setAttribute('value', '1');
    };

    // Editar doctor
    (window as any).editDoctor = async (id: number) => {
      const doctor = doctors.find(d => d.id === id);
      if (!doctor) return;

      document.getElementById('modalTitle')!.textContent = 'Editar Doctor';
      document.getElementById('doctorId')!.setAttribute('value', id.toString());
      (document.getElementById('doctorName') as HTMLInputElement).value = doctor.name;
      (document.getElementById('doctorEmail') as HTMLInputElement).value = doctor.email;
      (document.getElementById('doctorDocument') as HTMLInputElement).value = doctor.document_number || '';
      (document.getElementById('doctorPhone') as HTMLInputElement).value = doctor.phone || '';
      (document.getElementById('doctorSpecialization') as HTMLInputElement).value = doctor.specialization || '';
      (document.getElementById('doctorLicense') as HTMLInputElement).value = doctor.professional_license || '';
      (document.getElementById('doctorStatus') as HTMLSelectElement).value = doctor.is_active ? '1' : '0';

      // Cargar firma existente si existe
      if ((doctor as any).signature_path) {
        const previewContent = document.getElementById('signaturePreviewContent')!;
        previewContent.innerHTML = `
          <img src="${(doctor as any).signature_path}" alt="Firma actual" class="max-h-24 max-w-full object-contain">
        `;
        document.getElementById('existingSignaturePath')!.setAttribute('value', (doctor as any).signature_path);
        document.getElementById('removeSignatureBtn')!.classList.remove('hidden');
      } else {
        // Resetear vista de firma
        const previewContent = document.getElementById('signaturePreviewContent')!;
        previewContent.innerHTML = `
          <svg class="mx-auto h-12 w-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
          <p class="text-sm text-gray-400">Sin firma</p>
        `;
        document.getElementById('existingSignaturePath')!.setAttribute('value', '');
        document.getElementById('removeSignatureBtn')!.classList.add('hidden');
      }
      document.getElementById('removeSignatureFlag')!.setAttribute('value', '0');

      document.getElementById('passwordSection')!.style.display = 'block';
      document.getElementById('doctorPassword')!.removeAttribute('required');
      (document.getElementById('doctorPassword') as HTMLInputElement).placeholder = 'Dejar vacío para no cambiar';

      document.getElementById('doctorModal')!.classList.remove('hidden');
    };

    // Cerrar modal
    (window as any).closeDoctorModal = () => {
      document.getElementById('doctorModal')!.classList.add('hidden');
    };

    // Toggle password visibility
    (window as any).togglePasswordVisibility = (inputId: string) => {
      const input = document.getElementById(inputId) as HTMLInputElement;
      const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
      input.setAttribute('type', type);
    };

    // Manejar submit del formulario
    async function handleDoctorSubmit(e: Event) {
      e.preventDefault();

      const formData = new FormData(e.target as HTMLFormElement);
      const doctorId = formData.get('id');
      const isEdit = doctorId && doctorId !== '';

      const url = isEdit ? `/api/admin/doctors/update` : `/api/admin/doctors/create`;
      const method = 'POST';

      try {
        // Enviar FormData directamente para soportar archivos
        const response = await fetch(url, {
          method,
          body: formData // NO incluir Content-Type, el navegador lo configura automáticamente con boundary
        });

        const result = await response.json();

        if (result.success) {
          showAlert('success', isEdit ? 'Doctor actualizado correctamente' : 'Doctor creado correctamente');
          (window as any).closeDoctorModal();
          loadDoctors();
        } else {
          showAlert('error', 'Error al guardar doctor', result.message);
        }
      } catch (error) {
        showAlert('error', 'Error de conexión');
      }
    }

    // Toggle status
    (window as any).toggleDoctorStatus = async (id: number) => {
      const doctor = doctors.find(d => d.id === id);
      if (!doctor) {
        showAlert('error', 'Error', 'Doctor no encontrado');
        return;
      }

      const action = doctor.is_active ? 'desactivar' : 'activar';
      const actionUpper = action.charAt(0).toUpperCase() + action.slice(1);
      
      const result = await (window as any).showSweetConfirm(
        `${doctor.is_active ? '⏸️' : '▶️'} ${actionUpper} Doctor`,
        `Doctor: ${doctor.name}\nEstado actual: ${doctor.is_active ? '✅ Activo' : '❌ Inactivo'}\n\n${doctor.is_active 
          ? 'Al desactivar, el doctor no podrá acceder al sistema, pero mantendrá sus pacientes asignados.'
          : 'Al activar, el doctor podrá acceder nuevamente al sistema.'}\n\n¿Desea continuar?`,
        `${doctor.is_active ? '⏸️ Sí, desactivar' : '▶️ Sí, activar'}`,
        '❌ Cancelar'
      );

      if (!result.isConfirmed) {
        return;
      }

      try {
        const response = await fetch(`/api/admin/doctors/toggle-status`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ id, is_active: !doctor.is_active })
        });
        
        const apiResult = await response.json();
        
        if (apiResult.success) {
          showAlert('success', `¡Doctor ${action}do!`, `${doctor.name} ha sido ${action}do correctamente`);
          loadDoctors();
        } else {
          showAlert('error', `Error al ${action} doctor`, apiResult.message);
        }
      } catch (error) {
        showAlert('error', 'Error de conexión', 'No se pudo conectar con el servidor');
      }
    };

    // Eliminar doctor
    (window as any).deleteDoctor = async (id: number, name: string) => {
      const result = await (window as any).showSweetConfirm(
        '🗑️ Eliminar Doctor',
        `Doctor: ${name}\n\nEsta acción:\n• Eliminará permanentemente al doctor\n• Solo es posible si no tiene pacientes asignados\n• Solo es posible si no tiene citas programadas\n• No se puede deshacer\n\n¿Está seguro de eliminar al doctor "${name}"?`,
        '🗑️ Sí, eliminar',
        '❌ Cancelar'
      );

      if (!result.isConfirmed) {
        return;
      }

      // Procesando eliminación...

      try {
        const response = await fetch(`/api/admin/doctors/${id}`, {
          method: 'DELETE'
        });
        
        const apiResult = await response.json();
        
        if (apiResult.success) {
          showAlert('success', '¡Doctor eliminado!', `${name} ha sido eliminado correctamente del sistema`);
          loadDoctors(); // Recargar la lista
        } else {
          showAlert('error', 'No se pudo eliminar', apiResult.message || 'Error al eliminar doctor');
        }
      } catch (error) {
        showAlert('error', 'Error de conexión', 'No se pudo conectar con el servidor');
      }
    };

    // Reset password
    (window as any).resetDoctorPassword = async (id: number) => {
      const doctor = doctors.find(d => d.id === id);
      if (!doctor) {
        showAlert('error', 'Error', 'Doctor no encontrado');
        return;
      }

      const result = await (window as any).showSweetConfirm(
        '🔐 Resetear Contraseña',
        `Doctor: ${doctor.name}\nEmail: ${doctor.email}\n\n⚠️ Importante:\n• La nueva contraseña será: 123456\n• Se recomienda que el doctor la cambie en su próximo acceso\n• Esta acción notificará al doctor por email (si está configurado)\n\n¿Resetear la contraseña de ${doctor.name} a "123456"?`,
        '🔐 Sí, resetear',
        '❌ Cancelar'
      );

      if (!result.isConfirmed) {
        return;
      }

      // Procesando reseteo de contraseña...

      try {
        const response = await fetch(`/api/admin/doctors/reset-password`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ id })
        });
        
        const apiResult = await response.json();
        
        if (apiResult.success) {
          showAlert('success', '🔐 Contraseña reseteada', 
                   `La contraseña de ${doctor.name} ha sido cambiada a "123456"`);
        } else {
          showAlert('error', 'Error al resetear contraseña', apiResult.message);
        }
      } catch (error) {
        showAlert('error', 'Error de conexión', 'No se pudo conectar con el servidor');
      }
    };

    // Impersonar usuario
    (window as any).impersonateUser = async (id: number, name: string) => {
      // Usar Swal directamente si está disponible, o confirm nativo
      if (typeof Swal !== 'undefined') {
        const result = await Swal.fire({
          title: '🕵️ Iniciar Sesión como Usuario',
          text: `¿Estás seguro de que deseas iniciar sesión como "${name}"? Esto te desconectará de tu sesión de administrador temporalmente.`,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#7c3aed', // Purple
          cancelButtonColor: '#6b7280',
          confirmButtonText: 'Sí, acceder',
          cancelButtonText: 'Cancelar'
        });

        if (!result.isConfirmed) return;
      } else {
        if (!confirm(`¿Estás seguro de que deseas iniciar sesión como "${name}"? Esto te desconectará de tu sesión de administrador temporalmente.`)) {
          return;
        }
      }

      try {
        const response = await fetch('/api/auth/impersonate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ userId: id })
        });
        
        const data = await response.json();
        
        if (data.success) {
          window.location.href = data.redirectUrl;
        } else {
          showAlert('error', 'Error', data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        showAlert('error', 'Error', 'Ocurrió un error al intentar iniciar sesión');
      }
    };
  </script>
  </div>
</DashboardLayout>
