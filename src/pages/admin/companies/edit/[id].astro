---
import DashboardLayout from '../../../../components/layout/DashboardLayout.astro';
import { requireAuth } from '../../../../lib/auth';
import { db } from '../../../../lib/database';

const user = requireAuth(Astro.cookies);

if (!user || user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/companies');
}

// Fetch existing company
const [companies] = await db.execute('SELECT * FROM companies WHERE id = ?', [id]);
const company = (companies as any[])[0];

if (!company) {
  return Astro.redirect('/admin/companies');
}

let error = '';
let success = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get('name') as string;
    const nit = formData.get('nit') as string;
    const address = formData.get('address') as string;
    const phone = formData.get('phone') as string;
    const responsible_name = formData.get('responsible_name') as string;
    const email = formData.get('email') as string;
    const status = formData.get('status') as string;

    if (!name || !nit || !email || !responsible_name) {
      error = 'Nombre, NIT, Responsable y Email son campos requeridos';
    } else {
      // Check if NIT or Email already exists for OTHER companies
      const [existing] = await db.execute(
        'SELECT id FROM companies WHERE (nit = ? OR email = ?) AND id != ?',
        [nit, email, id]
      );

      if ((existing as any[]).length > 0) {
        error = 'Ya existe otra empresa con ese NIT o Email';
      } else {
        await db.execute(
          `UPDATE companies 
           SET name = ?, nit = ?, address = ?, phone = ?, responsible_name = ?, email = ?, status = ?
           WHERE id = ?`,
          [name, nit, address, phone, responsible_name, email, status, id]
        );
        return Astro.redirect('/admin/companies?success=updated');
      }
    }
  } catch (e) {
    console.error(e);
    error = 'Error al actualizar la empresa';
  }
}
---

<DashboardLayout title="Editar Empresa" user={user}>
  <div class="max-w-2xl mx-auto">
    <div class="md:flex md:items-center md:justify-between mb-6">
      <div class="flex-1 min-w-0">
        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
          Editar Empresa: {company.name}
        </h2>
      </div>
      <div class="mt-4 flex md:mt-0 md:ml-4">
        <a href="/admin/companies" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
          Cancelar
        </a>
      </div>
    </div>

    {error && (
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">{error}</h3>
          </div>
        </div>
      </div>
    )}

    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <form method="POST" class="space-y-6">
          <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
            <div class="sm:col-span-3">
              <label for="name" class="block text-sm font-medium text-gray-700">
                Nombre de la Empresa *
              </label>
              <div class="mt-1">
                <input type="text" name="name" id="name" required value={company.name} class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
            </div>

            <div class="sm:col-span-3">
              <label for="nit" class="block text-sm font-medium text-gray-700">
                NIT *
              </label>
              <div class="mt-1">
                <input type="text" name="nit" id="nit" required value={company.nit} class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
            </div>

            <div class="sm:col-span-6">
              <label for="address" class="block text-sm font-medium text-gray-700">
                Dirección
              </label>
              <div class="mt-1">
                <input type="text" name="address" id="address" value={company.address} class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
            </div>

            <div class="sm:col-span-3">
              <label for="responsible_name" class="block text-sm font-medium text-gray-700">
                Nombre del Responsable *
              </label>
              <div class="mt-1">
                <input type="text" name="responsible_name" id="responsible_name" required value={company.responsible_name} class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
            </div>

            <div class="sm:col-span-3">
              <label for="phone" class="block text-sm font-medium text-gray-700">
                Teléfono
              </label>
              <div class="mt-1">
                <input type="text" name="phone" id="phone" value={company.phone} class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
            </div>

            <div class="sm:col-span-6">
              <label for="email" class="block text-sm font-medium text-gray-700">
                Correo Electrónico (Para envío de resultados) *
              </label>
              <div class="mt-1">
                <input type="email" name="email" id="email" required value={company.email} class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
              <p class="mt-2 text-sm text-gray-500">
                A este correo se enviarán las notificaciones y resultados de exámenes.
              </p>
            </div>

            <div class="sm:col-span-3">
              <label for="status" class="block text-sm font-medium text-gray-700">
                Estado
              </label>
              <div class="mt-1">
                <select id="status" name="status" class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md">
                  <option value="active" selected={company.status === 'active'}>Activo</option>
                  <option value="inactive" selected={company.status === 'inactive'}>Inactivo</option>
                </select>
              </div>
            </div>
          </div>

          <div class="pt-5">
            <div class="flex justify-end">
              <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                Guardar Cambios
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</DashboardLayout>
