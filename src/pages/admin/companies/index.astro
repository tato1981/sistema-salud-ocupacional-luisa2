---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro';
import { requireAuth } from '../../../lib/auth';
import { db } from '../../../lib/database';

const user = requireAuth(Astro.cookies);

if (!user || user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const [companies] = await db.execute(`
  SELECT c.*, MAX(u.id) as user_id 
  FROM companies c 
  LEFT JOIN users u ON u.company_id = c.id AND u.role = 'company' 
  GROUP BY c.id 
  ORDER BY c.name ASC
`);
---

<DashboardLayout title="Gestión de Empresas" user={user}>
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-bold text-gray-900">Empresas</h1>
      <a href="/admin/companies/create" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Nueva Empresa
      </a>
    </div>

    <div class="bg-white shadow overflow-x-auto sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Empresa
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              NIT
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Contacto
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Email
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Estado
            </th>
            <th scope="col" class="relative px-6 py-3">
              <span class="sr-only">Acciones</span>
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          {(companies as any[]).map((company) => (
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">{company.name}</div>
                <div class="text-sm text-gray-500">{company.address}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">{company.nit}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">{company.responsible_name}</div>
                <div class="text-sm text-gray-500">{company.phone}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">{company.email}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${company.status === 'active' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                  {company.status === 'active' ? 'Activo' : 'Inactivo'}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex justify-end space-x-3">
                  <a href={`/admin/companies/edit/${company.id}`} class="text-blue-600 hover:text-blue-900">Editar</a>
                  {company.user_id && (
                    <button 
                      onclick={`impersonateUser(${company.user_id}, '${company.name.replace(/'/g, "\\'")}')`}
                      class="text-purple-600 hover:text-purple-900 flex items-center" 
                      title="Iniciar sesión como empresa"
                    >
                      <span class="mr-1">🕵️</span> Acceder
                    </button>
                  )}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    // Impersonar usuario
    window.impersonateUser = async (id, name) => {
      // Usar Swal directamente si está disponible, o confirm nativo
      if (typeof Swal !== 'undefined') {
        const result = await Swal.fire({
          title: '🕵️ Iniciar Sesión como Empresa',
          text: `¿Estás seguro de que deseas iniciar sesión como "${name}"? Esto te desconectará de tu sesión de administrador temporalmente.`,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#7c3aed', // Purple
          cancelButtonColor: '#6b7280',
          confirmButtonText: 'Sí, acceder',
          cancelButtonText: 'Cancelar'
        });

        if (!result.isConfirmed) return;
      } else {
        if (!confirm(`¿Estás seguro de que deseas iniciar sesión como "${name}"? Esto te desconectará de tu sesión de administrador temporalmente.`)) {
          return;
        }
      }

      try {
        const response = await fetch('/api/auth/impersonate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ userId: id })
        });
        
        const data = await response.json();
        
        if (data.success) {
          // Redirigir al dashboard (el backend maneja la redirección, pero por si acaso)
          window.location.href = data.redirectUrl || '/dashboard';
        } else {
          if (typeof Swal !== 'undefined') {
            Swal.fire('Error', data.message || 'Error al iniciar sesión', 'error');
          } else {
            alert(data.message || 'Error al iniciar sesión');
          }
        }
      } catch (error) {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
          Swal.fire('Error', 'Ocurrió un error al intentar iniciar sesión', 'error');
        } else {
          alert('Ocurrió un error al intentar iniciar sesión');
        }
      }
    };
  </script>
</DashboardLayout>
