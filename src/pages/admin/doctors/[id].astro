---
import Layout from '../../../layouts/Layout.astro';
import { requireAuth } from '../../../lib/auth';
import { db } from '../../../lib/database';

// Verificar autenticación y rol de administrador
const user = requireAuth(Astro.cookies);
if (!user || user.role !== 'admin') {
  return Astro.redirect('/auth/login');
}

// Obtener ID del doctor desde los parámetros
const doctorId = Astro.params.id;

if (!doctorId) {
  return Astro.redirect('/admin/doctors');
}

// Obtener información del doctor
let doctor = null;
let appointments = [];

try {
  // Obtener datos del doctor
  const [doctorRows] = await db.execute(`
    SELECT u.*, 
           COUNT(DISTINCT p.id) as patient_count,
           COUNT(DISTINCT a.id) as total_appointments,
           COUNT(DISTINCT CASE WHEN a.status = 'completada' THEN a.id END) as completed_appointments
    FROM users u
    LEFT JOIN patients p ON u.id = p.assigned_doctor_id
    LEFT JOIN appointments a ON u.id = a.doctor_id
    WHERE u.id = ? AND u.role = 'doctor'
    GROUP BY u.id
  `, [doctorId]);

  if ((doctorRows as any[]).length === 0) {
    return Astro.redirect('/admin/doctors');
  }

  doctor = (doctorRows as any[])[0];

  // Obtener citas recientes del doctor
  const [appointmentRows] = await db.execute(`
    SELECT a.*, 
           p.name as patient_name,
           p.document_number as patient_document
    FROM appointments a
    LEFT JOIN patients p ON a.patient_id = p.id
    WHERE a.doctor_id = ?
    ORDER BY a.appointment_date DESC, a.appointment_time DESC
    LIMIT 10
  `, [doctorId]);

  appointments = appointmentRows as any[];

} catch (error) {
  // Silently fail
  return Astro.redirect('/admin/doctors');
}
---

<Layout title={`Dr. ${doctor.name} - Perfil`}>
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-4">
          <div class="flex items-center space-x-4">
            <a href="/admin/doctors" class="text-gray-500 hover:text-gray-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </a>
            <h1 class="text-2xl font-bold text-gray-900">Dr. {doctor.name}</h1>
          </div>
          <div class="flex space-x-3">
            <button 
              onclick="window.location.href='/admin/doctors'"
              class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium transition-colors"
            >
              Volver a Doctores
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <!-- Información del Doctor -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        <!-- Perfil del Doctor -->
        <div class="lg:col-span-2">
          <div class="bg-white shadow rounded-lg p-6">
            <div class="flex items-center mb-6">
              <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div class="ml-6">
                <h2 class="text-2xl font-bold text-gray-900">Dr. {doctor.name}</h2>
                <p class="text-gray-600">{doctor.specialization || 'Medicina General'}</p>
                <p class="text-sm text-gray-500">{doctor.email}</p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h3 class="text-lg font-medium text-gray-900 mb-3">Información de Contacto</h3>
                <div class="space-y-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-sm text-gray-900">{doctor.email}</span>
                  </div>
                  {doctor.phone && (
                    <div class="flex items-center">
                      <svg class="w-4 h-4 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                      <span class="text-sm text-gray-900">{doctor.phone}</span>
                    </div>
                  )}
                  {doctor.document_number && (
                    <div class="flex items-center">
                      <svg class="w-4 h-4 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/>
                      </svg>
                      <span class="text-sm text-gray-900">Doc: {doctor.document_number}</span>
                    </div>
                  )}
                </div>
              </div>

              <div>
                <h3 class="text-lg font-medium text-gray-900 mb-3">Información Adicional</h3>
                <div class="space-y-2">
                  <div class="flex items-center">
                    <span class="text-sm text-gray-500 w-20">Estado:</span>
                    <span class={`px-2 py-1 text-xs rounded-full ${doctor.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                      {doctor.is_active ? 'Activo' : 'Inactivo'}
                    </span>
                  </div>
                  <div class="flex items-center">
                    <span class="text-sm text-gray-500 w-20">Rol:</span>
                    <span class="text-sm text-gray-900 capitalize">{doctor.role}</span>
                  </div>
                  <div class="flex items-center">
                    <span class="text-sm text-gray-500 w-20">Ingreso:</span>
                    <span class="text-sm text-gray-900">{new Date(doctor.created_at).toLocaleDateString('es-ES')}</span>
                  </div>
                  {doctor.last_login && (
                    <div class="flex items-center">
                      <span class="text-sm text-gray-500 w-20">Último acceso:</span>
                      <span class="text-sm text-gray-900">{new Date(doctor.last_login).toLocaleDateString('es-ES')}</span>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Estadísticas -->
        <div class="space-y-6">
          <div class="bg-white shadow rounded-lg p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Estadísticas</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Pacientes Asignados</span>
                <span class="text-2xl font-bold text-blue-600">{doctor.patient_count || 0}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Total Citas</span>
                <span class="text-2xl font-bold text-green-600">{doctor.total_appointments || 0}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Citas Completadas</span>
                <span class="text-2xl font-bold text-purple-600">{doctor.completed_appointments || 0}</span>
              </div>
            </div>
          </div>

          <div class="bg-white shadow rounded-lg p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Acciones Rápidas</h3>
            <div class="space-y-3">
              <button 
                onclick="window.location.href='/admin/appointments/new?doctor=${doctor.id}'"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm transition-colors"
              >
                Nueva Cita
              </button>
              <button 
                onclick="window.location.href='/admin/patients?doctor=${doctor.id}'"
                class="w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm transition-colors"
              >
                Ver Pacientes
              </button>
              <button 
                onclick="window.location.href='/admin/doctors'"
                class="w-full bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg text-sm transition-colors"
              >
                Editar Doctor
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Citas Recientes -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Citas Recientes</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paciente</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha y Hora</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Motivo</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              {appointments.map((appointment) => (
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">{appointment.patient_name || 'Sin nombre'}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-600">{appointment.patient_document || '-'}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900">
                      {new Date(appointment.appointment_date).toLocaleDateString('es-ES')}
                    </div>
                    <div class="text-sm text-gray-500">
                      {appointment.appointment_time || 'Sin hora'}
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900 capitalize">{appointment.appointment_type || 'General'}</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`px-2 py-1 text-xs rounded-full ${
                      appointment.status === 'completada' ? 'bg-green-100 text-green-800' :
                      appointment.status === 'programada' ? 'bg-blue-100 text-blue-800' :
                      appointment.status === 'en_progreso' ? 'bg-yellow-100 text-yellow-800' :
                      appointment.status === 'cancelada' ? 'bg-red-100 text-red-800' :
                      'bg-gray-100 text-gray-800'
                    }`}>
                      {appointment.status === 'programada' ? 'Programada' :
                       appointment.status === 'en_progreso' ? 'En progreso' :
                       appointment.status === 'completada' ? 'Completada' :
                       appointment.status === 'cancelada' ? 'Cancelada' :
                       appointment.status === 'no_asistio' ? 'No asistió' :
                       appointment.status}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate">
                    {appointment.reason || '-'}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href={`/admin/patients/${appointment.patient_id}`} class="text-blue-600 hover:text-blue-900">Ver Paciente</a>
                  </td>
                </tr>
              ))}
              {appointments.length === 0 && (
                <tr>
                  <td colspan="7" class="px-6 py-4 text-center text-gray-500">
                    No hay citas registradas para este doctor
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</Layout>