---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Verificar y Descargar Certificado">
  <!-- Header moderno con gradiente -->
  <div class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen">
    <!-- Navegación superior -->
    <div class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <div>
              <h1 class="text-xl font-bold text-gray-900">Verificación de Certificados</h1>
              <p class="text-sm text-gray-600">Sistema de Salud Ocupacional</p>
            </div>
          </div>
          <button onclick="window.location.href='/dashboard'" class="text-gray-600 hover:text-gray-900 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Contenido principal -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Entrada de código moderna -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <div class="text-center mb-8">
          <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Verificar Certificado</h2>
          <p class="text-gray-600">Ingresa el código del certificado para verificar su autenticidad</p>
        </div>
        
        <form id="verifyForm" class="space-y-6">
          <div>
            <label for="certificateCode" class="block text-sm font-medium text-gray-700 mb-2">Código del certificado</label>
            <input 
              type="text" 
              id="certificateCode" 
              placeholder="Ej: ABC123XYZ789"
              class="w-full px-4 py-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-lg text-center"
              required
            />
          </div>
          <button 
            type="submit" 
            class="w-full bg-blue-600 text-white py-4 px-6 rounded-lg font-semibold text-lg shadow-lg hover:bg-blue-700 active:bg-blue-800 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Verificar Certificado
          </button>
        </form>
      </div>

      <!-- Área de resultados modernizada -->
      <div id="result" class="hidden">
        <!-- Banner de estado moderno -->
        <div id="statusBanner" class="rounded-xl border p-6 mb-6 shadow-lg">
          <div class="flex items-center gap-4">
            <span id="statusIcon" class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-xl">?</span>
            <div class="flex-1">
              <p id="statusTitle" class="font-bold text-xl mb-1"></p>
              <p id="statusSubtitle" class="text-sm"></p>
            </div>
          </div>
        </div>

        <!-- Tarjeta del certificado modernizada -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <!-- Header de la tarjeta -->
          <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-6">
            <h3 class="text-white text-xl font-bold">Certificado de Aptitud Laboral</h3>
            <p class="text-blue-100 text-sm mt-1">Documento oficial verificado</p>
          </div>

          <!-- Contenido del certificado -->
          <div class="p-8 space-y-8">
            <!-- Información del paciente -->
            <div>
              <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                Paciente
              </h4>
              <div id="patientInfo" class="space-y-3"></div>
            </div>

            <!-- Estado y vigencia -->
            <div>
              <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Estado y Vigencia
              </h4>
              <div id="statusInfo" class="space-y-3"></div>
            </div>

            <!-- Restricciones y recomendaciones -->
            <div id="restrictionsSection" class="hidden">
              <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
                Observaciones
              </h4>
              <div id="restrictionsInfo" class="space-y-3"></div>
            </div>
          </div>

          <!-- Acciones modernizadas -->
          <div class="px-8 py-6 bg-gray-50 border-t space-y-4">
            <button 
              id="downloadBtn" 
              class="w-full bg-blue-600 text-white py-4 px-6 rounded-lg font-semibold text-lg flex items-center justify-center gap-3 hover:bg-blue-700 transition-colors shadow-lg"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Descargar PDF
            </button>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              <button 
                id="shareBtn" 
                class="bg-gray-100 text-gray-700 py-3 px-4 rounded-lg font-medium flex items-center justify-center gap-2 hover:bg-gray-200 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
                </svg>
                Compartir
              </button>
              
              <button 
                id="printBtn" 
                class="bg-gray-100 text-gray-700 py-3 px-4 rounded-lg font-medium flex items-center justify-center gap-2 hover:bg-gray-200 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                </svg>
                Imprimir
              </button>
              
              <button 
                id="newVerifyBtn" 
                class="bg-gray-100 text-gray-700 py-3 px-4 rounded-lg font-medium flex items-center justify-center gap-2 hover:bg-gray-200 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Nuevo
              </button>
            </div>
          </div>
        </div>

        <!-- Nota informativa -->
        <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-sm text-blue-800">
              Este certificado ha sido verificado digitalmente. Para consultas adicionales, contacte a la institución emisora.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" is:inline></script>
  <script is:inline>
    // Detectar dispositivos móviles y redirigir
    function isMobileDevice() {
      return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) ||
             window.innerWidth <= 768;
    }

    // Redirigir a la versión móvil si es necesario
    if (isMobileDevice()) {
      const currentParams = window.location.search;
      window.location.href = `/certificates/mobile${currentParams}`;
    }

    // Inicialización
    document.addEventListener('DOMContentLoaded', function() {
      setupEventListeners();
      checkUrlParams();
    });

    function setupEventListeners() {
      // Formulario
      document.getElementById('verifyForm').addEventListener('submit', handleVerifySubmit);
      
      // Botones de resultado
      document.getElementById('shareBtn').addEventListener('click', shareResult);
      document.getElementById('printBtn').addEventListener('click', () => window.print());
      document.getElementById('newVerifyBtn').addEventListener('click', resetVerify);
    }

    function checkUrlParams() {
      const params = new URLSearchParams(window.location.search);
      const code = params.get('code');
      if (code && code.trim() !== '') {
        document.getElementById('certificateCode').value = code;
        verifyCertificate(code);
      }
    }

    async function handleVerifySubmit(e) {
      e.preventDefault();
      const code = document.getElementById('certificateCode').value.trim();
      if (code) {
        await verifyCertificate(code);
      }
    }

    async function verifyCertificate(code) {
      showLoading(true);
      
      try {
        const response = await fetch(`/api/certificates/verify?code=${encodeURIComponent(code)}`);
        const data = await response.json();
        
        showLoading(false);
        
        if (data.success && data.data) {
          displayCertificate(data.data, code);
        } else {
          showError(data.message || 'Certificado no encontrado');
        }
      } catch (error) {
        showLoading(false);
        showError('Error al verificar el certificado. Verifica tu conexión.');
      }
    }

    function displayCertificate(cert, code) {
      // Mostrar resultado
      document.getElementById('result').classList.remove('hidden');
      
      // Configurar banner de estado
      const statusBanner = document.getElementById('statusBanner');
      const statusIcon = document.getElementById('statusIcon');
      const statusTitle = document.getElementById('statusTitle');
      const statusSubtitle = document.getElementById('statusSubtitle');
      
      statusBanner.className = 'rounded-xl border p-6 mb-6 shadow-lg bg-green-50 border-green-200';
      statusIcon.className = 'flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-xl bg-green-600';
      statusIcon.textContent = '✓';
      statusTitle.textContent = 'Certificado Válido';
      statusTitle.className = 'font-bold text-xl mb-1 text-green-800';
      statusSubtitle.textContent = 'La verificación fue exitosa';
      statusSubtitle.className = 'text-sm text-green-700';

      // Mostrar información del paciente
      const patientInfo = document.getElementById('patientInfo');
      patientInfo.innerHTML = `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Nombre:</span>
          <span class="text-gray-900">${cert.patient_name || 'N/A'}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Documento:</span>
          <span class="text-gray-900">${cert.document_type || ''} ${cert.document_number || ''}</span>
        </div>
        ${cert.date_of_birth ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Fecha de nacimiento:</span>
          <span class="text-gray-900">${new Date(cert.date_of_birth).toLocaleDateString('es-ES')}</span>
        </div>` : ''}
        ${cert.company ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Empresa:</span>
          <span class="text-gray-900">${cert.company}</span>
        </div>` : ''}
        ${cert.occupation ? `
        <div class="flex justify-between py-2">
          <span class="font-medium text-gray-700">Ocupación:</span>
          <span class="text-gray-900">${cert.occupation}</span>
        </div>` : ''}
      `;

      // Mostrar estado y vigencia
      const statusMap = {
        'apto': { text: 'APTO PARA EL TRABAJO', color: 'text-green-700 bg-green-100' },
        'apto_con_restricciones': { text: 'APTO CON RESTRICCIONES', color: 'text-yellow-700 bg-yellow-100' },
        'apto_manipulacion_alimentos': { text: 'APTO PARA MANIPULACIÓN DE ALIMENTOS', color: 'text-blue-700 bg-blue-100' },
        'apto_trabajo_alturas': { text: 'APTO PARA TRABAJO EN ALTURAS', color: 'text-purple-700 bg-purple-100' },
        'apto_espacios_confinados': { text: 'APTO PARA ESPACIOS CONFINADOS', color: 'text-indigo-700 bg-indigo-100' },
        'apto_conduccion': { text: 'APTO PARA CONDUCCIÓN', color: 'text-teal-700 bg-teal-100' }
      };
      
      const status = statusMap[cert.aptitude_status] || { text: cert.aptitude_status, color: 'text-gray-700 bg-gray-100' };
      
      const statusInfo = document.getElementById('statusInfo');
      const createdDate = cert.created_at ? new Date(cert.created_at).toLocaleDateString('es-ES') : 'N/A';
      const validityStart = cert.validity_start ? new Date(cert.validity_start).toLocaleDateString('es-ES') : null;
      const validityEnd = cert.validity_end ? new Date(cert.validity_end).toLocaleDateString('es-ES') : null;

      // Mapeo de tipos de cita
      const appointmentTypeMap = {
        'examen_periodico': 'Examen Médico Periódico',
        'examen_ingreso': 'Examen de Ingreso',
        'examen_egreso': 'Examen de Egreso',
        'examen_reintegro': 'Examen de Reintegro',
        'consulta_general': 'Consulta General',
        'consulta_especializada': 'Consulta Especializada',
        'seguimiento': 'Seguimiento',
        'urgencias': 'Urgencias'
      };
      const appointmentTypeText = cert.appointment_type ? (appointmentTypeMap[cert.appointment_type] || cert.appointment_type) : null;

      statusInfo.innerHTML = `
        <div class="mb-4">
          <span class="inline-block px-4 py-2 rounded-full text-sm font-semibold ${status.color}">${status.text}</span>
        </div>
        ${appointmentTypeText ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Tipo de Cita:</span>
          <span class="text-gray-900 font-semibold">${appointmentTypeText}</span>
        </div>` : ''}
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Fecha de emisión:</span>
          <span class="text-gray-900">${createdDate}</span>
        </div>
        ${validityStart ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Vigencia desde:</span>
          <span class="text-gray-900">${validityStart}</span>
        </div>` : ''}
        ${validityEnd ? `
        <div class="flex justify-between py-2">
          <span class="font-medium text-gray-700">Vigencia hasta:</span>
          <span class="text-gray-900">${validityEnd}</span>
        </div>` : ''}
      `;

      // Mostrar restricciones si existen
      const restrictionsSection = document.getElementById('restrictionsSection');
      const restrictionsInfo = document.getElementById('restrictionsInfo');
      
      if (cert.restrictions || cert.recommendations) {
        restrictionsSection.classList.remove('hidden');
        restrictionsInfo.innerHTML = `
          ${cert.restrictions ? `
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-yellow-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-yellow-800 mb-1">Restricciones:</h5>
                <p class="text-yellow-700">${cert.restrictions}</p>
              </div>
            </div>
          </div>` : ''}
          ${cert.recommendations ? `
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-blue-800 mb-1">Recomendaciones:</h5>
                <p class="text-blue-700">${cert.recommendations}</p>
              </div>
            </div>
          </div>` : ''}
        `;
      } else {
        restrictionsSection.classList.add('hidden');
      }

      // Configurar botón de descarga
      const downloadBtn = document.getElementById('downloadBtn');
      downloadBtn.onclick = async () => {
        try {
          showLoading(true);
          const response = await fetch(`/api/certificates/download?code=${encodeURIComponent(code)}`);
          
          if (!response.ok) {
            throw new Error('Error al descargar el certificado');
          }

          const blob = await response.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `certificado_${code}.pdf`;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          document.body.removeChild(a);
          
          showLoading(false);
          
          Swal.fire({
            icon: 'success',
            title: 'Descarga exitosa',
            text: 'El certificado se ha descargado correctamente',
            timer: 2000,
            showConfirmButton: false
          });
        } catch (error) {
          showLoading(false);
          Swal.fire({
            icon: 'error',
            title: 'Error de descarga',
            text: 'No se pudo descargar el certificado. Intenta nuevamente.',
            confirmButtonText: 'Entendido'
          });
        }
      };

      // Scroll a resultados
      setTimeout(() => {
        document.getElementById('result').scrollIntoView({ 
          behavior: 'smooth', 
          block: 'start' 
        });
      }, 100);

      // Mostrar mensaje de éxito
      Swal.fire({
        icon: 'success',
        title: 'Certificado verificado',
        text: 'El certificado es válido y auténtico',
        timer: 2000,
        showConfirmButton: false
      });
    }

    function showError(message) {
      document.getElementById('result').classList.add('hidden');
      
      Swal.fire({
        icon: 'error',
        title: 'Verificación fallida',
        text: message,
        confirmButtonText: 'Entendido'
      });
    }

    function showLoading(show) {
      const button = document.querySelector('#verifyForm button[type="submit"]');
      const downloadBtn = document.getElementById('downloadBtn');
      
      if (show) {
        if (button) {
          button.disabled = true;
          button.innerHTML = `
            <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Verificando...
          `;
        }
      } else {
        if (button) {
          button.disabled = false;
          button.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Verificar Certificado
          `;
        }
      }
    }

    async function shareResult() {
      const code = document.getElementById('certificateCode').value.trim();
      const url = `${window.location.origin}/certificates/verify?code=${encodeURIComponent(code)}`;
      
      if (navigator.share) {
        try {
          await navigator.share({
            title: 'Certificado de Aptitud Laboral',
            text: 'Verificación de certificado médico ocupacional',
            url: url
          });
        } catch (error) {
          if (error.name !== 'AbortError') {
            copyToClipboard(url);
          }
        }
      } else {
        copyToClipboard(url);
      }
    }

    async function copyToClipboard(text) {
      try {
        await navigator.clipboard.writeText(text);
        Swal.fire({
          icon: 'success',
          title: 'Enlace copiado',
          text: 'El enlace se ha copiado al portapapeles',
          timer: 2000,
          showConfirmButton: false
        });
      } catch (error) {
        Swal.fire({
          icon: 'info',
          title: 'Enlace disponible',
          text: text,
          confirmButtonText: 'Cerrar'
        });
      }
    }

    function resetVerify() {
      document.getElementById('result').classList.add('hidden');
      document.getElementById('certificateCode').value = '';
      document.getElementById('certificateCode').focus();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  </script>
</Layout>