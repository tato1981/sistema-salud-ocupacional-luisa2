---
import Layout from '../../layouts/Layout.astro';

// Obtener el token de la URL
const url = new URL(Astro.request.url);
const token = url.searchParams.get('token');

if (!token) {
  return Astro.redirect('/auth/forgot-password');
}
---

<Layout title="Nueva Contraseña - Sistema de Salud Ocupacional">
  <div class="min-h-screen flex">
    <!-- Sección Izquierda - Visual/Branding (Oculto en móviles) -->
    <div class="hidden lg:flex lg:w-1/2 relative bg-emerald-800 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-tr from-emerald-800 to-green-600 opacity-90 z-10"></div>
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1579684385136-1415dbd45960?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80')] bg-cover bg-center"></div>
      
      <div class="relative z-20 flex flex-col justify-center px-12 text-white">
        <div class="mb-8">
          <div class="h-16 w-16 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">🔐</span>
          </div>
          <h1 class="text-5xl font-bold mb-6 leading-tight">Establecer Nueva <br/>Contraseña</h1>
          <p class="text-xl text-emerald-100 max-w-md leading-relaxed">
            Asegura tu cuenta con una contraseña fuerte. La seguridad de la información médica es nuestra prioridad.
          </p>
        </div>
      </div>
    </div>

    <!-- Sección Derecha - Formulario -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-gray-50">
      <div class="w-full max-w-md space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center">
          <div class="mx-auto h-12 w-12 bg-green-100 rounded-full flex items-center justify-center mb-4">
            <span class="text-2xl">✨</span>
          </div>
          <h2 class="text-3xl font-bold text-gray-900 tracking-tight">
            Crea tu nueva contraseña
          </h2>
          <p class="mt-2 text-sm text-gray-600">
            Ingresa y confirma tu nueva contraseña segura
          </p>
        </div>

        <!-- Estado de verificación del token -->
        <div id="tokenVerification" class="mb-6">
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-center flex items-center justify-center space-x-2">
            <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-blue-600 font-medium">Verificando enlace...</span>
          </div>
        </div>

        <!-- Formulario de nueva contraseña (inicialmente oculto) -->
        <form id="resetPasswordForm" class="space-y-6 hidden animate-fade-in">
          <input type="hidden" id="token" value={token} />
          
          <div>
            <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-2">
              Nueva Contraseña
            </label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-gray-500 text-lg">🔒</span>
              </div>
              <input
                id="newPassword"
                name="newPassword"
                type="password"
                required
                minlength="6"
                class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 sm:text-sm transition duration-150 ease-in-out"
                placeholder="Mínimo 6 caracteres"
              />
            </div>
            <div class="mt-2 text-xs text-gray-500 flex items-center">
              <span class="mr-1">ℹ️</span>
              <span id="passwordHelp">La contraseña debe tener al menos 6 caracteres</span>
            </div>
          </div>

          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-2">
              Confirmar Contraseña
            </label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-gray-500 text-lg">🔐</span>
              </div>
              <input
                id="confirmPassword"
                name="confirmPassword"
                type="password"
                required
                minlength="6"
                class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 sm:text-sm transition duration-150 ease-in-out"
                placeholder="Repite la contraseña"
              />
            </div>
            <div class="mt-2 text-xs h-4" id="passwordMatch">
              <!-- Mensaje de coincidencia se mostrará aquí -->
            </div>
          </div>

          <button
            type="submit"
            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200 transform hover:scale-[1.02]"
            id="submitBtn"
          >
            <span id="submitText">Actualizar Contraseña</span>
            <span id="loadingText" class="hidden flex items-center">
              <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Actualizando...
            </span>
          </button>
        </form>

        <!-- Área de mensajes -->
        <div id="messageArea" class="mt-4 hidden animate-fade-in">
          <!-- Los mensajes se insertarán aquí dinámicamente -->
        </div>

        <div class="mt-6 text-center">
          <a
            href="/auth/login"
            class="font-medium text-blue-600 hover:text-blue-500 transition-colors flex items-center justify-center"
          >
            <span class="mr-2">←</span> Volver al inicio de sesión
          </a>
        </div>

        <div class="mt-8 bg-green-50 rounded-lg p-4 border border-green-100">
          <h3 class="font-semibold text-green-800 mb-2 text-sm flex items-center">
            <span class="mr-2">🛡️</span> Consejos de seguridad
          </h3>
          <ul class="text-xs text-green-700 space-y-1 ml-6 list-disc">
            <li>Usa una combinación de letras mayúsculas y minúsculas.</li>
            <li>Incluye números y caracteres especiales (@, #, $).</li>
            <li>Evita usar información personal como fechas de nacimiento.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', async function() {
    const form = document.getElementById('resetPasswordForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText') as HTMLSpanElement;
    const loadingText = document.getElementById('loadingText') as HTMLSpanElement;
    const messageArea = document.getElementById('messageArea') as HTMLDivElement;
    const tokenVerification = document.getElementById('tokenVerification') as HTMLDivElement;
    const tokenInput = document.getElementById('token') as HTMLInputElement;
    const token = tokenInput.value;

    const newPasswordInput = document.getElementById('newPassword') as HTMLInputElement;
    const confirmPasswordInput = document.getElementById('confirmPassword') as HTMLInputElement;
    const passwordMatchMsg = document.getElementById('passwordMatch') as HTMLDivElement;

    // Verificar token al cargar
    try {
      const response = await fetch(`/api/auth/verify-reset-token?token=${token}`);
      const data = await response.json();

      if (data.success) {
        tokenVerification.innerHTML = `
          <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-center flex items-center justify-center space-x-2 animate-fade-in">
            <span class="text-green-500">✅</span>
            <span class="text-green-700 font-medium text-sm">Enlace verificado correctamente</span>
          </div>
        `;
        // Ocultar mensaje de verificación después de un momento y mostrar formulario
        setTimeout(() => {
          tokenVerification.style.display = 'none';
          form.classList.remove('hidden');
        }, 1000);
      } else {
        tokenVerification.innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center">
            <span class="text-red-500 text-xl block mb-2">❌</span>
            <p class="text-red-800 font-medium">Enlace inválido o expirado</p>
            <p class="text-red-600 text-sm mt-1">Por favor solicita uno nuevo.</p>
            <a href="/auth/forgot-password" class="inline-block mt-3 px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 text-sm transition-colors">Solicitar nuevo enlace</a>
          </div>
        `;
      }
    } catch (error) {
      // Silently fail
      tokenVerification.innerHTML = `
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center">
           <p class="text-red-800">Error de conexión al verificar el enlace.</p>
        </div>
      `;
    }

    // Validación de coincidencia de contraseñas
    function checkPasswords() {
      if (confirmPasswordInput.value === '') {
        passwordMatchMsg.innerHTML = '';
        return;
      }
      
      if (newPasswordInput.value === confirmPasswordInput.value) {
        passwordMatchMsg.innerHTML = '<span class="text-green-600 flex items-center"><span class="mr-1">✓</span> Las contraseñas coinciden</span>';
      } else {
        passwordMatchMsg.innerHTML = '<span class="text-red-600 flex items-center"><span class="mr-1">✕</span> Las contraseñas no coinciden</span>';
      }
    }

    newPasswordInput.addEventListener('input', checkPasswords);
    confirmPasswordInput.addEventListener('input', checkPasswords);

    // Función para mostrar mensajes
    function showMessage(message: string, type: 'success' | 'error' | 'info' = 'info') {
      const bgColor = type === 'success' ? 'bg-green-50 border-green-200 text-green-800' :
                      type === 'error' ? 'bg-red-50 border-red-200 text-red-800' :
                      'bg-blue-50 border-blue-200 text-blue-800';
      
      const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️';

      messageArea.innerHTML = `
        <div class="border rounded-lg p-4 ${bgColor} flex items-start">
          <span class="mr-3 mt-0.5">${icon}</span>
          <p class="text-sm font-medium">${message}</p>
        </div>
      `;
      messageArea.classList.remove('hidden');
    }

    // Manejo del envío del formulario
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (newPasswordInput.value !== confirmPasswordInput.value) {
        showMessage('Las contraseñas no coinciden', 'error');
        return;
      }

      // Simular carga
      submitBtn.disabled = true;
      submitText.classList.add('hidden');
      loadingText.classList.remove('hidden');
      loadingText.classList.add('flex');
      messageArea.classList.add('hidden');

      try {
        const response = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            token: tokenInput.value,
            newPassword: newPasswordInput.value
          }),
        });

        const data = await response.json();

        if (data.success) {
          showMessage('Contraseña actualizada exitosamente. Redirigiendo...', 'success');
          setTimeout(() => {
            window.location.href = '/auth/login?message=password-updated';
          }, 2000);
        } else {
          showMessage(data.message || 'Error al actualizar la contraseña', 'error');
          submitBtn.disabled = false;
          submitText.classList.remove('hidden');
          loadingText.classList.add('hidden');
          loadingText.classList.remove('flex');
        }
      } catch (error) {
        // Silently fail
        showMessage('Error de conexión. Inténtalo de nuevo.', 'error');
        submitBtn.disabled = false;
        submitText.classList.remove('hidden');
        loadingText.classList.add('hidden');
        loadingText.classList.remove('flex');
      }
    });
  });
</script>
