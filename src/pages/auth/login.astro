---
import Layout from '../../layouts/Layout.astro';
import LoginForm from '../../components/auth/LoginForm.astro';

// Verificar si hay un mensaje de éxito por URL
const url = new URL(Astro.request.url);
const message = url.searchParams.get('message');
---

<Layout title="Iniciar Sesión - Salud Ocupacional">
  <div class="min-h-screen flex">
    <!-- Sección Izquierda - Visual/Branding (Oculto en móviles) -->
    <div class="hidden lg:flex lg:w-1/2 relative bg-blue-600 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-indigo-800 opacity-90 z-10"></div>
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80')] bg-cover bg-center"></div>
      
      <div class="relative z-20 flex flex-col justify-center px-12 text-white">
        <div class="mb-8">
          <div class="h-16 w-16 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">🏥</span>
          </div>
          <h1 class="text-5xl font-bold mb-6 leading-tight">Salud <br/>Ocupacional</h1>
          <p class="text-xl text-blue-100 max-w-md leading-relaxed">
            Sistema integral para la gestión de salud empresarial. Eficiencia, seguridad y cumplimiento normativo en una sola plataforma.
          </p>
        </div>
        
        <div class="mt-12 grid grid-cols-2 gap-6 text-sm">
          <div class="flex items-center space-x-3">
            <div class="h-8 w-8 rounded-full bg-green-400/20 flex items-center justify-center">
              <span class="text-green-300">✓</span>
            </div>
            <span>Gestión de Pacientes</span>
          </div>
          <div class="flex items-center space-x-3">
            <div class="h-8 w-8 rounded-full bg-green-400/20 flex items-center justify-center">
              <span class="text-green-300">✓</span>
            </div>
            <span>Historias Clínicas</span>
          </div>
          <div class="flex items-center space-x-3">
            <div class="h-8 w-8 rounded-full bg-green-400/20 flex items-center justify-center">
              <span class="text-green-300">✓</span>
            </div>
            <span>Certificados</span>
          </div>
          <div class="flex items-center space-x-3">
            <div class="h-8 w-8 rounded-full bg-green-400/20 flex items-center justify-center">
              <span class="text-green-300">✓</span>
            </div>
            <span>Reportes Avanzados</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Sección Derecha - Formulario -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-gray-50">
      <div class="w-full max-w-md space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-gray-900 tracking-tight">
            Bienvenido de nuevo
          </h2>
          <p class="mt-2 text-sm text-gray-600">
            Ingresa tus credenciales para acceder al sistema
          </p>
        </div>

        <!-- Mostrar mensaje de éxito si viene de reset de contraseña -->
        {message === 'password-updated' && (
          <div class="bg-green-50 border border-green-200 rounded-lg p-4 flex items-center space-x-3 animate-fade-in">
            <span class="text-green-500 text-xl">✅</span>
            <p class="text-sm text-green-700 font-medium">Contraseña actualizada exitosamente. Ya puedes iniciar sesión.</p>
          </div>
        )}

        <div class="mt-8">
          <LoginForm />
        </div>

        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-4 bg-white text-gray-500">¿No tienes una cuenta?</span>
          </div>
        </div>

        <div class="text-center">
          <a href="/auth/register" class="inline-flex items-center justify-center w-full px-4 py-3 border-2 border-gray-200 rounded-lg text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all duration-200">
            Crear nueva cuenta
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
