---
import Layout from '../../layouts/Layout.astro';
import RegisterForm from '../../components/auth/RegisterForm.astro';
---

<Layout title="Registro - Salud Ocupacional">
  <div class="min-h-screen flex">
    <!-- Sección Izquierda - Visual/Branding (Oculto en móviles) -->
    <div class="hidden lg:flex lg:w-1/2 relative bg-blue-600 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-tr from-teal-500 to-blue-700 opacity-90 z-10"></div>
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1505751172876-fa1923c5c528?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80')] bg-cover bg-center"></div>
      
      <div class="relative z-20 flex flex-col justify-center px-12 text-white">
        <div class="mb-8">
          <div class="h-16 w-16 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">👨‍⚕️</span>
          </div>
          <h1 class="text-5xl font-bold mb-6 leading-tight">Únete a nuestra <br/>plataforma</h1>
          <p class="text-xl text-blue-100 max-w-md leading-relaxed">
            Forma parte de la red más eficiente de gestión de salud ocupacional. Registra tu organización y comienza hoy.
          </p>
        </div>
        
        <div class="space-y-4 text-sm text-blue-50 mt-8">
          <div class="flex items-center">
            <div class="mr-4 h-10 w-10 rounded-full bg-white/10 flex items-center justify-center font-bold">1</div>
            <p>Registro rápido y sencillo con código de invitación.</p>
          </div>
          <div class="flex items-center">
            <div class="mr-4 h-10 w-10 rounded-full bg-white/10 flex items-center justify-center font-bold">2</div>
            <p>Configuración inmediata de tu perfil profesional.</p>
          </div>
          <div class="flex items-center">
            <div class="mr-4 h-10 w-10 rounded-full bg-white/10 flex items-center justify-center font-bold">3</div>
            <p>Acceso seguro a todas las herramientas.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Sección Derecha - Formulario -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-gray-50">
      <div class="w-full max-w-md space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-gray-900 tracking-tight">
            Crear una cuenta
          </h2>
          <p class="mt-2 text-sm text-gray-600">
            Completa tus datos para registrarte
          </p>
        </div>

        <div class="mt-8">
          <RegisterForm />
        </div>

        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-4 bg-white text-gray-500">¿Ya tienes una cuenta?</span>
          </div>
        </div>

        <div class="text-center">
          <a href="/auth/login" class="inline-flex items-center justify-center w-full px-4 py-3 border-2 border-gray-200 rounded-lg text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all duration-200">
            Iniciar sesión
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
