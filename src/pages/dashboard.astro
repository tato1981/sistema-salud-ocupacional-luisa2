---
import DashboardLayout from '../components/layout/DashboardLayout.astro';
import { requireAuth } from '../lib/auth';
import { db } from '../lib/database';

const user = requireAuth(Astro.cookies);

// Si no hay usuario, redirigir al login
if (!user) {
  return Astro.redirect('/auth/login');
}

// Datos para el Dashboard de Empresa
let companyStats = {
  pendingRequests: 0,
  completedExams: 0,
  totalEmployees: 0
};

if (user.role === 'company' && user.company_id) {
  try {
    const [requests] = await db.execute(
      'SELECT status, count(*) as count FROM exam_requests WHERE company_id = ? GROUP BY status',
      [user.company_id]
    );
    
    const [employees] = await db.execute(
      'SELECT count(*) as count FROM patients WHERE company_id = ?',
      [user.company_id]
    );
    
    companyStats.totalEmployees = (employees as any)[0].count;
    
    (requests as any[]).forEach(r => {
      if (r.status === 'pending') companyStats.pendingRequests += r.count;
      if (r.status === 'completed') companyStats.completedExams += r.count;
    });
  } catch (error) {
    console.error('Error loading company stats:', error);
  }
}

const currentDate = new Date().toLocaleDateString('es-ES', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

const success = Astro.url.searchParams.get('success');
---

<DashboardLayout title="Dashboard - Salud Ocupacional" user={user}>
