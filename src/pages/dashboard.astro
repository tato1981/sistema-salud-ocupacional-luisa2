  <!-- PATIENT DASHBOARD (o default) -->
  {user.role !== 'admin' && user.role !== 'doctor' && user.role !== 'company' && user.role !== 'staff' && (
    <div class="bg-white rounded-xl shadow-sm p-8 text-center border border-gray-100">
      <div class="mx-auto w-24 h-24 bg-blue-50 rounded-full flex items-center justify-center mb-6">
        <svg class="w-12 h-12 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">¡Hola, {user.name}!</h2>
      <p class="text-gray-600 max-w-md mx-auto">Bienvenido al sistema. Utiliza el menú lateral para navegar por las opciones disponibles.</p>
    </div>
  )}

</DashboardLayout>

<script>
  // Script para cargar estadísticas si es admin
  const userRole = document.querySelector('meta[name="user-role"]')?.getAttribute('content'); // No tenemos meta tag, pero podemos inferirlo o pasarlo de otra forma si es necesario.
  // Sin embargo, como el script se ejecuta en el cliente, podemos verificar la existencia de los elementos
  
  const statsElements = {
    totalUsers: document.getElementById('dashTotalUsers'),
    activeCodes: document.getElementById('dashActiveCodes'),
    usedCodes: document.getElementById('dashUsedCodes'),
    expiringSoon: document.getElementById('dashExpiringSoon')
  };

  if (statsElements.totalUsers) {
    fetchStats();
  }

  async function fetchStats() {
    try {
      const response = await fetch('/api/admin/statistics');
      if (response.ok) {
        const result = await response.json();
        if (result.success && result.data) {
          const stats = result.data;
          if (statsElements.totalUsers) statsElements.totalUsers.textContent = stats.totalUsers || '0';
          if (statsElements.activeCodes) statsElements.activeCodes.textContent = stats.activeCodes || '0';
          if (statsElements.usedCodes) statsElements.usedCodes.textContent = stats.usedCodes || '0';
          if (statsElements.expiringSoon) statsElements.expiringSoon.textContent = stats.expiringSoon || '0';
        }
      }
    } catch (error) {
      console.error('Error fetching stats:', error);
    }
  }

  // Actualizar cada 30 segundos
  if (statsElements.totalUsers) {
    setInterval(fetchStats, 30000);
  }
