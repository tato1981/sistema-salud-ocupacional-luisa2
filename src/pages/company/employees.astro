---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { requireAuth } from '../../lib/auth';
import { db } from '../../lib/database';

const user = requireAuth(Astro.cookies);

if (!user || user.role !== 'company' || !user.company_id) {
  return Astro.redirect('/dashboard');
}

// Obtener empleados con su último examen y concepto médico
const [employees] = await db.execute(
  `SELECT p.*,
          p.occupation as position,
          mh.aptitude_status as last_exam_concept,
          mh.id as last_history_id
   FROM patients p
   LEFT JOIN (
       SELECT patient_id, aptitude_status, id
       FROM medical_histories
       WHERE id IN (
           SELECT MAX(id)
           FROM medical_histories
           GROUP BY patient_id
       )
   ) mh ON p.id = mh.patient_id
   WHERE p.company_id = ?
   ORDER BY p.name ASC`,
  [user.company_id]
);

const employeeList = employees as any[];

const conceptLabels: Record<string, string> = {
  'apto': 'Apto',
  'apto_con_restricciones': 'Apto con restricciones',
  'no_apto': 'No apto',
  'aplazado': 'Aplazado'
};

const conceptClasses: Record<string, string> = {
  'apto': 'bg-green-100 text-green-800',
  'apto_con_restricciones': 'bg-yellow-100 text-yellow-800',
  'no_apto': 'bg-red-100 text-red-800',
  'aplazado': 'bg-orange-100 text-orange-800'
};
---

<DashboardLayout title="Empleados - Salud Ocupacional" user={user}>
  <!-- CDN para jsPDF y jsPDF-autoTable -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script is:inline>
    // Polyfill para que jspdf-autotable encuentre jsPDF globalmente
    window.jsPDF = window.jspdf.jsPDF;
  </script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>

  <div class="mb-6 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Empleados</h1>
      <p class="text-gray-600">Listado de empleados registrados en el sistema.</p>
    </div>
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
      <button id="exportCsvBtn" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium shadow-sm border border-gray-200 transition-colors">
        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v10M16 7v10M4 7h16M4 17h16"/></svg>
        Exportar CSV
      </button>
      <button id="exportPdfBtn" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium shadow-sm border border-gray-200 transition-colors">
        <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Exportar PDF
      </button>
      <a href="/company/request-exam" class="inline-flex items-center justify-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Nuevo Examen
      </a>
    </div>
  </div>

  <!-- Filtro de búsqueda -->
  <div class="bg-white p-4 rounded-lg shadow mb-4">
    <div class="flex gap-4">
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Buscar por nombre o documento</label>
        <input
          type="text"
          id="searchInput"
          placeholder="Buscar empleado..."
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
        >
      </div>
      <div class="flex items-end">
        <button
          onclick="clearFilters()"
          class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium text-sm"
        >
          Limpiar Filtros
        </button>
      </div>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cargo</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Último Concepto</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody id="employeesTableBody" class="bg-white divide-y divide-gray-200">
          <!-- Los datos se cargarán dinámicamente -->
        </tbody>
      </table>
    </div>

    <!-- Paginación -->
    <div class="px-4 py-4 sm:px-6 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
      <span class="text-sm text-gray-700" id="resultsCount">Mostrando 0 resultados</span>
      <div class="flex space-x-2">
        <button id="prevBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Anterior</button>
        <button id="nextBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Siguiente</button>
      </div>
    </div>
  </div>

  <script define:vars={{ employeeList, conceptLabels, conceptClasses }}>
    let allEmployees = employeeList;
    let filteredEmployees = [...allEmployees];
    let currentPage = 1;
    const itemsPerPage = 10;

    // Renderizar tabla con paginación
    function renderTable() {
      const tbody = document.getElementById('employeesTableBody');
      const resultsCount = document.getElementById('resultsCount');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');

      if (!tbody) return;

      if (filteredEmployees.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <p class="mt-2 text-sm font-medium">No se encontraron empleados.</p>
            </td>
          </tr>
        `;
        if (resultsCount) resultsCount.textContent = 'Mostrando 0 resultados';
        if (prevBtn) prevBtn.disabled = true;
        if (nextBtn) nextBtn.disabled = true;
        return;
      }

      // Paginación
      const totalPages = Math.ceil(filteredEmployees.length / itemsPerPage);
      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const paginatedEmployees = filteredEmployees.slice(start, end);

      if (resultsCount) {
        resultsCount.textContent = `Mostrando ${start + 1} - ${Math.min(end, filteredEmployees.length)} de ${filteredEmployees.length} resultados`;
      }

      if (prevBtn) {
        prevBtn.disabled = currentPage === 1;
        const newPrevBtn = prevBtn.cloneNode(true);
        prevBtn.parentNode.replaceChild(newPrevBtn, prevBtn);
        newPrevBtn.addEventListener('click', () => {
          if (currentPage > 1) {
            currentPage--;
            renderTable();
          }
        });
      }

      if (nextBtn) {
        nextBtn.disabled = currentPage >= totalPages;
        const newNextBtn = nextBtn.cloneNode(true);
        nextBtn.parentNode.replaceChild(newNextBtn, nextBtn);
        newNextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) {
            currentPage++;
            renderTable();
          }
        });
      }

      // Renderizar filas
      tbody.innerHTML = paginatedEmployees.map((employee) => {
        const initial = employee.name.charAt(0).toUpperCase();
        const conceptBadge = employee.last_exam_concept
          ? `<span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${conceptClasses[employee.last_exam_concept] || 'bg-gray-100 text-gray-800'}">
              ${conceptLabels[employee.last_exam_concept] || employee.last_exam_concept}
            </span>`
          : employee.last_history_id
            ? `<span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Sin concepto</span>`
            : `<span class="text-xs text-gray-500 italic">Sin exámenes</span>`;

        const downloadButton = employee.last_history_id
          ? `<a href="/api/employees/pdf/${employee.last_history_id}" target="_blank" class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 px-3 py-1 rounded-md transition-colors inline-flex items-center">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Descargar Concepto
            </a>`
          : '';

        return `
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div class="h-10 w-10 flex-shrink-0">
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gray-500">
                    <span class="text-sm font-medium leading-none text-white">${initial}</span>
                  </span>
                </div>
                <div class="ml-4">
                  <div class="text-sm font-medium text-gray-900">${employee.name}</div>
                  <div class="text-sm text-gray-500">${employee.email || '-'}</div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900">${employee.document_number}</div>
              <div class="text-sm text-gray-500">${employee.document_type}</div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900">${employee.position || '-'}</div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              ${conceptBadge}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              ${downloadButton}
            </td>
          </tr>
        `;
      }).join('');
    }

    // Filtrar empleados
    function filterEmployees() {
      const searchValue = (document.getElementById('searchInput')).value.toLowerCase();

      filteredEmployees = allEmployees.filter(emp => {
        const matchesSearch = !searchValue ||
          emp.name.toLowerCase().includes(searchValue) ||
          emp.document_number.toLowerCase().includes(searchValue);

        return matchesSearch;
      });

      currentPage = 1;
      renderTable();
    }

    // Limpiar filtros
    window.clearFilters = function() {
      document.getElementById('searchInput').value = '';
      filterEmployees();
    };

    // Event listeners
    document.getElementById('searchInput')?.addEventListener('input', filterEmployees);

    // Exportar CSV
    document.getElementById('exportCsvBtn')?.addEventListener('click', () => {
      let csv = 'Nombre,Email,Documento,Tipo Documento,Cargo,Último Concepto\n';

      filteredEmployees.forEach(emp => {
        const nombre = (emp.name || '').replace(/,/g, '');
        const email = (emp.email || '-').replace(/,/g, '');
        const documento = (emp.document_number || '').replace(/,/g, '');
        const tipoDoc = (emp.document_type || '').replace(/,/g, '');
        const cargo = (emp.position || '-').replace(/,/g, '');
        const concepto = emp.last_exam_concept
          ? (conceptLabels[emp.last_exam_concept] || emp.last_exam_concept)
          : emp.last_history_id
            ? 'Sin concepto'
            : 'Sin exámenes';

        csv += `${nombre},${email},${documento},${tipoDoc},${cargo},${concepto}\n`;
      });

      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'empleados.csv';
      a.click();
      window.URL.revokeObjectURL(url);
    });

    // Exportar PDF
    document.getElementById('exportPdfBtn')?.addEventListener('click', () => {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF('l', 'mm', 'a4');

      const pageWidth = doc.internal.pageSize.getWidth();

      // Título
      doc.setFontSize(18);
      const title = 'Listado de Empleados';
      const titleWidth = doc.getTextWidth(title);
      doc.text(title, (pageWidth - titleWidth) / 2, 22);

      // Fecha de generación
      doc.setFontSize(11);
      doc.setTextColor(100);
      const dateStr = `Generado el: ${new Date().toLocaleDateString('es-ES')} ${new Date().toLocaleTimeString('es-ES')}`;
      const dateWidth = doc.getTextWidth(dateStr);
      doc.text(dateStr, (pageWidth - dateWidth) / 2, 30);

      // Preparar datos para la tabla
      const tableData = filteredEmployees.map(emp => {
        const concepto = emp.last_exam_concept
          ? (conceptLabels[emp.last_exam_concept] || emp.last_exam_concept)
          : emp.last_history_id
            ? 'Sin concepto'
            : 'Sin exámenes';

        return [
          emp.name,
          emp.email || '-',
          emp.document_number,
          emp.document_type,
          emp.position || '-',
          concepto
        ];
      });

      // Generar tabla con autoTable
      doc.autoTable({
        head: [['Nombre', 'Email', 'Documento', 'Tipo Doc', 'Cargo', 'Último Concepto']],
        body: tableData,
        startY: 40,
        styles: { fontSize: 9, cellPadding: 3 },
        headStyles: { fillColor: [59, 130, 246], textColor: 255, fontStyle: 'bold' },
        alternateRowStyles: { fillColor: [245, 247, 250] },
        margin: { top: 40, right: 10, bottom: 10, left: 10 }
      });

      // Pie de página
      const pageCount = doc.internal.pages.length - 1;
      for (let i = 1; i <= pageCount; i++) {
        doc.setPage(i);
        doc.setFontSize(8);
        doc.setTextColor(150);
        doc.text(`Página ${i} de ${pageCount}`, pageWidth / 2, doc.internal.pageSize.getHeight() - 10, { align: 'center' });
      }

      doc.save('empleados.pdf');
    });

    // Renderizar inicialmente
    renderTable();
  </script>
</DashboardLayout>
