---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { requireAuth } from '../../lib/auth';
import { db } from '../../lib/database';

const user = requireAuth(Astro.cookies);

if (!user || user.role !== 'company' || !user.company_id) {
  return Astro.redirect('/dashboard');
}

// Obtener solicitudes
const [requests] = await db.execute(
  `SELECT * FROM exam_requests
   WHERE company_id = ?
   ORDER BY created_at DESC`,
  [user.company_id]
);

const requestList = requests as any[];

const statusLabels: Record<string, string> = {
  pending: 'Pendiente',
  scheduled: 'Agendada',
  completed: 'Completada',
  cancelled: 'Cancelada',
  rejected: 'Rechazada'
};

const statusClasses: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-800',
  scheduled: 'bg-blue-100 text-blue-800',
  completed: 'bg-green-100 text-green-800',
  cancelled: 'bg-red-100 text-red-800',
  rejected: 'bg-gray-100 text-gray-800'
};

const examTypeLabels: Record<string, string> = {
  ingreso: 'Ingreso',
  periodico: 'Periódico',
  retiro: 'Retiro',
  post_incapacidad: 'Post-Incapacidad',
  reubicacion: 'Reubicación'
};
---

<DashboardLayout title="Solicitudes - Salud Ocupacional" user={user}>
  <!-- CDN para jsPDF y jsPDF-autoTable -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script is:inline>
    // Polyfill para que jspdf-autotable encuentre jsPDF globalmente
    window.jsPDF = window.jspdf.jsPDF;
  </script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Solicitudes de Examen</h1>
      <p class="text-gray-600">Historial de solicitudes de exámenes médicos.</p>
    </div>
    <div class="flex items-center space-x-3">
      <button id="exportCsvBtn" class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium shadow-sm border border-gray-200 transition-colors">
        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v10M16 7v10M4 7h16M4 17h16"/></svg>
        Exportar CSV
      </button>
      <button id="exportPdfBtn" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Exportar PDF
      </button>
    </div>
  </div>

  <!-- Filtro de búsqueda -->
  <div class="bg-white p-4 rounded-lg shadow mb-4">
    <div class="flex gap-4">
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Buscar por nombre o documento</label>
        <input
          type="text"
          id="searchInput"
          placeholder="Buscar empleado..."
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
        >
      </div>
      <div class="flex items-end">
        <button
          onclick="clearFilters()"
          class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium text-sm"
        >
          Limpiar Filtros
        </button>
      </div>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Empleado</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo Examen</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cargo</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
          </tr>
        </thead>
        <tbody id="requestsTableBody" class="bg-white divide-y divide-gray-200">
          <!-- Los datos se cargarán dinámicamente -->
        </tbody>
      </table>
    </div>

    <!-- Paginación -->
    <div class="px-4 py-4 sm:px-6 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
      <span class="text-sm text-gray-700" id="resultsCount">Mostrando 0 resultados</span>
      <div class="flex space-x-2">
        <button id="prevBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Anterior</button>
        <button id="nextBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Siguiente</button>
      </div>
    </div>
  </div>

  <script define:vars={{ requestList, statusLabels, statusClasses, examTypeLabels }}>
    let allRequests = requestList;
    let filteredRequests = [...allRequests];
    let currentPage = 1;
    const itemsPerPage = 10;

    // Renderizar tabla con paginación
    function renderTable() {
      const tbody = document.getElementById('requestsTableBody');
      const resultsCount = document.getElementById('resultsCount');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');

      if (!tbody) return;

      if (filteredRequests.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p class="mt-2 text-sm font-medium">No se encontraron solicitudes.</p>
            </td>
          </tr>
        `;
        if (resultsCount) resultsCount.textContent = 'Mostrando 0 resultados';
        if (prevBtn) prevBtn.disabled = true;
        if (nextBtn) nextBtn.disabled = true;
        return;
      }

      // Paginación
      const totalPages = Math.ceil(filteredRequests.length / itemsPerPage);
      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const paginatedRequests = filteredRequests.slice(start, end);

      if (resultsCount) {
        resultsCount.textContent = `Mostrando ${start + 1} - ${Math.min(end, filteredRequests.length)} de ${filteredRequests.length} resultados`;
      }

      if (prevBtn) {
        prevBtn.disabled = currentPage === 1;
        const newPrevBtn = prevBtn.cloneNode(true);
        prevBtn.parentNode.replaceChild(newPrevBtn, prevBtn);
        newPrevBtn.addEventListener('click', () => {
          if (currentPage > 1) {
            currentPage--;
            renderTable();
          }
        });
      }

      if (nextBtn) {
        nextBtn.disabled = currentPage >= totalPages;
        const newNextBtn = nextBtn.cloneNode(true);
        nextBtn.parentNode.replaceChild(newNextBtn, nextBtn);
        newNextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) {
            currentPage++;
            renderTable();
          }
        });
      }

      // Renderizar filas
      tbody.innerHTML = paginatedRequests.map((req) => `
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            ${new Date(req.created_at).toLocaleDateString('es-ES')}
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-medium text-gray-900">${req.patient_name}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm text-gray-900">${req.patient_document}</div>
            <div class="text-xs text-gray-500">${req.patient_document_type}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
            ${examTypeLabels[req.exam_type] || req.exam_type}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            ${req.position}
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${statusClasses[req.status] || 'bg-gray-100 text-gray-800'}">
              ${statusLabels[req.status] || req.status}
            </span>
          </td>
        </tr>
      `).join('');
    }

    // Filtrar solicitudes
    function filterRequests() {
      const searchValue = (document.getElementById('searchInput')).value.toLowerCase();

      filteredRequests = allRequests.filter(req => {
        const matchesSearch = !searchValue ||
          req.patient_name.toLowerCase().includes(searchValue) ||
          req.patient_document.toLowerCase().includes(searchValue);

        return matchesSearch;
      });

      currentPage = 1;
      renderTable();
    }

    // Limpiar filtros
    window.clearFilters = function() {
      document.getElementById('searchInput').value = '';
      filterRequests();
    };

    // Event listeners
    document.getElementById('searchInput')?.addEventListener('input', filterRequests);

    // Exportar CSV
    document.getElementById('exportCsvBtn')?.addEventListener('click', () => {
      let csv = 'Fecha,Empleado,Documento,Tipo de Documento,Tipo Examen,Cargo,Estado\n';

      filteredRequests.forEach(req => {
        const fecha = new Date(req.created_at).toLocaleDateString('es-ES');
        const nombre = (req.patient_name || '').replace(/,/g, '');
        const documento = (req.patient_document || '').replace(/,/g, '');
        const tipoDoc = (req.patient_document_type || '').replace(/,/g, '');
        const tipoExamen = examTypeLabels[req.exam_type] || req.exam_type;
        const cargo = (req.position || '').replace(/,/g, '');
        const estado = statusLabels[req.status] || req.status;

        csv += `${fecha},${nombre},${documento},${tipoDoc},${tipoExamen},${cargo},${estado}\n`;
      });

      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'solicitudes_examenes.csv';
      a.click();
      window.URL.revokeObjectURL(url);
    });

    // Exportar PDF
    document.getElementById('exportPdfBtn')?.addEventListener('click', () => {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF('l', 'mm', 'a4');

      const pageWidth = doc.internal.pageSize.getWidth();

      // Título
      doc.setFontSize(18);
      const title = 'Solicitudes de Exámenes Médicos';
      const titleWidth = doc.getTextWidth(title);
      doc.text(title, (pageWidth - titleWidth) / 2, 22);

      // Fecha de generación
      doc.setFontSize(11);
      doc.setTextColor(100);
      const dateStr = `Generado el: ${new Date().toLocaleDateString('es-ES')} ${new Date().toLocaleTimeString('es-ES')}`;
      const dateWidth = doc.getTextWidth(dateStr);
      doc.text(dateStr, (pageWidth - dateWidth) / 2, 30);

      // Preparar datos para la tabla
      const tableData = filteredRequests.map(req => [
        new Date(req.created_at).toLocaleDateString('es-ES'),
        req.patient_name,
        req.patient_document,
        req.patient_document_type,
        examTypeLabels[req.exam_type] || req.exam_type,
        req.position,
        statusLabels[req.status] || req.status
      ]);

      // Generar tabla con autoTable
      doc.autoTable({
        head: [['Fecha', 'Empleado', 'Documento', 'Tipo Doc', 'Tipo Examen', 'Cargo', 'Estado']],
        body: tableData,
        startY: 40,
        styles: { fontSize: 9, cellPadding: 3 },
        headStyles: { fillColor: [59, 130, 246], textColor: 255, fontStyle: 'bold' },
        alternateRowStyles: { fillColor: [245, 247, 250] },
        margin: { top: 40, right: 10, bottom: 10, left: 10 }
      });

      // Pie de página
      const pageCount = doc.internal.pages.length - 1;
      for (let i = 1; i <= pageCount; i++) {
        doc.setPage(i);
        doc.setFontSize(8);
        doc.setTextColor(150);
        doc.text(`Página ${i} de ${pageCount}`, pageWidth / 2, doc.internal.pageSize.getHeight() - 10, { align: 'center' });
      }

      doc.save('solicitudes_examenes.pdf');
    });

    // Renderizar inicialmente
    renderTable();
  </script>
</DashboardLayout>
