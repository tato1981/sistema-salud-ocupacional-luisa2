---
const { user, currentPath } = Astro.props;

const adminMenu = [
    { label: 'Dashboard', href: '/dashboard', icon: 'home' },
    { label: 'Solicitudes', href: '/admin/requests', icon: 'clipboardCheck' },
    { label: 'Pacientes', href: '/admin/patients', icon: 'users' },
    { label: 'Empresas', href: '/admin/companies', icon: 'building' },
    { label: 'Doctores', href: '/admin/doctors', icon: 'doctor' },
    { 
      label: 'Citas', 
      href: '#', // Changed to trigger dropdown
      icon: 'calendar',
      subItems: [
        { label: 'Listado', href: '/admin/appointments' },
        { label: 'Monitoreo', href: '/admin/monitoring' },
        { label: 'Concepto Médico', href: '/admin/medical-concepts' },
      ]
    },
    { label: 'Reportes', href: '/admin/reports', icon: 'chart' },
    { label: 'Códigos', href: '/admin/invitation-codes', icon: 'ticket' },
    { label: 'Certificados', href: '/certificates/verify', icon: 'badge' },
  ];

const menuItems = {
  admin: adminMenu,
  doctor: [
    { label: 'Dashboard', href: '/dashboard', icon: 'home' },
    { label: 'Mis Citas', href: '/doctor/appointments', icon: 'calendar' },
    { label: 'Conceptos Médicos', href: '/doctor/medical-concepts', icon: 'clipboardCheck' },
    { label: 'Pacientes', href: '/doctor/patients', icon: 'users' },
  ],
  patient: [
    { label: 'Dashboard', href: '/dashboard', icon: 'home' },
    { label: 'Mis Consultas', href: '/patient/consultations', icon: 'clipboard' },
    { label: 'Mi Perfil', href: '/patient/profile', icon: 'user' },
  ],
  company: [
    { label: 'Dashboard', href: '/dashboard', icon: 'home' },
    { label: 'Solicitar Examen', href: '/company/request-exam', icon: 'clipboard' },
    { label: 'Solicitudes', href: '/company/requests', icon: 'clipboardCheck' },
    { label: 'Empleados', href: '/company/employees', icon: 'users' },
  ],
  staff: [
    { label: 'Dashboard', href: '/dashboard', icon: 'home' },
    { label: 'Solicitudes', href: '/admin/requests', icon: 'clipboardCheck' },
    { label: 'Pacientes', href: '/admin/patients', icon: 'users' },
    {
      label: 'Citas',
      href: '#',
      icon: 'calendar',
      subItems: [
        { label: 'Listado', href: '/admin/appointments' },
        { label: 'Monitoreo', href: '/admin/monitoring' },
      ]
    },
    { label: 'Certificados', href: '/certificates/verify', icon: 'badge' },
  ]
};

const items = menuItems[user?.role] || menuItems.staff;

const icons = {
  home: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>`,
  building: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>`,
  users: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>`,
  doctor: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>`, // Using user icon for now, could be specific
  calendar: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>`,
  chart: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>`,
  ticket: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path></svg>`,
  badge: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>`,
  clipboard: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>`,
  clipboardCheck: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>`,
  user: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>`,
  activity: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`,
  chevronDown: `<svg class="w-4 h-4 ml-auto transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>`,
};
---

<aside class:list={[
  "fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-gray-200 shadow-sm transform transition-transform duration-300 ease-in-out flex flex-col h-full",
  currentPath === '/dashboard' ? 'translate-x-0 lg:fixed' : '-translate-x-full'
]} id="sidebar">
  <!-- Header -->
  <div class="flex-shrink-0 flex items-center justify-center h-16 bg-blue-600 px-6">
    <a href="/dashboard" class="flex items-center space-x-2 text-white hover:text-blue-100 transition-colors group">
      <h1 class="text-xl font-bold tracking-wider">Salud Ocupacional</h1>
    </a>
  </div>
  
  <!-- Menu Items (Scrollable) -->
  <nav class="flex-1 overflow-y-auto mt-5 px-4 space-y-1 pb-4">
    {items.map((item, index) => {
      // Check if this item or any of its subItems is active
      const isSubItemActive = item.subItems?.some(sub => currentPath === sub.href || (sub.href !== '/dashboard' && currentPath.startsWith(sub.href)));
      const isActive = currentPath === item.href || (item.href !== '/dashboard' && currentPath.startsWith(item.href));
      const isExpanded = isSubItemActive; // Auto-expand if active

      return (
        <div>
          {item.subItems ? (
            // Dropdown Menu Item
            <div class="space-y-1">
              <button 
                type="button"
                class:list={[
                  "w-full group flex items-center px-2 py-3 text-base font-medium rounded-md transition-colors duration-200 focus:outline-none",
                  isSubItemActive || isActive 
                    ? "bg-blue-50 text-blue-700" 
                    : "text-gray-600 hover:bg-gray-50 hover:text-gray-900"
                ]}
                onclick={`document.getElementById('submenu-${index}').classList.toggle('hidden'); this.querySelector('svg:last-child').classList.toggle('rotate-180');`}
              >
                <div class:list={[
                  "mr-4 flex-shrink-0 h-6 w-6",
                  isSubItemActive || isActive ? "text-blue-600" : "text-gray-400 group-hover:text-gray-500"
                ]} set:html={icons[item.icon]} />
                <span class="flex-1 text-left">{item.label}</span>
                <div class:list={[
                  "w-4 h-4 ml-auto transform transition-transform duration-200",
                  isExpanded ? "rotate-180" : ""
                ]} set:html={icons.chevronDown} />
              </button>
              
              <div id={`submenu-${index}`} class:list={["space-y-1 pl-11", isExpanded ? "" : "hidden"]}>
                {item.subItems.map((subItem) => {
                   const isSubActive = currentPath === subItem.href || (subItem.href !== '/dashboard' && currentPath.startsWith(subItem.href));
                   return (
                    <a
                      href={subItem.href}
                      class:list={[
                        "group flex items-center px-2 py-2 text-sm font-medium rounded-md transition-colors duration-200",
                        isSubActive
                          ? "bg-blue-100 text-blue-800"
                          : "text-gray-600 hover:bg-gray-50 hover:text-gray-900"
                      ]}
                    >
                      {subItem.label}
                    </a>
                   );
                })}
              </div>
            </div>
          ) : (
            // Standard Menu Item
            <a 
              href={item.href}
              class:list={[
                "group flex items-center px-2 py-3 text-base font-medium rounded-md transition-colors duration-200",
                isActive 
                  ? "bg-blue-50 text-blue-700" 
                  : "text-gray-600 hover:bg-gray-50 hover:text-gray-900"
              ]}
            >
              <div class:list={[
                "mr-4 flex-shrink-0 h-6 w-6",
                isActive ? "text-blue-600" : "text-gray-400 group-hover:text-gray-500"
              ]} set:html={icons[item.icon]} />
              {item.label}
            </a>
          )}
        </div>
      );
    })}
  </nav>

  <!-- Logout Button (Fixed at bottom) -->
  <div class="flex-shrink-0 w-full border-t border-gray-200 p-4 bg-white z-10">
    <button id="logoutBtnSidebar" class="flex items-center w-full px-2 py-2 text-base font-medium text-red-600 rounded-md hover:bg-red-50 transition-colors duration-200">
      <svg class="mr-4 h-6 w-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      Cerrar Sesión
    </button>
  </div>
</aside>

<div class="fixed inset-0 z-40 bg-gray-600 bg-opacity-75 hidden lg:hidden transition-opacity" id="sidebarOverlay"></div>

<script>
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  const logoutBtn = document.getElementById('logoutBtnSidebar');

  // Close sidebar on overlay click
  overlay?.addEventListener('click', () => {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
  });

  // Logout logic
  logoutBtn?.addEventListener('click', async () => {
    try {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/auth/login';
    } catch (error) {
      // Silently fail
    }
  });
</script>
