---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`signature-pad-container ${className}`}>
  <div class="signature-controls mb-3">
    <label class="block text-sm font-medium text-gray-700 mb-2">
      ✍️ Firma del Paciente
    </label>
    <p class="text-xs text-gray-500 mb-3">
      Dibuje su firma en el recuadro usando el mouse o el dedo (en dispositivos táctiles)
    </p>
  </div>

  <div class="signature-canvas-wrapper border-2 border-gray-300 rounded-lg bg-white mb-3">
    <canvas
      id="signatureCanvas"
      class="signature-canvas"
      width="600"
      height="200"
    ></canvas>
  </div>

  <div class="signature-actions flex flex-wrap gap-2">
    <button
      type="button"
      id="clearSignature"
      class="btn-secondary flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 text-sm"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Limpiar
    </button>

    <button
      type="button"
      id="confirmSignature"
      class="btn-primary flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      Confirmar Firma
    </button>

    <div id="signatureStatus" class="flex items-center gap-2 text-sm">
      <span id="signatureStatusText" class="text-gray-500">Sin firma</span>
    </div>
  </div>

  <!-- Preview de firma confirmada -->
  <div id="signaturePreviewContainer" class="hidden mt-4 p-3 bg-gray-50 border border-gray-200 rounded-lg">
    <p class="text-xs text-gray-600 mb-2">Firma guardada:</p>
    <img id="signaturePreview" src="" alt="Firma" class="border border-gray-300 rounded bg-white" style="max-height: 100px;" />
  </div>
</div>

<script>
  interface SignaturePadState {
    canvas: HTMLCanvasElement | null;
    ctx: CanvasRenderingContext2D | null;
    isDrawing: boolean;
    lastX: number;
    lastY: number;
    signatureBlob: Blob | null;
    signaturePath: string | null;
  }

  const state: SignaturePadState = {
    canvas: null,
    ctx: null,
    isDrawing: false,
    lastX: 0,
    lastY: 0,
    signatureBlob: null,
    signaturePath: null
  };

  function initSignaturePad() {
    state.canvas = document.getElementById('signatureCanvas') as HTMLCanvasElement;
    if (!state.canvas) return;

    state.ctx = state.canvas.getContext('2d');
    if (!state.ctx) return;

    // Configurar contexto
    state.ctx.strokeStyle = '#000000';
    state.ctx.lineWidth = 2;
    state.ctx.lineCap = 'round';
    state.ctx.lineJoin = 'round';

    // Eventos de mouse
    state.canvas.addEventListener('mousedown', startDrawing);
    state.canvas.addEventListener('mousemove', draw);
    state.canvas.addEventListener('mouseup', stopDrawing);
    state.canvas.addEventListener('mouseout', stopDrawing);

    // Eventos táctiles
    state.canvas.addEventListener('touchstart', handleTouchStart);
    state.canvas.addEventListener('touchmove', handleTouchMove);
    state.canvas.addEventListener('touchend', stopDrawing);

    // Botones
    document.getElementById('clearSignature')?.addEventListener('click', clearSignature);
    document.getElementById('confirmSignature')?.addEventListener('click', confirmSignature);
  }

  function getCoordinates(e: MouseEvent | TouchEvent): { x: number; y: number } {
    if (!state.canvas) return { x: 0, y: 0 };

    const rect = state.canvas.getBoundingClientRect();
    const scaleX = state.canvas.width / rect.width;
    const scaleY = state.canvas.height / rect.height;

    if (e instanceof MouseEvent) {
      return {
        x: (e.clientX - rect.left) * scaleX,
        y: (e.clientY - rect.top) * scaleY
      };
    } else {
      const touch = e.touches[0];
      return {
        x: (touch.clientX - rect.left) * scaleX,
        y: (touch.clientY - rect.top) * scaleY
      };
    }
  }

  function startDrawing(e: MouseEvent) {
    if (!state.ctx) return;
    state.isDrawing = true;
    const coords = getCoordinates(e);
    state.lastX = coords.x;
    state.lastY = coords.y;
  }

  function handleTouchStart(e: TouchEvent) {
    e.preventDefault();
    if (!state.ctx) return;
    state.isDrawing = true;
    const coords = getCoordinates(e);
    state.lastX = coords.x;
    state.lastY = coords.y;
  }

  function draw(e: MouseEvent) {
    if (!state.isDrawing || !state.ctx) return;
    e.preventDefault();

    const coords = getCoordinates(e);

    state.ctx.beginPath();
    state.ctx.moveTo(state.lastX, state.lastY);
    state.ctx.lineTo(coords.x, coords.y);
    state.ctx.stroke();

    state.lastX = coords.x;
    state.lastY = coords.y;
  }

  function handleTouchMove(e: TouchEvent) {
    if (!state.isDrawing || !state.ctx) return;
    e.preventDefault();

    const coords = getCoordinates(e);

    state.ctx.beginPath();
    state.ctx.moveTo(state.lastX, state.lastY);
    state.ctx.lineTo(coords.x, coords.y);
    state.ctx.stroke();

    state.lastX = coords.x;
    state.lastY = coords.y;
  }

  function stopDrawing() {
    state.isDrawing = false;
  }

  function clearSignature() {
    if (!state.canvas || !state.ctx) return;

    state.ctx.clearRect(0, 0, state.canvas.width, state.canvas.height);
    state.signatureBlob = null;
    state.signaturePath = null;

    // Ocultar preview
    const previewContainer = document.getElementById('signaturePreviewContainer');
    if (previewContainer) {
      previewContainer.classList.add('hidden');
    }

    // Actualizar estado
    updateSignatureStatus('Sin firma', 'text-gray-500');
  }

  async function confirmSignature() {
    if (!state.canvas) return;

    // Verificar que hay algo dibujado
    if (!isCanvasBlank()) {
      try {
        // Convertir canvas a blob
        const blob = await new Promise<Blob>((resolve) => {
          state.canvas!.toBlob((blob) => {
            resolve(blob!);
          }, 'image/png');
        });

        state.signatureBlob = blob;

        // Mostrar preview
        const previewImg = document.getElementById('signaturePreview') as HTMLImageElement;
        const previewContainer = document.getElementById('signaturePreviewContainer');

        if (previewImg && previewContainer) {
          previewImg.src = URL.createObjectURL(blob);
          previewContainer.classList.remove('hidden');
        }

        // Subir firma al servidor
        await uploadSignature(blob);

        updateSignatureStatus('✓ Firma confirmada', 'text-green-600');

        // Llamar callback global si existe
        if (typeof (window as any).onSignatureCapture === 'function') {
          (window as any).onSignatureCapture(state.signatureBlob, state.signaturePath);
        }
      } catch (error) {
        updateSignatureStatus('Error al guardar firma', 'text-red-600');
      }
    } else {
      alert('Por favor, dibuje su firma antes de confirmar');
    }
  }

  async function uploadSignature(blob: Blob) {
    try {
      const formData = new FormData();
      formData.append('signature', blob, 'signature.png');
      formData.append('patientId', 'temp_' + Date.now());

      const response = await fetch('/api/admin/patients/upload-signature', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (result.success) {
        state.signaturePath = result.data.path;
      } else {
        throw new Error(result.message);
      }
    } catch (error) {
      throw error;
    }
  }

  function isCanvasBlank(): boolean {
    if (!state.canvas || !state.ctx) return true;

    const pixelData = state.ctx.getImageData(0, 0, state.canvas.width, state.canvas.height).data;

    // Verificar si hay al menos un pixel no transparente
    for (let i = 0; i < pixelData.length; i += 4) {
      if (pixelData[i + 3] !== 0) {
        return false;
      }
    }

    return true;
  }

  function updateSignatureStatus(text: string, colorClass: string) {
    const statusText = document.getElementById('signatureStatusText');
    if (statusText) {
      statusText.textContent = text;
      statusText.className = `text-sm ${colorClass}`;
    }
  }

  // Exponer funciones globalmente para uso externo
  (window as any).signaturePad = {
    getSignatureBlob: () => state.signatureBlob,
    getSignaturePath: () => state.signaturePath,
    clearSignature,
    isCanvasBlank
  };

  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSignaturePad);
  } else {
    initSignaturePad();
  }
</script>

<style>
  .signature-canvas {
    display: block;
    width: 100%;
    height: 200px;
    cursor: crosshair;
    touch-action: none;
  }

  .signature-canvas-wrapper {
    position: relative;
    max-width: 100%;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .signature-canvas {
      height: 150px;
    }
  }
</style>
