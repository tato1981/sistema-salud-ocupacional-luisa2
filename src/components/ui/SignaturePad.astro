---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`signature-pad-container ${className}`}>
  <div class="relative w-full aspect-[3/1] bg-white border-2 border-dashed border-gray-300 rounded-lg overflow-hidden mb-4 touch-none">
    <canvas id="signatureCanvas" class="w-full h-full cursor-crosshair"></canvas>
    <div id="signaturePlaceholder" class="absolute inset-0 flex items-center justify-center pointer-events-none text-gray-400">
      <p>Firme aquí</p>
    </div>
  </div>

  <div class="flex gap-2 justify-center">
    <button
      id="clearSignatureBtn"
      type="button"
      class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
      Borrar
    </button>

    <button
      id="saveSignatureBtn"
      type="button"
      class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      Confirmar Firma
    </button>
  </div>
</div>

<script>
  class SignaturePad {
    private canvas: HTMLCanvasElement;
    private context: CanvasRenderingContext2D;
    private clearBtn: HTMLButtonElement;
    private saveBtn: HTMLButtonElement;
    private placeholder: HTMLElement;
    private isDrawing = false;
    private hasSignature = false;

    constructor() {
      this.canvas = document.getElementById('signatureCanvas') as HTMLCanvasElement;
      this.context = this.canvas.getContext('2d')!;
      this.clearBtn = document.getElementById('clearSignatureBtn') as HTMLButtonElement;
      this.saveBtn = document.getElementById('saveSignatureBtn') as HTMLButtonElement;
      this.placeholder = document.getElementById('signaturePlaceholder') as HTMLElement;

      this.resizeCanvas();
      this.initEvents();
      
      // Expose cleanup method globally
      (window as any).signaturePad = {
        clearSignature: () => this.clear(),
        resize: () => this.resizeCanvas(),
        isEmpty: () => !this.hasSignature
      };
      
      window.addEventListener('resize', () => this.resizeCanvas());
    }

    private resizeCanvas() {
      const rect = this.canvas.parentElement?.getBoundingClientRect();
      if (rect) {
        this.canvas.width = rect.width;
        this.canvas.height = rect.height;
        this.context.lineCap = 'round';
        this.context.lineJoin = 'round';
        this.context.lineWidth = 2;
        this.context.strokeStyle = '#000';
      }
    }

    private initEvents() {
      // Mouse events
      this.canvas.addEventListener('mousedown', (e) => this.startDrawing(e));
      this.canvas.addEventListener('mousemove', (e) => this.draw(e));
      this.canvas.addEventListener('mouseup', () => this.stopDrawing());
      this.canvas.addEventListener('mouseout', () => this.stopDrawing());

      // Touch events
      this.canvas.addEventListener('touchstart', (e) => this.startDrawing(e));
      this.canvas.addEventListener('touchmove', (e) => this.draw(e));
      this.canvas.addEventListener('touchend', () => this.stopDrawing());

      // Buttons
      this.clearBtn?.addEventListener('click', () => this.clear());
      this.saveBtn?.addEventListener('click', () => this.save());
    }

    private getCoordinates(e: MouseEvent | TouchEvent) {
      const rect = this.canvas.getBoundingClientRect();
      let x, y;

      if ('touches' in e) {
        x = e.touches[0].clientX - rect.left;
        y = e.touches[0].clientY - rect.top;
      } else {
        x = (e as MouseEvent).clientX - rect.left;
        y = (e as MouseEvent).clientY - rect.top;
      }

      return { x, y };
    }

    private startDrawing(e: MouseEvent | TouchEvent) {
      e.preventDefault();
      this.isDrawing = true;
      this.hasSignature = true;
      this.placeholder.classList.add('hidden');
      
      const { x, y } = this.getCoordinates(e);
      this.context.beginPath();
      this.context.moveTo(x, y);
    }

    private draw(e: MouseEvent | TouchEvent) {
      if (!this.isDrawing) return;
      e.preventDefault();

      const { x, y } = this.getCoordinates(e);
      this.context.lineTo(x, y);
      this.context.stroke();
    }

    private stopDrawing() {
      if (this.isDrawing) {
        this.isDrawing = false;
        this.context.closePath();
      }
    }

    clear() {
      this.context.clearRect(0, 0, this.canvas.width, this.canvas.height);
      this.hasSignature = false;
      this.placeholder.classList.remove('hidden');
    }

    save() {
      if (!this.hasSignature) {
        alert('Por favor, firme antes de guardar.');
        return;
      }

      this.canvas.toBlob((blob) => {
        if (blob) {
          const url = URL.createObjectURL(blob);
          
          // Call global callback if defined
          if (typeof (window as any).onSignatureCapture === 'function') {
            (window as any).onSignatureCapture(blob, url);
          }
        }
      }, 'image/png');
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new SignaturePad();
  });
</script>