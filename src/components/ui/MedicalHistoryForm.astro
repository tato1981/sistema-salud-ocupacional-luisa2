---
// Componente de formulario para Historia Médica Ocupacional
// Incluye cálculos automáticos y validaciones según estándares OMS
---

<div class="bg-white shadow-lg rounded-lg p-3 sm:p-4 md:p-6">
  <form id="medicalHistoryForm" class="space-y-6 md:space-y-8">
    <!-- Información básica -->
    <div class="border-b border-gray-200 pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Información de la Consulta</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="symptoms" class="block text-sm font-medium text-gray-700 mb-1">
            Motivo de consulta / Síntomas principales *
          </label>
          <textarea 
            id="symptoms" 
            name="symptoms" 
            rows="3" 
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Describa el motivo principal de la consulta..."></textarea>
        </div>
        
        <div>
          <label for="currentIllness" class="block text-sm font-medium text-gray-700 mb-1">
            Enfermedad actual
          </label>
          <textarea 
            id="currentIllness" 
            name="currentIllness" 
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Detalle la evolución de la enfermedad actual..."></textarea>
        </div>
      </div>
    </div>

    <!-- Antecedentes -->
    <div class="border-b border-gray-200 pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Antecedentes</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="personalHistory" class="block text-sm font-medium text-gray-700 mb-1">
            Antecedentes personales
          </label>
          <textarea 
            id="personalHistory" 
            name="personalHistory" 
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Enfermedades previas, alergias, medicamentos..."></textarea>
        </div>
        
        <div>
          <label for="familyHistory" class="block text-sm font-medium text-gray-700 mb-1">
            Antecedentes familiares
          </label>
          <textarea 
            id="familyHistory" 
            name="familyHistory" 
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Enfermedades hereditarias, factores de riesgo..."></textarea>
        </div>
        
        <div>
          <label for="surgicalHistory" class="block text-sm font-medium text-gray-700 mb-1">
            Antecedentes quirúrgicos
          </label>
          <textarea 
            id="surgicalHistory" 
            name="surgicalHistory" 
            rows="2"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Cirugías previas, complicaciones..."></textarea>
        </div>
        
        <div>
          <label for="occupationalHistory" class="block text-sm font-medium text-gray-700 mb-1">
            Antecedentes ocupacionales
          </label>
          <textarea 
            id="occupationalHistory" 
            name="occupationalHistory" 
            rows="2"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Exposiciones laborales, riesgos ocupacionales..."></textarea>
        </div>
      </div>
    </div>

    <!-- Signos vitales y medidas antropométricas -->
    <div class="border-b border-gray-200 pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Signos Vitales y Medidas Antropométricas</h3>
      
      <!-- Presión arterial -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-4 md:mb-6">
        <div>
          <label for="systolicPressure" class="block text-sm font-medium text-gray-700 mb-1">
            Presión sistólica (mmHg)
          </label>
          <input 
            type="number" 
            id="systolicPressure" 
            name="systolicPressure" 
            min="60" 
            max="250"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="120">
        </div>
        
        <div>
          <label for="diastolicPressure" class="block text-sm font-medium text-gray-700 mb-1">
            Presión diastólica (mmHg)
          </label>
          <input 
            type="number" 
            id="diastolicPressure" 
            name="diastolicPressure" 
            min="40" 
            max="150"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="80">
        </div>
        
        <div>
          <label for="heartRate" class="block text-sm font-medium text-gray-700 mb-1">
            Frecuencia cardíaca (lpm)
          </label>
          <input 
            type="number" 
            id="heartRate" 
            name="heartRate" 
            min="30" 
            max="200"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="72">
        </div>
        
        <div>
          <label for="respiratoryRate" class="block text-sm font-medium text-gray-700 mb-1">
            Frecuencia respiratoria (rpm)
          </label>
          <input 
            type="number" 
            id="respiratoryRate" 
            name="respiratoryRate" 
            min="8" 
            max="40"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="16">
        </div>
      </div>
      
      <!-- Alertas de presión arterial -->
      <div id="bloodPressureAlert" class="hidden mb-3 md:mb-4 p-3 md:p-4 rounded-md">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-4 w-4 md:h-5 md:w-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-2 md:ml-3">
            <p class="text-xs md:text-sm font-medium" id="bloodPressureMessage"></p>
          </div>
        </div>
      </div>
      
      <!-- Medidas antropométricas -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-4">
        <div>
          <label for="height" class="block text-sm font-medium text-gray-700 mb-1">
            Estatura (cm) *
          </label>
          <input 
            type="number" 
            id="height" 
            name="height" 
            min="100" 
            max="250" 
            step="0.1"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="170.0">
        </div>
        
        <div>
          <label for="weight" class="block text-sm font-medium text-gray-700 mb-1">
            Peso (kg) *
          </label>
          <input 
            type="number" 
            id="weight" 
            name="weight" 
            min="20" 
            max="300" 
            step="0.1"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="70.0">
        </div>
        
        <div>
          <label for="temperature" class="block text-sm font-medium text-gray-700 mb-1">
            Temperatura (°C)
          </label>
          <input 
            type="number" 
            id="temperature" 
            name="temperature" 
            min="35" 
            max="42" 
            step="0.1"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="36.5">
        </div>
        
        <div>
          <label for="oxygenSaturation" class="block text-sm font-medium text-gray-700 mb-1">
            Saturación O₂ (%)
          </label>
          <input 
            type="number" 
            id="oxygenSaturation" 
            name="oxygenSaturation" 
            min="70" 
            max="100"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="98">
        </div>
      </div>
      
      <!-- Cálculo automático de IMC -->
      <div id="bmiCalculation" class="hidden bg-blue-50 border border-blue-200 rounded-md p-3 md:p-4">
        <h4 class="font-semibold text-blue-900 mb-2 text-sm md:text-base">Cálculo Automático de IMC</h4>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 md:gap-4 text-xs md:text-sm">
          <div>
            <span class="font-medium">IMC:</span> 
            <span id="bmiValue" class="font-bold text-blue-600"></span>
          </div>
          <div>
            <span class="font-medium">Clasificación:</span> 
            <span id="bmiClassification" class="font-bold"></span>
          </div>
          <div>
            <span class="font-medium">Riesgo:</span> 
            <span id="bmiRisk" class="font-bold"></span>
          </div>
        </div>
        <div class="mt-3">
          <h5 class="font-medium text-blue-900 mb-1">Recomendaciones automáticas:</h5>
          <ul id="bmiRecommendations" class="list-disc list-inside text-sm text-blue-700 space-y-1"></ul>
        </div>
      </div>

      <!-- Estado General del Paciente -->
      <div id="patientHealthStatus" class="hidden mt-4 md:mt-6 p-4 md:p-6 rounded-lg border-2">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 gap-3">
          <h3 class="text-lg md:text-xl font-bold flex items-center">
            <span id="statusIcon" class="mr-2 md:mr-3 text-xl md:text-2xl"></span>
            <span id="statusTitle" class="text-sm md:text-base lg:text-lg">Estado General del Paciente</span>
          </h3>
          <div id="statusBadge" class="px-3 md:px-4 py-1 md:py-2 rounded-full text-xs md:text-sm font-bold self-start sm:self-auto"></div>
        </div>
        
        <div id="statusDescription" class="mb-4 text-xs md:text-sm"></div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
          <div>
            <h4 class="font-semibold mb-2 text-gray-700 text-xs md:text-sm">📊 Signos Vitales Evaluados:</h4>
            <ul id="vitalSignsStatus" class="space-y-1 text-xs md:text-sm"></ul>
          </div>
          <div>
            <h4 class="font-semibold mb-2 text-gray-700 text-xs md:text-sm">💡 Recomendaciones Prioritarias:</h4>
            <ul id="priorityRecommendations" class="space-y-1 text-xs md:text-sm"></ul>
          </div>
        </div>
        
        <div class="mt-4 p-2 md:p-3 bg-gray-50 rounded-md">
          <p class="text-xs md:text-sm text-gray-600">
            <strong>Nota:</strong> Esta evaluación se basa en estándares de la OMS y debe ser interpretada por personal médico calificado.
          </p>
        </div>
      </div>

      <!-- Alertas Individuales de Signos Vitales -->
      <div id="individualAlerts" class="space-y-2 md:space-y-3 mt-3 md:mt-4"></div>
    </div>

    <!-- Examen físico -->
    <div class="border-b border-gray-200 pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Examen Físico</h3>
      <div>
        <label for="physicalExam" class="block text-sm font-medium text-gray-700 mb-1">
          Hallazgos del examen físico
        </label>
        <textarea 
          id="physicalExam" 
          name="physicalExam" 
          rows="4"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="Describa los hallazgos del examen físico por sistemas..."></textarea>
      </div>
    </div>

    <!-- Evaluación ocupacional -->
    <div class="border-b border-gray-200 pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Evaluación Ocupacional</h3>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6 mb-4">
        <div>
          <label for="workEnvironmentRisk" class="block text-sm font-medium text-gray-700 mb-1">
            Riesgos del ambiente laboral
          </label>
          <textarea 
            id="workEnvironmentRisk" 
            name="workEnvironmentRisk" 
            rows="2"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Describa los riesgos identificados en el puesto de trabajo..."></textarea>
        </div>
        
        <div>
          <label for="psychologicalStressLevel" class="block text-sm font-medium text-gray-700 mb-1">
            Nivel de estrés psicológico
          </label>
          <select 
            id="psychologicalStressLevel" 
            name="psychologicalStressLevel"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            <option value="">Seleccionar nivel</option>
            <option value="bajo">Bajo</option>
            <option value="moderado">Moderado</option>
            <option value="alto">Alto</option>
            <option value="muy_alto">Muy alto</option>
          </select>
        </div>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-3">Exposiciones ocupacionales</label>
          <div class="space-y-2">
            <label class="flex items-center">
              <input type="checkbox" id="exposureChemicals" name="exposureChemicals" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
              <span class="ml-2 text-xs md:text-sm text-gray-700">Exposición a químicos</span>
            </label>
            <label class="flex items-center">
              <input type="checkbox" id="exposureNoise" name="exposureNoise" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
              <span class="ml-2 text-xs md:text-sm text-gray-700">Exposición a ruido</span>
            </label>
            <label class="flex items-center">
              <input type="checkbox" id="exposureRadiation" name="exposureRadiation" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
              <span class="ml-2 text-xs md:text-sm text-gray-700">Exposición a radiación</span>
            </label>
            <label class="flex items-center">
              <input type="checkbox" id="ergonomicRisks" name="ergonomicRisks" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
              <span class="ml-2 text-xs md:text-sm text-gray-700">Riesgos ergonómicos</span>
            </label>
          </div>
        </div>
        
        <div>
          <label for="fitnessForWork" class="block text-sm font-medium text-gray-700 mb-1">
            Aptitud para el trabajo *
          </label>
          <select
            id="fitnessForWork"
            name="fitnessForWork"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent mb-3">
            <option value="" disabled selected>Seleccionar aptitud</option>
            <option value="apto">Apto</option>
            <option value="apto_con_restricciones">Apto con restricciones</option>
            <option value="no_apto">No apto</option>
            <option value="aplazado">Aplazado</option>
          </select>
          
          <label for="workRestrictions" class="block text-sm font-medium text-gray-700 mb-1">
            Restricciones laborales (si aplica)
          </label>
          <textarea 
            id="workRestrictions" 
            name="workRestrictions" 
            rows="2"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Especifique las restricciones o limitaciones..."></textarea>
        </div>
      </div>
    </div>

    <!-- Diagnóstico y tratamiento -->
    <div class="border-b border-gray-200 pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Diagnóstico y Tratamiento</h3>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6 mb-4">
        <div>
          <label for="diagnosis" class="block text-sm font-medium text-gray-700 mb-1">
            Diagnóstico principal *
          </label>
          <textarea 
            id="diagnosis" 
            name="diagnosis" 
            rows="3"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Diagnóstico principal y diferenciales..."></textarea>
        </div>
        
        <div>
          <label for="cie10Code" class="block text-sm font-medium text-gray-700 mb-1">
            Código CIE-10
          </label>
          <input 
            type="text" 
            id="cie10Code" 
            name="cie10Code" 
            maxlength="20"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent mb-3"
            placeholder="Ej: Z02.1 (máx. 20 caracteres)">
          
          <label for="treatment" class="block text-sm font-medium text-gray-700 mb-1">
            Plan de tratamiento *
          </label>
          <textarea 
            id="treatment" 
            name="treatment" 
            rows="2"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Plan terapéutico y conducta a seguir..."></textarea>
        </div>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="medications" class="block text-sm font-medium text-gray-700 mb-1">
            Medicamentos prescritos
          </label>
          <textarea 
            id="medications" 
            name="medications" 
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Medicamentos, dosis, frecuencia y duración..."></textarea>
        </div>
        
        <div>
          <label for="manualRecommendations" class="block text-sm font-medium text-gray-700 mb-1">
            Recomendaciones adicionales
          </label>
          <textarea 
            id="manualRecommendations" 
            name="manualRecommendations" 
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Recomendaciones específicas para el paciente..."></textarea>
          <small class="text-gray-500">Nota: Las recomendaciones automáticas basadas en signos vitales se agregarán automáticamente</small>
        </div>
      </div>
    </div>

    <!-- Seguimiento -->
    <div class="pb-4 md:pb-6">
      <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-3 md:mb-4">Seguimiento</h3>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="nextAppointmentDate" class="block text-sm font-medium text-gray-700 mb-1">
            Próxima cita (si es necesaria)
          </label>
          <input 
            type="date" 
            id="nextAppointmentDate" 
            name="nextAppointmentDate"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>
        
        <div>
          <label for="notes" class="block text-sm font-medium text-gray-700 mb-1">
            Notas adicionales
          </label>
          <textarea 
            id="notes" 
            name="notes" 
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Observaciones, comentarios o notas especiales..."></textarea>
        </div>
      </div>
    </div>

    <!-- Botones -->
    <div class="flex flex-col sm:flex-row justify-end gap-3 sm:gap-4 pt-4 md:pt-6 border-t border-gray-200">
      <button 
        type="button" 
        id="cancelBtn"
        class="w-full sm:w-auto px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 order-2 sm:order-1">
        Cancelar
      </button>
      <button 
        type="submit"
        class="w-full sm:w-auto px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 order-1 sm:order-2">
        <span id="submitText">Guardar Historia Médica</span>
        <svg id="loadingSpinner" class="hidden animate-spin -ml-1 mr-3 h-5 w-5 text-white inline" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </button>
    </div>
  </form>
</div>

<script>
// Cálculos automáticos y validaciones
document.addEventListener('DOMContentLoaded', function() {
  const weightInput = document.getElementById('weight') as HTMLInputElement;
  const heightInput = document.getElementById('height') as HTMLInputElement;
  const systolicInput = document.getElementById('systolicPressure') as HTMLInputElement;
  const diastolicInput = document.getElementById('diastolicPressure') as HTMLInputElement;
  const heartRateInput = document.getElementById('heartRate') as HTMLInputElement;
  const temperatureInput = document.getElementById('temperature') as HTMLInputElement;
  const oxygenSaturationInput = document.getElementById('oxygenSaturation') as HTMLInputElement;
  const respiratoryRateInput = document.getElementById('respiratoryRate') as HTMLInputElement;
  
  // Calcular IMC automáticamente
  function calculateBMI() {
    const weight = parseFloat(weightInput.value);
    const height = parseFloat(heightInput.value);
    
    if (weight && height && weight > 0 && height > 0) {
      const heightInMeters = height / 100;
      const bmi = weight / (heightInMeters * heightInMeters);
      
      // Mostrar cálculo
      const bmiCalculation = document.getElementById('bmiCalculation')!;
      const bmiValue = document.getElementById('bmiValue')!;
      const bmiClassification = document.getElementById('bmiClassification')!;
      const bmiRisk = document.getElementById('bmiRisk')!;
      const bmiRecommendations = document.getElementById('bmiRecommendations')!;
      
      bmiCalculation.classList.remove('hidden');
      bmiValue.textContent = bmi.toFixed(1);
      
      // Clasificación según OMS
      let classification = '';
      let risk = '';
      let recommendations: string[] = [];
      let classColor = '';
      
      if (bmi < 18.5) {
        classification = 'Bajo peso';
        risk = 'Riesgo de desnutrición';
        classColor = 'text-blue-600';
        recommendations = [
          'Evaluación nutricional detallada',
          'Consulta con nutricionista',
          'Incremento gradual de ingesta calórica'
        ];
      } else if (bmi >= 18.5 && bmi < 25) {
        classification = 'Peso normal';
        risk = 'Riesgo normal';
        classColor = 'text-green-600';
        recommendations = [
          'Mantener peso actual',
          'Dieta balanceada y ejercicio regular'
        ];
      } else if (bmi >= 25 && bmi < 30) {
        classification = 'Sobrepeso';
        risk = 'Riesgo aumentado';
        classColor = 'text-yellow-600';
        recommendations = [
          'Reducción de peso gradual (5-10%)',
          'Plan nutricional personalizado',
          'Ejercicio aeróbico 150 min/semana'
        ];
      } else if (bmi >= 30 && bmi < 35) {
        classification = 'Obesidad grado I';
        risk = 'Riesgo alto';
        classColor = 'text-orange-600';
        recommendations = [
          'Pérdida de peso estructurada (10-15%)',
          'Intervención nutricional intensiva',
          'Evaluación cardiovascular'
        ];
      } else if (bmi >= 35 && bmi < 40) {
        classification = 'Obesidad grado II';
        risk = 'Riesgo muy alto';
        classColor = 'text-red-600';
        recommendations = [
          'Pérdida de peso significativa (15-20%)',
          'Manejo multidisciplinario',
          'Consideración de farmacoterapia'
        ];
      } else {
        classification = 'Obesidad grado III (mórbida)';
        risk = 'Riesgo extremo';
        classColor = 'text-red-800';
        recommendations = [
          'Pérdida de peso urgente',
          'Evaluación para cirugía bariátrica',
          'Control estricto de comorbilidades'
        ];
      }
      
      bmiClassification.textContent = classification;
      bmiClassification.className = `font-bold ${classColor}`;
      bmiRisk.textContent = risk;
      bmiRisk.className = `font-bold ${classColor}`;
      
      // Mostrar recomendaciones
      bmiRecommendations.innerHTML = recommendations
        .map(rec => `<li>${rec}</li>`)
        .join('');
    } else {
      document.getElementById('bmiCalculation')!.classList.add('hidden');
    }
  }
  
  // Evaluar presión arterial
  function evaluateBloodPressure() {
    const systolic = parseFloat(systolicInput.value);
    const diastolic = parseFloat(diastolicInput.value);
    
    if (systolic && diastolic) {
      const alert = document.getElementById('bloodPressureAlert')!;
      const message = document.getElementById('bloodPressureMessage')!;
      
      let alertClass = '';
      let alertMessage = '';
      
      if (systolic < 120 && diastolic < 80) {
        alert.classList.add('hidden');
        return;
      } else if ((systolic >= 120 && systolic <= 129) && diastolic < 80) {
        alertClass = 'bg-yellow-50 text-yellow-800 border-yellow-200';
        alertMessage = '⚠️ Presión arterial elevada - Se recomienda modificaciones de estilo de vida';
      } else if ((systolic >= 130 && systolic <= 139) || (diastolic >= 80 && diastolic <= 89)) {
        alertClass = 'bg-orange-50 text-orange-800 border-orange-200';
        alertMessage = '🔶 Hipertensión estadio 1 - Requiere evaluación médica y posible tratamiento';
      } else if (systolic >= 140 || diastolic >= 90) {
        alertClass = 'bg-red-50 text-red-800 border-red-200';
        alertMessage = '🚨 Hipertensión estadio 2 - Requiere tratamiento farmacológico inmediato';
      }
      
      if (systolic >= 180 || diastolic >= 110) {
        alertClass = 'bg-red-100 text-red-900 border-red-300';
        alertMessage = '🆘 CRISIS HIPERTENSIVA - Requiere atención médica inmediata';
      }
      
      if (alertMessage) {
        alert.className = `p-4 rounded-md ${alertClass}`;
        alert.classList.remove('hidden');
        message.textContent = alertMessage;
      } else {
        alert.classList.add('hidden');
      }
    } else {
      document.getElementById('bloodPressureAlert')!.classList.add('hidden');
    }
  }
  
  // Event listeners para cálculos automáticos
  weightInput.addEventListener('input', calculateBMI);
  heightInput.addEventListener('input', calculateBMI);
  systolicInput.addEventListener('input', evaluateBloodPressure);
  diastolicInput.addEventListener('input', evaluateBloodPressure);
  
  // Validación de frecuencia cardíaca con alertas OMS
