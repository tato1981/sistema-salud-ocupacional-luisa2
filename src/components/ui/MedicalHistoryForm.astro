  function evaluateHeartRate(heartRate: number) {
    const input = heartRateInput;
    let alertType = '';
    let alertTitle = '';
    let alertMessage = '';
    let recommendations: string[] = [];

    if (heartRate < 60) {
      input.style.borderColor = '#f59e0b';
      alertType = 'warning';
      alertTitle = '⚠️ Bradicardia Detectada';
      alertMessage = `Frecuencia cardíaca de ${heartRate} lpm está por debajo del rango normal (60-100 lpm).`;
