// Envío del formulario
(window as any).submitMedicalHistory = async function(patientId: number, doctorId: number, appointmentId: number) {
  const form = document.getElementById('medicalHistoryForm') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]')!;
  const submitText = document.getElementById('submitText')!;
  const loadingSpinner = document.getElementById('loadingSpinner')!;
  
  // Mostrar loading
  submitText.textContent = 'Guardando...';
  loadingSpinner.classList.remove('hidden');
  submitBtn.setAttribute('disabled', 'true');
  
  try {
    // Recopilar datos del formulario
    const formData = new FormData(form);

    // Validar que se haya seleccionado una aptitud
    const fitnessForWork = formData.get('fitnessForWork');
    if (!fitnessForWork || fitnessForWork === '') {
      if (typeof (window as any).showSweetAlert === 'function') {
        (window as any).showSweetAlert('error', 'Campo Requerido', 'Debe seleccionar la aptitud para el trabajo');
      } else {
        alert('Debe seleccionar la aptitud para el trabajo');
      }
      submitText.textContent = 'Guardar Historia Médica';
      loadingSpinner.classList.add('hidden');
      submitBtn.removeAttribute('disabled');
      return;
    }
    
    // Construir objeto de signos vitales
    const vitalSigns: any = {};
    
    if (formData.get('systolicPressure')) vitalSigns.systolic_pressure = parseFloat(formData.get('systolicPressure') as string);
    if (formData.get('diastolicPressure')) vitalSigns.diastolic_pressure = parseFloat(formData.get('diastolicPressure') as string);
    if (formData.get('heartRate')) vitalSigns.heart_rate = parseFloat(formData.get('heartRate') as string);
    if (formData.get('respiratoryRate')) vitalSigns.respiratory_rate = parseFloat(formData.get('respiratoryRate') as string);
    if (formData.get('temperature')) vitalSigns.temperature = parseFloat(formData.get('temperature') as string);
    if (formData.get('oxygenSaturation')) vitalSigns.oxygen_saturation = parseFloat(formData.get('oxygenSaturation') as string);
    if (formData.get('height')) vitalSigns.height = parseFloat(formData.get('height') as string);
    if (formData.get('weight')) vitalSigns.weight = parseFloat(formData.get('weight') as string);
    
    // Construir evaluación ocupacional
    const occupationalAssessment: any = {};
    
    if (formData.get('workEnvironmentRisk')) occupationalAssessment.work_environment_risk = formData.get('workEnvironmentRisk');
    if (formData.get('psychologicalStressLevel')) occupationalAssessment.psychological_stress_level = formData.get('psychologicalStressLevel');
    if (formData.get('fitnessForWork')) occupationalAssessment.fitness_for_work = formData.get('fitnessForWork');
    if (formData.get('workRestrictions')) occupationalAssessment.work_restrictions = [formData.get('workRestrictions')];
    
    occupationalAssessment.exposure_to_chemicals = formData.get('exposureChemicals') === 'on';
    occupationalAssessment.exposure_to_noise = formData.get('exposureNoise') === 'on';
    occupationalAssessment.exposure_to_radiation = formData.get('exposureRadiation') === 'on';
    occupationalAssessment.ergonomic_risks = formData.get('ergonomicRisks') === 'on';
    
    // Datos principales
    const medicalHistoryData = {
      patient_id: patientId,
      doctor_id: doctorId,
      appointment_id: appointmentId,
      symptoms: formData.get('symptoms'),
      current_illness: formData.get('currentIllness') || null,
      personal_history: formData.get('personalHistory') || null,
      family_history: formData.get('familyHistory') || null,
      surgical_history: formData.get('surgicalHistory') || null,
      occupational_history: formData.get('occupationalHistory') || null,
      physical_exam: formData.get('physicalExam') || null,
      vital_signs: Object.keys(vitalSigns).length > 0 ? vitalSigns : null,
      occupational_assessment: Object.keys(occupationalAssessment).length > 0 ? occupationalAssessment : null,
      diagnosis: formData.get('diagnosis'),
      cie10_code: formData.get('cie10Code') || null,
      treatment: formData.get('treatment'),
      medications: formData.get('medications') || null,
      recommendations: formData.get('manualRecommendations') || null,
      next_appointment_date: formData.get('nextAppointmentDate') || null,
      notes: formData.get('notes') || null,
      aptitude_status: formData.get('fitnessForWork') || null,
      restrictions: formData.get('workRestrictions') || null
    };
    
    // Enviar al servidor
    const response = await fetch('/api/doctor/medical-history/create', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(medicalHistoryData),
    });
    
    const result = await response.json();
    
    if (result.success) {
      // Mostrar mensaje de éxito con recomendaciones automáticas si están disponibles
      let successMessage = 'La historia médica se ha guardado exitosamente';
      
      if (result.calculated_data) {
        let recommendations = [];
        
        // Agregar análisis de IMC
        if (result.calculated_data.bmi_analysis) {
          const bmi = result.calculated_data.bmi_analysis;
          recommendations.push(`📊 IMC: ${bmi.bmi} - ${bmi.classification}`);
        }
        
        // Agregar análisis de presión arterial
        if (result.calculated_data.blood_pressure_analysis) {
          const bp = result.calculated_data.blood_pressure_analysis;
          recommendations.push(`🫀 Presión arterial: ${bp.classification}`);
          if (bp.occupational_fitness !== 'Apto para actividades normales') {
            recommendations.push(`⚠️ Aptitud: ${bp.occupational_fitness}`);
          }
        }
        
        // Agregar análisis de frecuencia cardíaca
        if (result.calculated_data.heart_rate_analysis) {
          const hr = result.calculated_data.heart_rate_analysis;
          recommendations.push(`💓 Frecuencia cardíaca: ${hr.classification}`);
          if (hr.occupational_fitness !== 'Apto para actividades normales') {
            recommendations.push(`⚠️ Estado cardiovascular: ${hr.occupational_fitness}`);
          }
        }
        
        if (recommendations.length > 0) {
          successMessage += '\n\n📋 Evaluación automática OMS:\n' + recommendations.join('\n');
        }
      }
      
      if (typeof (window as any).showSweetAlert === 'function') {
        (window as any).showSweetAlert('success', '✅ Historia Médica Guardada', successMessage, 3000);
      } else {
        alert('Historia médica guardada exitosamente');
      }
      
      // Limpiar formulario
      form.reset();
      document.getElementById('bmiCalculation')!.classList.add('hidden');
      document.getElementById('bloodPressureAlert')!.classList.add('hidden');
      
      // Redirigir o actualizar vista después de la alerta
      setTimeout(() => {
        window.location.reload();
      }, 2200);
    } else {
      if (typeof (window as any).showSweetAlert === 'function') {
        (window as any).showSweetAlert('error', 'Error al Guardar', result.message || 'No se pudo guardar la historia médica');
      } else {
        alert('Error al guardar la historia médica: ' + result.message);
      }
    }
  } catch (error) {
    // Silently fail
    if (typeof (window as any).showSweetAlert === 'function') {
      (window as any).showSweetAlert('error', 'Error de Conexión', 'No se pudo conectar con el servidor. Por favor, intente nuevamente.');
    } else {
      alert('Error de conexión. Por favor, intente nuevamente.');
    }
  } finally {
    // Ocultar loading
    submitText.textContent = 'Guardar Historia Médica';
    loadingSpinner.classList.add('hidden');
    submitBtn.removeAttribute('disabled');
  }
};

