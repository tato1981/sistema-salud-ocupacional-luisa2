      alertType = 'warning';
      alertTitle = '🔥 Fiebre Moderada';
      alertMessage = `Temperatura de ${temperature}°C indica fiebre moderada.`;
      recommendations = [
        'Investigación de causa infecciosa',
        'Antipiréticos si es necesario',
        'Hidratación abundante',
        'Reposo laboral',
        'Control médico en 24 horas'
      ];
    } else if (temperature >= 39.0) {
      input.style.borderColor = '#dc2626';
      alertType = 'error';
      alertTitle = '🆘 Fiebre Alta';
      alertMessage = `Temperatura de ${temperature}°C indica fiebre alta que requiere atención médica.`;
      recommendations = [
        'Evaluación médica INMEDIATA',
        'Hemocultivos y laboratorios',
        'Antipiréticos y medidas físicas',
        'Suspensión temporal de actividades laborales',
        'Posible hospitalización'
      ];
    } else {
      input.style.borderColor = '#10b981';
      return;
    }

    // Mostrar alerta con SweetAlert
    if (typeof (window as any).showSweetAlert === 'function') {
      const recommendationsText = recommendations.join('\n• ');
      (window as any).showSweetAlert(
        alertType, 
        alertTitle, 
        `${alertMessage}\n\nRecomendaciones OMS:\n• ${recommendationsText}`
      );
    }
  }

  // Función para evaluar saturación de oxígeno según OMS
  oxygenSaturationInput.addEventListener('input', function() {
    const saturation = parseFloat(this.value);
    if (saturation) {
      evaluateOxygenSaturation(saturation);
    }
  });

  function evaluateOxygenSaturation(saturation: number) {
