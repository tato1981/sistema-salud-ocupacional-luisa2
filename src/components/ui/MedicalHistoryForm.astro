      input.style.borderColor = '#ef4444';
      alertType = 'warning';
      alertTitle = '⚠️ Hipoxemia Moderada';
      alertMessage = `Saturación de ${saturation}% está por debajo del rango normal (≥95%).`;
      recommendations = [
        'Evaluación pulmonar completa',
        'Radiografía de tórax',
        'Considerar oxigenoterapia',
        'Restricción de actividades físicas intensas',
        'Seguimiento médico estrecho'
