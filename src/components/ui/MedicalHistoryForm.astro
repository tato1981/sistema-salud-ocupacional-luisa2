        'Se requiere evaluación cardiológica',
        'Realizar electrocardiograma',
        'Evaluar medicamentos actuales',
        'Considerar Holter de 24 horas',
        'Restricción temporal de actividades intensas'
      ];
    } else if (heartRate > 100 && heartRate <= 120) {
      input.style.borderColor = '#f59e0b';
      alertType = 'warning';
      alertTitle = '⚠️ Taquicardia Leve';
      alertMessage = `Frecuencia cardíaca de ${heartRate} lpm está levemente elevada.`;
      recommendations = [
        'Evaluar causas subyacentes (ansiedad, cafeína)',
        'Control de estrés',
        'Limitación de cafeína',
        'Evaluación tiroidea',
        'Seguimiento médico regular'
      ];
