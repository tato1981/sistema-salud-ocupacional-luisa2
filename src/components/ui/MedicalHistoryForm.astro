        'Investigar causas de hipotermia',
        'Evaluar exposición a frío',
        'Revisar función tiroidea',
        'Monitoreo continuo de temperatura'
      ];
    } else if (temperature >= 37.3 && temperature < 38.0) {
      input.style.borderColor = '#f59e0b';
      alertType = 'warning';
      alertTitle = '🌡️ Febrícula';
      alertMessage = `Temperatura de ${temperature}°C indica febrícula.`;
      recommendations = [
        'Buscar foco infeccioso',
        'Hidratación adecuada',
        'Control en 4-6 horas',
        'Evaluar síntomas asociados'
