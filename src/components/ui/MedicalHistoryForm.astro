      { min: 101, max: 120, level: 'warning', status: 'Taquicardia leve', recommendations: ['Control de estrés', 'Limitar cafeína', 'Evaluación tiroidea'] },
      { min: 121, max: 999, level: 'critical', status: 'Taquicardia severa', recommendations: ['Evaluación cardiológica urgente', 'ECG inmediato'] }
    ]);
    evaluations.push({ name: 'Frecuencia Cardíaca', value: `${heartRate} lpm`, ...hrEval });
  }

  // Evaluar temperatura
  if (temperature) {
    const tempEval = evaluateVitalSign('temperature', temperature, [
      { min: 0, max: 36.0, level: 'warning', status: 'Hipotermia', recommendations: ['Evaluación médica', 'Medidas de calentamiento'] },
      { min: 36.1, max: 37.2, level: 'normal', status: 'Normal' },
      { min: 37.3, max: 38.0, level: 'warning', status: 'Febrícula', recommendations: ['Observación', 'Hidratación', 'Control térmico'] },
      { min: 38.1, max: 999, level: 'critical', status: 'Fiebre', recommendations: ['Antipiréticos', 'Evaluación médica', 'Suspensión laboral'] }
    ]);
    evaluations.push({ name: 'Temperatura', value: `${temperature}°C`, ...tempEval });
  }

  // Evaluar saturación de oxígeno
  if (oxygenSaturation) {
    const satEval = evaluateVitalSign('oxygenSaturation', oxygenSaturation, [
      { min: 0, max: 89, level: 'critical', status: 'Hipoxemia severa', recommendations: ['OXÍGENO INMEDIATO', 'Emergencia médica'] },
      { min: 90, max: 94, level: 'warning', status: 'Hipoxemia moderada', recommendations: ['Evaluación respiratoria', 'Oxígeno suplementario'] },
      { min: 95, max: 100, level: 'normal', status: 'Normal' }
    ]);
    evaluations.push({ name: 'Saturación O₂', value: `${oxygenSaturation}%`, ...satEval });
  }

  // Evaluar frecuencia respiratoria
  if (respiratoryRate) {
    const respEval = evaluateVitalSign('respiratoryRate', respiratoryRate, [
      { min: 0, max: 11, level: 'warning', status: 'Bradipnea', recommendations: ['Evaluación respiratoria', 'Gasometría'] },
      { min: 12, max: 20, level: 'normal', status: 'Normal' },
      { min: 21, max: 24, level: 'warning', status: 'Taquipnea leve', recommendations: ['Evaluación pulmonar', 'Radiografía de tórax'] },
      { min: 25, max: 999, level: 'critical', status: 'Taquipnea severa', recommendations: ['Evaluación respiratoria urgente', 'Oxígeno'] }
    ]);
    evaluations.push({ name: 'Frecuencia Respiratoria', value: `${respiratoryRate} rpm`, ...respEval });
  }

  // Evaluar presión arterial
  if (systolic && diastolic) {
    let bpLevel = 'normal';
    let bpStatus = 'Normal';
    let bpRecommendations: string[] = [];

    if (systolic >= 180 || diastolic >= 110) {
      bpLevel = 'critical';
      bpStatus = 'Crisis hipertensiva';
      bpRecommendations = ['ATENCIÓN MÉDICA INMEDIATA', 'Tratamiento urgente'];
    } else if (systolic >= 140 || diastolic >= 90) {
      bpLevel = 'critical';
      bpStatus = 'Hipertensión estadio 2';
      bpRecommendations = ['Tratamiento farmacológico', 'Evaluación cardiovascular'];
    } else if ((systolic >= 130 && systolic <= 139) || (diastolic >= 80 && diastolic <= 89)) {
      bpLevel = 'warning';
      bpStatus = 'Hipertensión estadio 1';
      bpRecommendations = ['Modificaciones de estilo de vida', 'Seguimiento médico'];
    } else if ((systolic >= 120 && systolic <= 129) && diastolic < 80) {
      bpLevel = 'warning';
      bpStatus = 'Presión elevada';
      bpRecommendations = ['Cambios en estilo de vida', 'Control regular'];
    }

    evaluations.push({ 
      name: 'Presión Arterial', 
      value: `${systolic}/${diastolic} mmHg`, 
      level: bpLevel, 
      status: bpStatus, 
      recommendations: bpRecommendations 
    });
  }

  // Evaluar IMC si hay peso y altura
  if (weight && height) {
    const bmi = weight / Math.pow(height / 100, 2);
    let bmiLevel = 'normal';
    let bmiStatus = 'Normal';
    let bmiRecommendations: string[] = [];

    if (bmi < 18.5) {
      bmiLevel = 'warning';
      bmiStatus = 'Bajo peso';
      bmiRecommendations = ['Evaluación nutricional', 'Aumento de peso controlado'];
    } else if (bmi >= 25 && bmi < 30) {
      bmiLevel = 'warning';
      bmiStatus = 'Sobrepeso';
      bmiRecommendations = ['Dieta balanceada', 'Actividad física regular'];
    } else if (bmi >= 30) {
      bmiLevel = 'critical';
      bmiStatus = 'Obesidad';
      bmiRecommendations = ['Tratamiento integral', 'Evaluación médica especializada'];
    }

    evaluations.push({ 
      name: 'IMC', 
      value: `${bmi.toFixed(1)} kg/m²`, 
      level: bmiLevel, 
      status: bmiStatus, 
      recommendations: bmiRecommendations 
    });
  }

  // Contar niveles de alerta
  evaluations.forEach(evaluation => {
    if (evaluation.level === 'critical') criticalCount++;
    else if (evaluation.level === 'warning') warningCount++;
    else normalCount++;
  });
  
  // Silently fail

  // Determinar estado general
  let overallLevel, overallStatus, overallIcon, statusClasses, badgeClasses;

  if (criticalCount > 0) {
    overallLevel = 'critical';
    overallStatus = 'ESTADO CRÍTICO';
    overallIcon = '🚨';
    statusClasses = 'bg-red-50 border-red-300';
    badgeClasses = 'bg-red-100 text-red-800';
  } else if (warningCount > 0) {
    overallLevel = 'warning';
    overallStatus = 'REQUIERE ATENCIÓN';
    overallIcon = '⚠️';
    statusClasses = 'bg-yellow-50 border-yellow-300';
    badgeClasses = 'bg-yellow-100 text-yellow-800';
  } else if (normalCount > 0) {
    overallLevel = 'normal';
    overallStatus = 'ESTADO NORMAL';
    overallIcon = '✅';
    statusClasses = 'bg-green-50 border-green-300';
    badgeClasses = 'bg-green-100 text-green-800';
  } else {
    statusDiv.classList.add('hidden');
    return;
  }

  // Actualizar UI
  statusDiv.className = `mt-6 p-6 rounded-lg border-2 ${statusClasses}`;
  statusDiv.classList.remove('hidden');
  statusIcon.textContent = overallIcon;
  statusBadge.className = `px-4 py-2 rounded-full text-sm font-bold ${badgeClasses}`;
  statusBadge.textContent = overallStatus;

  // Descripción del estado
  let description = '';
  if (criticalCount > 0) {
    description = `Se detectaron ${criticalCount} parámetro(s) en estado crítico que requieren atención médica inmediata.`;
  } else if (warningCount > 0) {
    description = `Se detectaron ${warningCount} parámetro(s) que requieren seguimiento médico y modificaciones.`;
  } else {
    description = `Todos los signos vitales evaluados se encuentran dentro de parámetros normales según OMS.`;
  }
  statusDescription.innerHTML = `<p class="font-medium">${description}</p>`;

  // Lista de signos vitales
  vitalSignsStatus.innerHTML = evaluations.map(evaluation => {
    const icon = evaluation.level === 'critical' ? '🔴' : evaluation.level === 'warning' ? '🟡' : '🟢';
    return `<li class="flex justify-between"><span>${icon} ${evaluation.name}:</span><span class="font-medium">${evaluation.value} - ${evaluation.status}</span></li>`;
  }).join('');

  // Recomendaciones prioritarias
  const allRecommendations = evaluations
    .filter(evaluation => evaluation.recommendations && evaluation.recommendations.length > 0)
    .flatMap(evaluation => evaluation.recommendations)
    .slice(0, 8); // Máximo 8 recomendaciones

  priorityRecommendations.innerHTML = allRecommendations
    .map(rec => `<li class="text-gray-700">• ${rec}</li>`)
    .join('');

  // Actualizar alertas individuales
  updateIndividualAlerts(evaluations);
}

// Función auxiliar para evaluar signos vitales
function evaluateVitalSign(type: string, value: number, ranges: any[]) {
  for (const range of ranges) {
    if (value >= range.min && value <= range.max) {
      return {
        level: range.level,
        status: range.status,
        recommendations: range.recommendations || []
      };
    }
  }
  return { level: 'normal', status: 'Normal', recommendations: [] };
}

// Función para actualizar alertas individuales
function updateIndividualAlerts(evaluations: any[]) {
  const alertsContainer = document.getElementById('individualAlerts')!;
  alertsContainer.innerHTML = '';

  evaluations
    .filter(evaluation => evaluation.level !== 'normal')
    .forEach((evaluation, index) => {
      const alertClasses = evaluation.level === 'critical' 
        ? 'bg-red-50 border-red-200 text-red-800' 
        : 'bg-yellow-50 border-yellow-200 text-yellow-800';
      
      const alert = document.createElement('div');
      alert.className = `p-3 md:p-4 rounded-md border ${alertClasses}`;
      alert.innerHTML = `
        <div class="flex">
          <div class="flex-shrink-0">
            <span class="text-base md:text-lg">${evaluation.level === 'critical' ? '🚨' : '⚠️'}</span>
          </div>
          <div class="ml-2 md:ml-3 flex-1">
            <h4 class="text-xs md:text-sm font-bold">${evaluation.name}: ${evaluation.status}</h4>
            <p class="text-xs md:text-sm mt-1">Valor actual: ${evaluation.value}</p>
            ${evaluation.recommendations.length > 0 ? `
              <div class="mt-2">
                <p class="text-xs font-medium">Recomendaciones:</p>
                <ul class="text-xs mt-1 space-y-1">
                  ${evaluation.recommendations.map((rec: string) => `<li>• ${rec}</li>`).join('')}
                </ul>
              </div>
            ` : ''}
          </div>
        </div>
      `;
      alertsContainer.appendChild(alert);
    });
}

// Event listeners para actualización en tiempo real
const vitalSignInputs = [
  document.getElementById('heartRate') as HTMLInputElement,
  document.getElementById('temperature') as HTMLInputElement,
  document.getElementById('oxygenSaturation') as HTMLInputElement,
  document.getElementById('respiratoryRate') as HTMLInputElement,
  document.getElementById('systolicPressure') as HTMLInputElement,
  document.getElementById('diastolicPressure') as HTMLInputElement,
  document.getElementById('weight') as HTMLInputElement,
  document.getElementById('height') as HTMLInputElement
];

vitalSignInputs.forEach((input: HTMLInputElement | null) => {
  if (input) {
    input.addEventListener('input', debounce(updatePatientHealthStatus, 500) as EventListener);
  }
});

// Función de debounce para evitar demasiadas actualizaciones
function debounce(func: Function, wait: number): Function {
  let timeout: NodeJS.Timeout;
  return function executedFunction(...args: any[]) {
    const later = () => {
      clearTimeout(timeout);
      func(...args);
    };
    clearTimeout(timeout);
    timeout = setTimeout(later, wait);
  };
}

// Función para cancelar
document.getElementById('cancelBtn')!.addEventListener('click', function() {
  if (confirm('¿Está seguro de que desea cancelar? Se perderán los datos ingresados.')) {
    window.history.back();
  }
});
</script>