      input.style.borderColor = '#ef4444';
      alertType = 'error';
      alertTitle = '🚨 Taquicardia Significativa';
      alertMessage = `Frecuencia cardíaca de ${heartRate} lpm requiere evaluación inmediata.`;
      recommendations = [
        'Evaluación cardiológica URGENTE',
        'Electrocardiograma inmediato',
        'Control de signos vitales',
        'Suspensión de esfuerzos intensos',
        'Considerar derivación a emergencias'
      ];
    } else {
      input.style.borderColor = '#10b981';
      input.title = 'Frecuencia cardíaca normal';
      return;
    }

    // Mostrar alerta con SweetAlert
    if (typeof (window as any).showSweetAlert === 'function') {
      const recommendationsText = recommendations.join('\n• ');
      (window as any).showSweetAlert(
        alertType, 
        alertTitle, 
        `${alertMessage}\n\nRecomendaciones OMS:\n• ${recommendationsText}`
      );
    }
    
    input.title = alertMessage;
  }

  // Función mejorada para evaluación de temperatura según OMS
  temperatureInput.addEventListener('input', function() {
    const temperature = parseFloat(this.value);
    if (temperature) {
      evaluateTemperature(temperature);
    }
  });

  function evaluateTemperature(temperature: number) {
    const input = temperatureInput;
    let alertType = '';
    let alertTitle = '';
    let alertMessage = '';
    let recommendations: string[] = [];

    if (temperature < 36.0) {
      input.style.borderColor = '#3b82f6';
      alertType = 'info';
      alertTitle = '🥶 Hipotermia';
      alertMessage = `Temperatura de ${temperature}°C está por debajo del rango normal (36.1-37.2°C).`;
