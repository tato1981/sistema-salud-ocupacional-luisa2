---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`camera-capture-container ${className}`}>
  <div class="relative w-full aspect-video bg-gray-900 rounded-lg overflow-hidden mb-4">
    <video id="cameraFeed" autoplay playsinline class="w-full h-full object-cover"></video>
    <canvas id="photoCanvas" class="hidden"></canvas>
    
    <div id="cameraOverlay" class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-50 hidden">
      <p class="text-white text-lg font-medium">Cámara desactivada</p>
    </div>
  </div>

  <div class="flex gap-2 justify-center">
    <button
      id="startCameraBtn"
      type="button"
      class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z" />
      </svg>
      Iniciar Cámara
    </button>

    <button
      id="captureBtn"
      type="button"
      class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2 hidden"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4 5a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V7a2 2 0 00-2-2h-1.586a1 1 0 01-.707-.293l-1.121-1.121A2 2 0 0011.172 3H8.828a2 2 0 00-1.414.586L6.293 4.707A1 1 0 015.586 5H4zm6 9a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
      </svg>
      Capturar Foto
    </button>
  </div>
</div>

<script>
  class CameraCapture {
    private video: HTMLVideoElement;
    private canvas: HTMLCanvasElement;
    private startBtn: HTMLButtonElement;
    private captureBtn: HTMLButtonElement;
    private stream: MediaStream | null = null;

    constructor() {
      this.video = document.getElementById('cameraFeed') as HTMLVideoElement;
      this.canvas = document.getElementById('photoCanvas') as HTMLCanvasElement;
      this.startBtn = document.getElementById('startCameraBtn') as HTMLButtonElement;
      this.captureBtn = document.getElementById('captureBtn') as HTMLButtonElement;

      this.initEvents();
      
      // Expose cleanup method globally
      (window as any).cameraCapture = {
        cleanup: () => this.stopCamera()
      };
    }

    private initEvents() {
      this.startBtn?.addEventListener('click', () => this.startCamera());
      this.captureBtn?.addEventListener('click', () => this.capturePhoto());
    }

    async startCamera() {
      try {
        this.stream = await navigator.mediaDevices.getUserMedia({ 
          video: { 
            facingMode: 'environment',
            width: { ideal: 1280 },
            height: { ideal: 720 }
          } 
        });
        
        this.video.srcObject = this.stream;
        this.startBtn.classList.add('hidden');
        this.captureBtn.classList.remove('hidden');
      } catch (error) {
        console.error('Error accessing camera:', error);
        alert('No se pudo acceder a la cámara. Por favor, verifique los permisos.');
      }
    }

    stopCamera() {
      if (this.stream) {
        this.stream.getTracks().forEach(track => track.stop());
        this.stream = null;
        this.video.srcObject = null;
        this.startBtn.classList.remove('hidden');
        this.captureBtn.classList.add('hidden');
      }
    }

    capturePhoto() {
      if (!this.stream) return;

      const context = this.canvas.getContext('2d');
      if (!context) return;

      // Set canvas dimensions to match video
      this.canvas.width = this.video.videoWidth;
      this.canvas.height = this.video.videoHeight;

      // Draw current video frame to canvas
      context.drawImage(this.video, 0, 0, this.canvas.width, this.canvas.height);

      // Convert to blob and trigger callback
      this.canvas.toBlob((blob) => {
        if (blob) {
          const url = URL.createObjectURL(blob);
          
          // Call global callback if defined
          if (typeof (window as any).onPhotoCapture === 'function') {
            (window as any).onPhotoCapture(blob, url);
          }

          // Optional: Stop camera after capture
          // this.stopCamera();
        }
      }, 'image/webp', 0.8);
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new CameraCapture();
  });
</script>